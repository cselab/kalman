### Implementation 1:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.mean(bins)) * np.exp(item - np.mean(bins)) + np.sin(np.pi * (item / np.mean(bins)))

### Implementation 2:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.sum(bins)) * np.exp(item - np.sum(bins)) + np.log(1 + np.sin(np.pi * item / np.sum(bins)))

### Implementation 3:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.std(bins)) * np.exp(item - np.std(bins)) + np.cos(np.pi * (item / np.std(bins)))

### Implementation 4:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.var(bins)) * np.exp(item - np.var(bins)) + np.tanh(np.pi * (item / np.var(bins)))

### Implementation 5:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.min(bins)) * np.exp(item - np.min(bins)) + np.log10(1 + np.sin(np.pi * item / np.min(bins)))

### Implementation 6:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.max(bins)) * np.exp(item - np.max(bins)) + np.log2(1 + np.cos(np.pi * item / np.max(bins)))

### Implementation 7:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.argmin(bins)) * np.exp(item - np.argmin(bins)) + np.sqrt(np.pi * (item / np.argmin(bins)))

### Implementation 8:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.argmax(bins)) * np.exp(item - np.argmax(bins)) + np.cbrt(np.pi * (item / np.argmax(bins)))

### Implementation 9:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.any(bins)) * np.exp(item - np.any(bins)) + np.log(1 + np.tanh(np.pi * (item / np.any(bins))))
