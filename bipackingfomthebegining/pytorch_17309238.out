def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate remaining capacity
    rem = bins[:,0] - bins[:,1]
    # Check if item fits
    fits = rem >= item
    # Compute priority as remaining capacity divided by item
    priority = np.where(fits, rem / item, 0)
    return priority
