def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.add.at(np.zeros_like(bins), bins > item, np.exp(item - bins)) + np.log(1 + item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log2(1 + np.mod(item, bins)) * np.exp(item - np.mean(bins))

