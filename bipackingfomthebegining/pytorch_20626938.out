def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    remaining = np.maximum(remaining, 0)
    # Calculate how well the item fits (lower remaining is better)
    fit_score = 1 / (remaining + 1e-8)
    # Decay with remaining space
    decay = np.exp(-remaining)
    # Combine fit and decay
    priority = fit_score * decay
    return priority
