def priority(item: float, bins: np.ndarray) -> np.ndarray:
    can_fit = bins >= item
    fit_score = can_fit.astype(float)
    # Compute how much space is left
    space = bins - item
    # Compute how full the bin is before adding the item
    fullness = bins / (bins + item)
    # Combine space and fullness
    priority = np.where(can_fit, space * (1 - fullness), 0)
    return priority
