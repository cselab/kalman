7.142857142857142function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    remaining = np.maximum(remaining, 0)
    # Higher priority for bins where the item fits well
    fit_priority = 1 / (remaining + 1e-8)
    # Higher priority for smaller bins
    size_priority = 1 / bins
    # Combine fit and size priorities
    priority = fit_priority * size_priority
    return priority
