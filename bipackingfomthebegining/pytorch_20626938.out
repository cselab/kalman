def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Compute the loss for each bin
    loss = np.where(bins >= item, bins - item, item - bins)
    # Scale the loss to [-1, 1]
    min_loss = np.min(loss)
    max_loss = np.max(loss)
    scaled_loss = (loss - min_loss) / (max_loss - min_loss) * 2 - 1
    return scaled_loss
