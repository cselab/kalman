def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Compute the remaining capacity in each bin
    remaining = np.maximum(1 - bins, 0)
    # Compute the ratio of item to remaining capacity
    ratio = item / (remaining + 1e-8)  # avoid division by zero
    # Compute a term using log
    term1 = np.log(remaining + 1)
    # Compute another term using cos
    term2 = np.cos(np.pi * (item - bins) / (item + 1))
    # Use np.where to set priority to zero if remaining is zero
    priority = ratio * (term1 + term2)
    priority = np.where(remaining == 0, 0, priority)
    return priority
