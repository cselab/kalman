144.89795918367346function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the fit factor for each bin
    fit = item / bins
    # Calculate the space left after adding the item
    space_left = bins - item
    # Calculate the utilization
    utilization = (bins - space_left) / bins
    # Combine the factors with weights
    priority = (fit * 0.3) + (space_left * 0.4) + (utilization * 0.3)
    return priority
