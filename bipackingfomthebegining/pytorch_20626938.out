def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Worst Fit heuristic: prioritize bins with the most remaining space after placing the item
    can_fit = bins >= item
    remaining = bins - item
    priority = np.zeros_like(bins)
    priority[can_fit] = remaining[can_fit]
    # For bins that cannot fit, set priority to a very low value
    priority[~can_fit] = -np.inf
    # To implement worst fit, we can invert the priority by taking the negative
    priority = -priority
    return priority
