def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    # Avoid negative values by capping at 0
    remaining = np.maximum(remaining, 0)
    # Calculate how well the item fits (lower remaining is better)
    fit_score = 1 / (remaining + 1e-8)
    # Combine with the remaining space to penalize larger gaps
    priority = fit_score * np.exp(-remaining)
    return priority
