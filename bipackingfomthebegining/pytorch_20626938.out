def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Create an array of zeros
    priority = np.zeros_like(bins)
    # Iterate through each bin
    for i in range(len(bins)):
        if bins[i] >= item:
            priority[i] = 1
            break
    return priority
