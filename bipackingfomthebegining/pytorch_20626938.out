def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.maximum(1 - bins, 0)
    # Use np.where to set available to zero if bins are full
    available = np.where(available < 0, 0, available)
    # Compute the ratio of item to available space
    ratio = item / available
    # Use np.log to compute a term
    term = np.log(available + 1)
    # Use np.sin to compute another term
    term2 = np.sin(np.pi * (item - bins) / (item + 1))
    priority = ratio * (term + term2)
    # Use np.putmask to set priority to zero where bins are full
    priority = np.putmask(priority, bins >= 1, 0)
    return priority
