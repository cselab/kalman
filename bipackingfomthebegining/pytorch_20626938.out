def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    remaining = np.maximum(remaining, 0)
    # Weighted sum of remaining space and bin capacity
    priority = remaining * 0.5 + (1 / bins) * 0.5
    # Invert to prioritize lower remaining
    priority = 1 / priority
    return priority
