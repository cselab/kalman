def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    remaining = np.maximum(remaining, 0)
    # Exponential decay with remaining space
    decay = np.exp(-remaining)
    # Inverse of bin size
    size_factor = 1 / bins
    # Combine decay and size factor
    priority = decay * size_factor
    return priority
score::
7.142857142857142function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    remaining = np.maximum(remaining, 0)
    # Calculate how well the item fits
    fit_score = 1 / (remaining + 1e-8)
    # Calculate bin occupancy
    occupancy = bins - remaining
    # Combine fit and occupancy
    priority = fit_score + occupancy
    return priority
score::
7.142857142857142function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    remaining = np.maximum(remaining, 0)
    # Ratio of remaining space to capacity
    ratio = remaining / bins
    # Inverse ratio to prioritize smaller remaining
    priority = 1 / (ratio + 1e-8)
