def priority(item: float, bins: np.ndarray) -> np.ndarray:
    base = item / (item + bins)
    term1 = np.log(bins + 8)
    term2 = np.sin(np.pi * (item - bins) / (item + 1))
    priority = base * (term1 + term2)
    # Use a logical operation to adjust priority
    priority = np.where(priority < 0, 0, priority)
    return priority
 
