72.85714285714286function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    fit_mask = bins >= item
    remaining_space = bins[fit_mask] - item
    # For bins that can't fit, set remaining_space to a large negative number
    remaining_space_all = np.full_like(bins, -np.inf)
    remaining_space_all[fit_mask] = remaining_space
    # Priority is the remaining space; lower remaining space is better (since we want to minimize)
    priority = remaining_space_all
    return priority
