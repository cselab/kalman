def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = np.maximum(0, 1 - bins)  # Assuming bins are filled from 0 to 1
    fit = np.where(remaining >= item, remaining - item, -np.inf)
    return fit
