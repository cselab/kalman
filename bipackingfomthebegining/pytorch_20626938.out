144.89795918367346function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    suitable = bins >= item
    if np.any(suitable):
        first_suitable = np.where(suitable)[0][0]
        priority = np.zeros_like(bins)
        priority[first_suitable] = 1
    else:
        priority = np.zeros_like(bins)
    return priority
