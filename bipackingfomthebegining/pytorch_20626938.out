144.89795918367346function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Compute whether each bin can fit the item
    can_fit = bins >= item
    # Compute loss for bins that can fit
    loss = np.where(can_fit, bins - item, np.inf)
    # Compute priority as 1/(loss + 1)
    priority = np.where(can_fit, 1.0 / (loss + 1), 0.0)
    return priority
