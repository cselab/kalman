def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Greedy by space: prioritize bins with the smallest capacity that can fit the item
    can_fit = bins >= item
    # Compute the capacity ratio: bins[i] / (bins[i] + item)
    capacity_ratio = bins / (bins + item)
    priority = np.zeros_like(bins)
    priority[can_fit] = capacity_ratio[can_fit]
    priority[~can_fit] = -np.inf
    return priority
