def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the remaining space in each bin
    space_left = bins - item
    # Ensure that space_left is non-negative, else set to a very low value
    space_left = np.where(space_left >= 0, space_left, -1e9)
    # Calculate the fit factor as item / bin_size
    fit = item / bins
    # Combine space_left and fit into the priority score
    priority = space_left + fit
    return priority
