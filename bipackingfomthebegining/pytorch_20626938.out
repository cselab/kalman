7.142857142857142function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Best Fit heuristic: prioritize bins with least remaining space after placing the item
    can_fit = bins >= item
    remaining = bins - item
    # Compute priority as the remaining space
    priority = np.zeros_like(bins)
    priority[can_fit] = remaining[can_fit]
    # For bins that cannot fit, set priority to a very low value
    priority[~can_fit] = -np.inf
    return priority
