103.16326530612245function:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    fit_mask = bins >= item
    remaining = bins - item
    # For bins that can fit, priority is based on their remaining space; smaller space gets higher priority
    priority = np.where(fit_mask, 1/(remaining + 1e-8), -1)
    return priority
