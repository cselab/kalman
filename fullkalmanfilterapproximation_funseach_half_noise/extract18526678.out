def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P_new = F @ P @ F.T + Q
    y = z - xp
    S = P_new + R + F.min(axis=1)[:, None] * 1.2
    inv_S = np.linalg.inv(S)
    K = (P_new @ inv_S) * 0.85
    x = xp + K @ y
    P = (P_new - K @ S @ K.T) * 0.95
    return xp, P, y, S, K, x

