🏆 Best Function Code:

def aproximate(x, F, P, Q, z, R):
    noise = np.random.normal(0, 0.0001, P.shape)
    xp = F @ x
    P = F @ P @ F.T + Q + noise
    y = z - xp
    damping = 0.95 + 0.05 * np.mean(y**2)
    mean_F = F.mean(axis=1)[:, None]
    S = P + R + mean_F * 2.5
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    K *= damping
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    P = P - P.min() * 0.5
    return xp, P, y, S, K, x

