### Solution Code:
```python
import numpy as np

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = np.linalg.inv(P + F @ Q @ F.T) @ F @ P.T
    x = xp + K @ y
    return xp, P, y, S, K, x

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = np.linalg.inv(S) @ F @ P.T
    x = xp + K @ y
    return xp, P, y, S, K, x

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = F @ Q @ F.T + R
    K = np.linalg.inv(S) @ F @ P.T
    x = xp + K @ y
    return xp, P, y, S, K, x

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = np.linalg.inv(P) @ F.T @ np.linalg.inv(S)
    x = xp + K @ y
    return xp, P, y, S, K, x

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = np.linalg.inv(S) @ F @ P.T
    x = xp + K @ y
    return xp, P, y, S, K, x

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = F @ Q @ F.T + R
    K = np.linalg.inv(S) @ F @ P.T
    x = xp + K @ y
    return xp, P, y, S, K, x

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = np.linalg.inv(P + Q) @ F @ P.T
    x = xp + K @ y
    return xp, P, y, S, K, x

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = F @ Q @ F.T + R
    K = np.linalg.inv(S) @ F @ P.T
    x = xp + K @ y
    return xp, P, y, S, K, x

