    x = xp + K @ y
    return xp, P, y, S, K, x

### Implementation 2: Adaptive Kalman Filter with Dynamic State Transition

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = np.linalg.inv(P @ F.T) @ P @ F @ y
    x = xp + K @ y
    return xp, P, y, S, K, x

