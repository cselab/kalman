import numpy as np

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = F @ P @ F.T + Q
    K = P @ F.T @ np.linalg.inv(S)
    x = x + K @ y
    return xp, P, y, S, K, x

