### Solution 1:
def predict(x, F, P, Q, z, R):
    xp = x + F @ x
    y = z - x
    S = F @ P @ F.T + Q
    K = np.linalg.inv(S) @ F @ P.T
    x = x + K @ y
    return xp, P, y, S, K, x

