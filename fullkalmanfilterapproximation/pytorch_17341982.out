    g = a * (np.sum(b) / (np.mean(b) + 1e-8))
    h = c + np.mean(d, axis=1)
    i = e - np.std(f, axis=0)
    j = c.dot(d.T)
    k = e.dot(f.T)
    return g, c, h, i, j, k
