def aproximate(a, b, c, d, e, f):
    g = a * (np.sum(b, axis=0) + 1)
    h = c * (np.mean(d, axis=1) + 1)
    i = e / (np.mean(f, axis=1) + 1)
    j = c.dot(d.T) + np.sum(c, axis=0)
    k = e.dot(f.T) + np.sum(e, axis=0)
    return (g, c, h, i, j, k)
