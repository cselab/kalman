    g = a * (b[:,0] + b[:,1])
    h = c + (d[:,0] + d[:,1])
    i = e - (f[:,0] + f[:,1])
    j = np.dot(c, d)
    k = np.dot(e, f)
    return g, c, h, i, j, k
