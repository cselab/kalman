def aproximate(a, b, c, d, e, f):
    g = a + np.trace(b) * np.sum(c)
    h = c - np.max(d, axis=0) * np.mean(f)
    i = e + np.min(f, axis=1) * np.sum(b)
    j = np.dot(c, d.T) + np.trace(f)
    k = np.dot(e, f.T) * np.mean(a)
    return (g, c, h, i, j, k)
