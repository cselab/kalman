def aproximate(a, b, c, d, e, f):
    g = a * (b.sum() / b.size)
    h = c + (d.max() - d.min())
    i = e - (f.max() + f.min())
    j = (c * d).sum()
    k = (e * f).sum()
    return g, c, h, i, j, k
