function:
def aproximate(a, b, c, d, e, f):
    g = a + np.sum(b, axis=0, keepdims=True)
    h = c * np.mean(d, axis=1, keepdims=True)
    i = e / np.mean(f, axis=1, keepdims=True)
    j = c.dot(d.T) + np.sum(c, axis=0)
    k = e.dot(f.T) + np.sum(e, axis=0)
    return (g, c, h, i, j, k)
score: 55601.71507790106
function:
def aproximate(a, b, c, d, e, f):
    g = a * np.sum(b, axis=1, keepdims=True)
    h = c * np.mean(d, axis=0, keepdims=True)
    i = e + np.sum(f, axis=1, keepdims=True)
    j = np.dot(c, d) + np.sum(c, axis=1)
