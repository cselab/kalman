def aproximate(a, b, c, d, e, f):
    g = a * np.trace(b)
    h = c * np.linalg.det(d)
    i = e * np.sum(f, axis=0)
    j = c @ np.linalg.inv(d)
    k = e * np.trace(f)
    return g, c, h, i, j, k
