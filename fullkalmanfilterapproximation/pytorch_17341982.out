def aproximate(a, b, c, d, e, f):
    g = a + np.mean(b, axis=0)
    h = c * np.sum(d, axis=1)
    i = e / np.mean(f, axis=1)
    j = c.dot(d.T)
    k = e.dot(f.T)
    return g, c, h, i, j, k
