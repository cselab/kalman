def aproximate(a, b, c, d, e, f):
    g = a + np.sum(b) * np.mean(c)
    h = c * np.mean(d) + e * np.max(f)
    i = e / np.mean(f) + a * np.sum(d)
    j = c.dot(d.T) + e.dot(f.T)
    k = np.dot(a, f.T) + np.trace(b)
    return (g, c, h, i, j, k)
