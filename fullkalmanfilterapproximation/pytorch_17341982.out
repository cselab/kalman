    g = a + np.sum(b, axis=1, keepdims=True)
    h = c + np.mean(d, axis=0)
    i = e / (np.std(f, axis=0) + 1e-8)
    j = c.dot(d)
    k = e.dot(f.T)
    return g, c, h, i, j, k
