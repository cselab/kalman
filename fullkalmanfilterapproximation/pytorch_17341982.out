    g = a * np.exp(np.mean(b, axis=0))
    h = c + np.sum(d, axis=1)
    i = e / (np.min(f, axis=1) + 1)
    j = np.dot(c, d.T)
    k = np.dot(e, f.T)
    return g, c, h, i, j, k
