    g = a * np.sum(b, axis=0)
    h = c + np.mean(d, axis=1)
    i = e / np.sum(f, axis=0)
    j = np.dot(c, d.T)
    k = np.dot(e, f.T)
    return (g, c, h, i, j, k)
