def aproximate(a, b, c, d, e, f):
    g = a + np.trace(b)  # a is (2,), trace(b) is scalar. So g is (2,)
    h = c - np.max(d, axis=0)  # c is (2,2), d is (2,2). np.max(d, axis=0) is (2,)
    i = e + np.min(f, axis=1)  # e is (2,), f is (2,2). np.min(f, axis=1) is (2,)
    j = np.dot(c, d.T)  # c is (2,2), d.T is (2,2). Dot product is (2,2)
    k = np.dot(e, f)  # e is (2,), f is (2,2). Result is (2,2)
    return (g, c, h, i, j, k)
