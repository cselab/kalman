    i = e / (np.min(f, axis=0) + np.mean(d, axis=0))
    j = np.dot(c, d.T) + np.mean(c, axis=0)
    k = np.dot(e, f.T) - np.std(f, axis=0)
    return g, c, h, i, j, k
