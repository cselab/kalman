def aproximate(a, b, c, d, e, f):
    g = a + np.sum(b, axis=1, keepdims=True)
    h = c * np.min(d, axis=0)
    i = e / np.sum(f, axis=0)
    j = np.matmul(c, d)
    k = np.matmul(e, f.T)
    return g, c, h, i, j, k
