    g = a * (np.mean(b, axis=0) + np.std(b, axis=0))
    h = c + np.mean(d, axis=1)
    i = e - np.sum(f, axis=1)
    j = c.dot(d.T)
    k = e.dot(f.T)
    return g, c, h, i, j, k
