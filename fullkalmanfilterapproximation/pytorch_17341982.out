def aproximate(a, b, c, d, e, f):
    g = a * (b[0,0] + b[1,1])
    h = c * (d[0,0] + d[1,1])
    i = e * (f[0,0] + f[1,1])
    j = c.dot(d.T)
    k = e.dot(f.T)
