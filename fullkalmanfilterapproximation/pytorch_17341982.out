    g = a + np.sum(b, axis=1)
    h = c * np.min(d, axis=0)
    i = e + np.trace(f)
    j = np.dot(c, d.T)
    k = np.dot(e, f.T)
    return g, c, h, i, j, k
score: 2.0742094832589832
function:
def aproximate(a, b, c, d, e, f):
    g = a + np.sum(b)
    h = c * np.linalg.norm(d)
    i = e - np.trace(f)
    j = np.dot(c, d)
    k = np.dot(e, f)
    return (g, c, h, i, j, k)
