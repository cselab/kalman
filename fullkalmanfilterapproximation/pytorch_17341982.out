    g = a * np.mean(b, axis=0) + np.sum(c, axis=0)
    h = c * np.sum(d, axis=0) - np.mean(f, axis=0)
    i = e / (np.min(f, axis=0) + np.std(f, axis=0))
    j = np.dot(c, d.T) + np.dot(c, f.T)
    k = np.dot(e, f.T) - np.dot(e, d.T)
    return g, c, h, i, j, k
