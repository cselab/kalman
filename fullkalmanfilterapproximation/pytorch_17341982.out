def aproximate(a, b, c, d, e, f):
    g = a + (b[:,1] * d[:,0])
    h = c * (d.sum(axis=0) + 1)
    i = e / (f.sum(axis=1) + 1)
    j = np.dot(c, d.T)
    k = np.dot(e, f.T)
    return g, c, h, i, j, k
