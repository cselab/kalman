def aproximate(a, b, c, d, e, f):
    g = a * np.mean(b, axis=1) + np.sum(c, axis=0)
    h = c * np.mean(d, axis=1) + np.sum(f, axis=0)
    i = e / (np.mean(f, axis=1) + np.mean(b, axis=0))
    j = np.dot(c, d) + np.dot(f, f.T)
    k = np.dot(e, f) + np.dot(c, c.T)
    return g, c, h, i, j, k
