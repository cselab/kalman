def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = (P @ S.T) / (S @ S.T + 1e-8)
    K = K * (np.sign(K.sum()))
    x = xp + K @ y
    return xp, P, y, S, K, x
