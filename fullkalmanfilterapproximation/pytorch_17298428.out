def predict(x, F, P, Q, z, R):
    # Square root implementation
    xp = F @ x
    y = z - xp
    S = Q + R
    # Compute square root of P and S
    sqrt_P = np.linalg.cholesky(P)
    sqrt_S = np.linalg.cholesky(S)
    # Compute K using square roots
    K = (sqrt_P @ sqrt_S.T) / (sqrt_S @ sqrt_S.T)
    x = xp + K @ y
    return xp, P, y, S, K, x
