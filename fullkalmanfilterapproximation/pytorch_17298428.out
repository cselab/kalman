def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = (P @ S.T) / (S.T @ S + 0.3 * np.log(1 + S.sum()))
    x = xp + K @ y
    K = K * (1 + 0.4 * (S.max() ** 2))
    return xp, P, y, S, K, x
