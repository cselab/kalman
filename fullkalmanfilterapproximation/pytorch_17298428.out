def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    diag_S = np.diag(S)
    threshold = np.mean(diag_S)
    diag_K = np.where(diag_S > threshold, 1/diag_S, 0)
    K = np.diag(diag_K)
    x = xp + K @ y
    return xp, P, y, S, K, x
