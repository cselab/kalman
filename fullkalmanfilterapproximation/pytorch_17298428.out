    xp = F @ x
    y = z - xp
    S = Q + R
    inv_S = np.linalg.inv(S + 1e-8 * np.eye(S.shape[0]))
    K = P @ inv_S @ y
    x = xp + K @ y
    return xp, P, y, S, K, x
