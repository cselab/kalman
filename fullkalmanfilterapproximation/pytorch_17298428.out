def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = (P @ S.T) / (S.T @ S + 0.6 * np.log(S.sum()))
    x = xp + K @ y
    K = K + 0.1 * np.mean(K)
    update_K = K + 0.1 * (K.mean() / (1 + K.std()))
    x = xp + update_K @ y
    return xp, P, y, S, K, x 
