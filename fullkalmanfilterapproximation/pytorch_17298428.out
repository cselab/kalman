    xp = F @ x
    y = z - xp
    S = Q * R  # Element-wise multiplication
    K = (P @ S.T) / (S.T @ S + np.log(1 + np.mean(S)))
    x = xp + K @ y
    K = K * (1 + 0.5 * np.sum(np.sin(K), axis=0))  # Add sine sum
    return xp, P, y, S, K, x
