def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    # Robust estimation using Huber loss
    # Compute weights
    sigma = np.std(y)
    rho = 1 / (2 * sigma**2)
    weights = np.exp(-rho * y**2)
    # Weighted S
    S_robust = (weights[:, None] * S)
    # Weighted K
    K = (P @ S.T) / (S @ S.T + 1e-5 * S_robust)
    x = xp + K @ y
    return xp, P, y, S, K, x
