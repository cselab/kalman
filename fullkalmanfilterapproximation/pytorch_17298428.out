def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = (P @ S.T) / (S @ S.T + 0.3)
    x = xp + K @ y
    # Add a term to K that penalizes large K values
    K = K + (K.max() * y.mean()) * 0.1
    return xp, P, y, S, K, x
