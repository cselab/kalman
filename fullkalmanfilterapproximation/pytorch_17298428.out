def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = (P @ S.T) / (S @ S.T + np.log(1 + np.sqrt(np.mean(S**2))))
    x = xp + K @ y
    K = K * (1 + 0.6 * np.sum(np.tanh(K), axis=0))  # Add tanh sum
    return xp, P, y, S, K, x
