def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    # SVD of S
    U, S, V = np.linalg.svd(S)
    # Compute K using SVD
    inv_S = np.diag(1/S)
    K = (P @ V.T) @ inv_S @ (U.T @ y)
    x = xp + K
    return xp, P, y, S, K, x
