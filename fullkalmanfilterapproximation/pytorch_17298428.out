    xp = F @ x
    y = z - xp
    S = Q + R
    K = (P @ S.T) / (S.T @ S + 0.5 * (1 + np.tanh(S.mean())))
    x = xp + K @ y
    K = K * (1 + 0.3 * np.tanh(K.mean()))
    return xp, P, y, S, K, x
