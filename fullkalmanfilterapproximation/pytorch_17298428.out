def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    norm_y = np.linalg.norm(y)
    K = 0.1 * norm_y * np.eye(*P.shape)
    x = xp + K @ y
    return xp, P, y, S, K, x
