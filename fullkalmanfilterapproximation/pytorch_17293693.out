#### Example 1: 

def predict(x, F, P, Q, z, R):
    xp = x
    y = z - x
    S = R
    K = np.ones_like(P)
    x = x + 0.1 * y
    return xp, P, y, S, K, x

#### Example 2: 

def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = Q + R
    K = 0.5 * np.eye(x.shape[0])
    x = xp + K @ y
    return xp, P, y, S, K, x
