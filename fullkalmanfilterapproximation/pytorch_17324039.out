def predict(x, F, P, Q, z, R):
    # Create a diagonal matrix where each diagonal is x[i]
    F_custom = np.diag(x)
    xp = F_custom @ x
    y = z - xp
    S = F_custom @ P @ F_custom.T + Q
    K = P @ F_custom.T @ np.linalg.inv(S)
    x = xp + K @ y
    return xp, P, y, S, K, x
