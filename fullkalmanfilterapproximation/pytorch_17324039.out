def predict(x, F, P, Q, z, R):
    xp = F @ x + np.random.normal(0, 0.1, x.shape)
    y = z - xp
    S = np.diag(np.diag(F @ P @ F.T + Q))
    K = P @ F.T @ np.linalg.inv(S)
    x = xp + K @ y
    return xp, P, y, S, K, x 
