def predict(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    S = F @ P @ F.T + Q
    K = np.linalg.solve(S, F @ P.T).T
    x = xp + K @ y
    return xp, P, y, S, K, x
