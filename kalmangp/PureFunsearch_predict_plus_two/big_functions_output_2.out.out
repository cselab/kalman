def fun(i1, i2, i3, i4, i5, i6):
    a = i1 + i5 + i1 + i5 + i1 + i5  # 3*(i1 + i5)
    b = (i3 - i6) * 6  # 6*(i3 - i6)
    b = b * i4.T  # (6*(i3 -i6)) * i4.T, which is matrix multiplication
    b = b - i6  # subtract i6 from b
    c = a @ b  # matrix multiply a and b
    c = c - (a @ i6) * 2  # subtract 2*(a @ i6) from c
    d = c @ (i4 * 3)  # matrix multiply c with (i4 scaled by 3)
    d = d + 3 * d  # same as 4*d
    e = c.T  # transpose of c
    f = e + i5  # add i5 to e
    g = i2 + (i6 * i4).T  # i6 * i4 is matrix multiplication, then transpose
    h = g @ i6.T  # matrix multiply g with i6.T
    i = h + i6  # add i6 to h
    return (f, i, d - f, i - h)

