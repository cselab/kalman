def fun(i1, i2, i3, i4, i5, i6):
    a = i1 + i5
    b = i3 - i6
    b = b * 3
    b = b - i3
    c = a @ b
    c = c - a @ i6
    d = (i6 @ (i4.T @ c * 3)) * 3
    d = d * 3
    e = c.T
    f = e + i5
    g = i2 + (i4 @ i6)
    h = g @ i6
