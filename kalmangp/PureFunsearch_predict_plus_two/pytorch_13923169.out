def fun(i1, i2, i3, i4, i5, i6):
    a = i1 + i5  # shape (2,)
    b = (i3 - i6) * 3 - i3  # (i3 - i6) is (2,2), multiply by 3 (scalar) gives (2,2), then subtract i3 (2,2) gives (2,2)
    c = a @ (b - i6)  # a is (2,), (b - i6) is (2,2). So a @ (b - i6) is (2,). So c is (2,)
    d = (i6 @ i4) * 3 @ (c + c + c)  # i6 @ i4 is (2,2) * (2,2) = (2,2). Multiply by 3 (scalar) gives (2,2). Then, (c + c + c) is (2,) + (2,) + (2,) = (2,). Then, (i6 @ i4) * 3 is (2,2), then @ (c + c + c) is (2,2) @ (2,) which is (2,). So d is (2,)
