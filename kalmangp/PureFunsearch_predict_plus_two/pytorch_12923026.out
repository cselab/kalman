    g = i2 + i4  # (2,2) + (2,2) → (2,2)
    h = g @ i6  # (2,2) @ (2,2) → (2,2)
    i = h + i6.T  # (2,2) + (2,2) → (2,2)
    return (f, i, d - f, i - h)

