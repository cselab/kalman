    b = i3 - (i4 + i6)  # i4 and i6 are (2,2); their sum is (2,2). Subtracting from i3 (2,2) gives (2,2).
    c = a @ b  # (2,) @ (2,2) → (2,2)
    d = c @ (i6 @ i4)  # (2,2) @ (2,2) → (2,2)
