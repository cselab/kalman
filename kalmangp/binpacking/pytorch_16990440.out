### Example of a Priority Function:

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    # Only consider bins that can fit the item
    available[available < 0] = 0
    # Compute priority as the available space divided by the bin size
    priority = available / bins
    return priority

