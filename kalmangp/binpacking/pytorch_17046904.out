 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the remaining space in each bin
    remaining = bins[:, np.newaxis] - item
    # Find all bins that can fit the item
    fit = np.where(remaining >= 0, 1, 0)
    # Select a random bin from the fit bins
    fit_indices = np.where(fit == 1)[0]
    if len(fit_indices) == 0:
        return np.full_like(bins, -1)  # No fit bins
    random_index = np.random.choice(fit_indices)
    return np.full_like(bins, random_index)
