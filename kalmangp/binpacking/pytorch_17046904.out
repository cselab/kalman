 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Assuming bins are represented by their capacities, but need to track the number of items in each bin
    # Since bins are just capacities, we can't directly get the number of items, so this heuristic may not be directly applicable.
    # Perhaps, instead, we can represent bins by their remaining capacity, and the least loaded is the one with the highest remaining capacity.
    # So this is similar to 'Best Fit'.
    # Alternatively, if bins are represented differently, but in our case, it's just an array of capacities.
    # So perhaps, for the sake of this problem, we can treat 'least loaded' as the bin with the highest remaining capacity.
    remaining = bins - item
    remaining[remaining < 0] = -np.inf
    return remaining
