 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the remaining space in each bin
    remaining = bins[:, np.newaxis] - item
    # Find the first bin where the item can fit
    fit = np.where(remaining >= 0, 1, 0)
    # The priority is the index of the first fit
    priority = np.argmax(fit, axis=0)
    return np.full_like(bins, priority)
