 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the difference between each bin and the item
    diff = np.abs(bins - item)
    # Calculate the remaining space in each bin
    remaining = bins.max() - bins
    # Combine difference and remaining space
    priority = diff + remaining
    return priority

