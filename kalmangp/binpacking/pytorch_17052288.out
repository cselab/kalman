 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the capacity utilization of each bin
    capacity = bins + item
    utilization = bins / capacity
    # Penalize bins with higher utilization
    penalty = np.where(utilization > 0.95, 1000, 0)
    # Combine utilization and penalty
    priority = utilization + penalty
    return priority

