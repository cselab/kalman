 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the ratio of item size to each bin size
    ratio = item / bins
    # Penalize bins where the ratio exceeds 1 (item larger than bin)
    penalty = np.where(ratio > 1, 1000, 0)
    # Combine ratio and penalty to get priority
    priority = ratio + penalty
    return priority
