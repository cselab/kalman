 def priority(item: float, bins: np.ndarray):
    # Implementation 3: Higher priority for bins with lower remaining capacity
    # The priority is the remaining capacity after adding the item
    remaining_capacity = bins - item
    # Ensure that we don't have negative values, which would mean the item doesn't fit
    remaining_capacity = np.maximum(remaining_capacity, 0)
    # Assign priority as the remaining capacity
    priority = remaining_capacity
    return priority

