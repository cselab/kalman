 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the utilization of each bin
    utilization = bins / (bins + item)
    # Penalize bins with higher utilization
    penalty = np.where(utilization > 0.8, 1000, 0)
    # Combine utilization and penalty
    priority = utilization + penalty
    return priority
