    return (item + np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) * np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.log(bins + 1)) + np.tan(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

