    return (item * np.std(bins)) * np.exp(item - bins) + np.log(item + bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.cos(np.pi * (item / bins)) + np.cos(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.log(np.max(bins)) + np.log(np.max(bins)) + np.log(np.max(bins))
