    return (item * np.std(bins)) * np.exp(item - bins) + (item * np.std(bins)) * np.exp(item - bins) + (item * np.std(bins)) * np.exp(item - bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * (bins ** 2)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))
    
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

