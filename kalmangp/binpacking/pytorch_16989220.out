### Solution Code

```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item) * np.sin(np.pi * (item / bins)) + np.log(item) * np.sin(np.pi * (item / bins))

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item + bins) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.min(bins)) * np.max(bins) * np.exp(item - bins)

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item) * np.std(bins) + np.log(item) * np.std(bins)

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * np.exp(bins) * np.sin(np.pi * (item / bins))

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + bins) * np.exp(item - bins)

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    return item * (bins / np.max(bins)) * np.exp(item - bins)

def priority_10(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) * np.sin(np.pi * (item / bins)) + np.sqrt(item) * np.sin(np.pi * (item / bins))
