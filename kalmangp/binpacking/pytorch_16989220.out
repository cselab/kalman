```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.abs(item - bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(bins + 1e-10) * item

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sum(np.exp(-np.abs(bins - item)), axis=0)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(np.abs(bins - item)) * item

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.dot(bins, item) * np.mean(bins)

def priority(item: np.ndarray, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.std(bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log2(bins + 1e-10) * np.sin(item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(bins) * item

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item / (bins + 1e-10)) * np.mean(bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.tanh(item - bins) * np.std(bins)
```

