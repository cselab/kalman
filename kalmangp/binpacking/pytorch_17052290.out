 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the mean and standard deviation of the bins
    mean_bins = np.mean(bins)
    std_bins = np.std(bins)
    
    # Calculate the item's contribution to the priority
    item_contribution = np.exp(item - bins) * (item * std_bins)
    
    # Calculate the sine term with the item and bins
    sine_term = np.sin(np.pi * (item / bins))
    
    # Combine the contributions to form the priority
    priorities = item_contribution + sine_term * (item / bins)
    
    return priorities
