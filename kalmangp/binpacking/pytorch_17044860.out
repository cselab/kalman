```python
import numpy as np

def priority_0(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / bins
    return priority

def priority_1(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / (bins + 1e-8)
    return priority

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / (bins * (1 + np.std(bins)))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / (bins * np.mean(bins))

