### Solution Code
The following are 10 unique implementations of the `priority` function. Each implementation uses a different combination of mathematical operations and functions to calculate the priority scores for each bin.

```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + bins) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.var(bins)) + np.sin(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + bins) * np.exp(item - bins) + np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(item - bins) + np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.var(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))
```

