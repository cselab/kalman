def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / (bins + np.log(bins + 1e-8))

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / (bins * np.sin(np.pi * (item / bins)))

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / (bins * np.cos(np.pi * (item / bins)))

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / (bins * np.tan(np.pi * (item / bins)))

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    available = bins - item
    available[available < 0] = 0
    priority = available / (bins * np.sqrt(np.pi * (item / bins)))
```

