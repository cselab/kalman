### Implementation 1:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    can_fit = bins >= item
    remaining = bins - item
    priority = np.where(can_fit, np.exp(remaining) * item, 0)
    return priority

### Implementation 2:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    can_fit = bins >= item
    ratio = item / bins
    priority = np.where(can_fit, np.sin(np.pi * ratio) + np.cos(np.pi * ratio), 0)
    return priority

