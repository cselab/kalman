### Example for Best Fit:

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # For bins that can fit the item, compute the leftover space
    # The priority is higher for smaller leftover
    # For bins that cannot fit, priority is 0
    can_fit = bins >= item
    leftover = np.where(can_fit, bins - item, 0)
    # To prioritize smaller leftovers, we can take 1 / (leftover + 1e-8) to avoid division by zero
    priority = np.where(can_fit, 1 / (leftover + 1e-8), 0)
    return priority

