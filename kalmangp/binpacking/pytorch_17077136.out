    # Heuristic: Place the item in the bin with the smallest size that can fit it
    valid_bins = bins[bins >= item]
    if len(valid_bins) == 0:
        return np.zeros_like(bins)  # No valid bins, return zeros
    bin_priorities = np.zeros_like(bins)
    bin_priorities[bins >= item] = valid_bins / item
    return bin_priorities

