import numpy as np
import math

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the smallest available space
    available_space = bins - item
    available_space[available_space < 0] = np.inf  # Penalize bins that can't fit the item
    return np.exp(-available_space)  # Prioritize smaller available space

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the largest available space
    available_space = bins - item
    available_space[available_space < 0] = -np.inf  # Penalize bins that can't fit the item
    return np.exp(available_space)  # Prioritize larger available space

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the least remaining capacity
    remaining_capacity = bins - np.mean(bins)
    return np.abs(item - remaining_capacity)  # Prioritize bins where item fits well

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the most empty space
    empty_space = bins.max() - bins
    return np.exp(empty_space)  # Prioritize bins with more empty space

