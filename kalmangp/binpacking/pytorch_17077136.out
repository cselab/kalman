Here are 10 unique implementations of the `priority` function, each using a distinct combination of allowed operations:

```python
# Implementation 1: Uses exponential and standard deviation with sine functions
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.sin(np.pi * item) + np.sin(np.pi * item)

# Implementation 2: Combines maximum and minimum bin values with the item
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.maximum(item, np.max(bins)) - np.minimum(item, np.min(bins))

# Implementation 3: Uses logarithm and division with mean
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item) / (np.mean(bins) + 1e-8)

# Implementation 4: Square root and addition with mean
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) + np.mean(bins)

# Implementation 5: Median and multiplication with exponential
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return item * np.median(bins) * np.exp(item - np.median(bins))

# Implementation 6: ReLU on (item - mean of bins)
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.maximum(0, item - np.mean(bins))

# Implementation 7: Clip bins and compute priority
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    clipped_bins = np.clip(bins, item - 1, item + 1)
    return np.exp(item - clipped_bins)

# Implementation 8: Cumulative sum and log
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(np.cumsum(bins) + 1e-8)

# Implementation 9: Boolean condition on bins and item
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    condition = bins > item
    return np.where(condition, bins, item)

# Implementation 10: Transpose and use max and min
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    transposed = bins.T
    return np.max(transposed) - np.min(transposed)
```

Each function implements a unique heuristic, combining different operations to compute the priority scores for each bin.
