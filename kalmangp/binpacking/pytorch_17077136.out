### Solution Code

```python
import numpy as np
import math

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + math.sin(math.pi * item / np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(item - bins) + np.sin(math.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.mean(bins) * np.exp(item - np.max(bins)) + math.cos(math.pi * item / np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + math.tanh(math.pi * item / np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.median(bins)) * np.exp(item - bins) + math.sin(math.pi * item / np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.mean(bins) * np.exp(item - np.min(bins)) + math.cos(math.pi * item / np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(item - bins) + math.tanh(math.pi * item / np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.mean(bins) * np.exp(item - np.mean(bins)) + math.sin(math.pi * item / np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + math.cos(math.pi * item / np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.mean(bins) * np.exp(item - np.max(bins)) + math.tanh(math.pi * item / np.mean(bins))
```

### Explanation

Each of the provided functions computes a priority score for each bin based on the given item and the current state of the bins. The functions use a variety of mathematical operations, including exponential decay, trigonometric functions, statistical measures (mean, standard deviation, median), and transformations like hyperbolic tangent. Each function is designed to be unique by combining these operations in different ways, ensuring that the priority computation is varied and provides different heuristics for the bin packing problem.
