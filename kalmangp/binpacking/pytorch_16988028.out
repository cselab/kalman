### Solution Code:

```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1) * np.exp(item - np.mean(bins)) + np.cos(np.pi * (item / bins)) + np.log(item + 1)

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sin(np.pi * (item / bins)) * np.exp(item - np.mean(bins)) + np.cos(np.pi * (item / bins)) * np.log(item + 1)

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) * np.exp(item - bins) + np.log(item + 1) * np.sin(np.pi * (item / bins))

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.log(item + 1) + np.cos(np.pi * (item / bins)) * np.sin(np.pi * (item / bins))

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    return np.where(bins > item, np.exp(item - bins) * np.log(item + 1), np.zeros_like(bins))

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    return np.select([bins > item, bins <= item], [np.exp(item - bins) * np.log(item + 1), np.log(item + 1) * np.sin(np.pi * (item / bins))])

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    return (item / (bins + 1e-8)) * np.exp(item - bins) + np.log(item + 1) * np.sin(np.pi * (item / bins))

def priority_10(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (np.log(item + 1) + np.std(bins)) + np.sin(np.pi * (item / bins)) * np.cos(np.pi * (item / bins))
```

