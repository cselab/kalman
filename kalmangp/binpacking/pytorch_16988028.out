### Solution Code:

```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.mean(bins)) * np.exp(item / bins) + np.log(bins + 1e-8)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.max(bins)) / (np.min(bins) + 1e-8) + np.sin(np.pi * item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1e-8) * (np.sum(bins) / bins) + np.exp(item - bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item / np.mean(bins)) * np.exp(np.std(bins) + 1e-8) + np.tan(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (np.sqrt(item) + np.mean(bins)) * np.exp(item - bins) + np.log(bins + 1e-8)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.max(bins)) / (np.min(bins) + 1e-8) + np.cos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (np.log(item + 1e-8) * np.mean(bins)) + np.exp(item / bins) + np.tan(np.pi * item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.std(bins)) * np.exp(np.mean(bins) - item) + np.sin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.sum(bins)) / (np.max(bins) + 1e-8) + np.cos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (np.sqrt(item) + np.min(bins)) * np.exp(item / bins) + np.log(bins + 1e-8)
