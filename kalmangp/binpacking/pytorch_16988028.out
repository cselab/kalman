### Solution Code:

```python
import numpy as np
import math
import scipy

def priority_1(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.cos(np.pi * (item / bins)) + np.cos(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.cos(np.pi * (item / bins))

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.tan(np.pi * (item / bins)) + np.tan(np.pi * (item / bins)) + np.tan(np.pi * (item / bins))

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.tan(np.pi * (item / bins))

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.arcsin(np.pi * (item / bins)) + np.arcsin(np.pi * (item / bins)) + np.arcsin(np.pi * (item / bins))

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.arcsin(np.pi * (item / bins))

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.arccos(np.pi * (item / bins)) + np.arccos(np.pi * (item / bins)) + np.arccos(np.pi * (item / bins))

def priority_10(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.arccos(np.pi * (item / bins))
```...
