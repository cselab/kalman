### Solution Code:

```python
import numpy as np

def priority_1(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.log(np.abs(item - bins)) + np.log(np.abs(item - bins)) + np.log(np.abs(item - bins))

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.log(np.abs(item - bins))

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sqrt(np.abs(item - bins)) + np.sqrt(np.abs(item - bins)) + np.sqrt(np.abs(item - bins))

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sqrt(np.abs(item - bins))

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.sqrt(np.abs(item - bins)) + np.sqrt(np.abs(item - bins))

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.sqrt(np.abs(item - bins))

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.log(np.abs(item - bins)) + np.sin(np.pi * (item / bins)) + np.sqrt(np.abs(item - bins))

def priority_10(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.log(np.abs(item - bins)) + np.sin(np.pi * (item / bins)) + np.sqrt(np.abs(item - bins))
```

### Explanation:
Each of the 10 functions (`priority_1` to `priority_10`) implements a unique combination of mathematical operations and array operations to compute the priority score for each bin in the bin packing problem. The functions use operations like exponential, logarithm, sine, cosine, square root, and standard deviation to create distinct priority heuristics. Each function ensures that the output is an array of the same size as the input `bins`, providing a vectorized and efficient computation without any loops or conditional statements....
