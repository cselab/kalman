### Solution Code

```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * np.sqrt(bins) + np.sin(np.pi * bins) + np.cos(np.pi * item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + bins) * np.exp(item - bins) + np.log(1 + item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item * bins) * np.mean(bins) + np.cos(np.pi * bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item / bins) * np.exp(bins - item) + np.log(1 + bins / item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item + bins) * np.std(bins) + np.sin(np.pi * item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(item - bins) + np.log(1 + item + bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item / bins) * np.sqrt(bins) + np.cos(np.pi * bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + bins) * np.exp(item / bins) + np.log(1 + bins - item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(bins - item) * np.mean(bins) + np.sin(np.pi * item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(bins / item) + np.cos(np.pi * bins)
