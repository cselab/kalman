# Implementation 1: Using exponential decay and sine function with squared terms
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(-item * bins) + np.sin(np.pi * (item / bins))**2
```

```python
# Implementation 2: Combining logarithmic and cosine functions
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + np.mean(bins)) * np.cos(np.pi * bins)
```

```python
# Implementation 3: Exponential growth with square root of variance
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item * np.sqrt(np.var(bins))) + np.log(item + 1)
```

```python
# Implementation 4: Sine and tangent functions with mean subtraction
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sin(np.pi * (item / bins)) + np.tan(np.mean(bins) - item)
```

```python
# Implementation 5: Polynomial combination with logarithmic terms
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item ** 2) * np.log(bins + 1) + np.mean(bins)
```

```python
# Implementation 6: Trigonometric and square root combination
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(np.sin(np.pi * (item / bins))) + np.sqrt(np.mean(bins))
```

```python
# Implementation 7: Exponential with absolute difference
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(abs(item - bins)) + np.log(abs(item - bins) + 1)
```

```python
# Implementation 8: Polynomial and logarithmic mean
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item ** 3) * np.log(np.mean(bins) + 1) + np.sin(np.pi * item)
```

```python
# Implementation 9: Trigonometric and exponential mean
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(np.mean(bins)) * np.cos(np.pi * (item / bins))
```

```python
# Implementation 10: Polynomial combination with variance
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item ** 2) * np.var(bins) + np.log(item + np.mean(bins))
```

Each implementation uses a unique combination of mathematical operations and functions to compute the priority scores for the bins. They are all vectorized to work efficiently with NumPy arrays and return the required output shape.
