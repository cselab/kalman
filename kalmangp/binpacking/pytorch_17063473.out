import numpy as np
import math

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(-abs(item - bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

# Below are 10 unique implementations.

# Implementation 1
