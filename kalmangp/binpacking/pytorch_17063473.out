### Solution Code

```python
import numpy as np
import math

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sin(item * np.mean(bins)) + np.cos(np.pi * (item / bins)) + (item * np.exp(bins))

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(np.exp(item - bins) * (item * np.std(bins))) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    return np.tanh(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    return np.arctan(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.mean(bins)) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(np.exp(item - bins) * (item * np.std(bins)) + 1) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_10(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins)) + np.exp(item - bins) * (item * np.std(bins))
```

### Explanation

Each function computes a priority score for each bin in a unique way, combining different mathematical operations and functions to create distinct heuristics for the bin packing problem. The functions use a variety of operations such as exponential, trigonometric, logarithmic, and hyperbolic functions, as well as array operations like element-wise multiplication and broadcasting. Each implementation ensures that bins which can better accommodate the item have higher priority scores, adhering to the problem constraints and requirements.
