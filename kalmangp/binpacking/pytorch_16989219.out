import numpy as np

def priority_1(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.sin(np.pi * (item / bins))

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + np.abs(bins)) * np.exp(item - np.mean(bins))

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item * (bins - np.min(bins))) + np.sin(np.pi * (item / bins))

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) / np.exp(bins - item) + np.cos(np.pi * (item / bins))

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.sqrt(np.mean(bins) + item) + np.sin(np.pi * (item / bins))

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.min(bins)) * np.exp(np.abs(item - bins)) + np.cos(np.pi * (item / bins))

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1.0) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.cos(np.pi * (item / bins))

def priority_10(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.sqrt(np.mean(bins) + item) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))
