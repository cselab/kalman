### Solution Code

```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.sin(np.pi * item / bins) + np.cos(np.pi * item / bins)

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1) * np.exp(np.std(bins)) + np.sin(np.pi * (item / bins)) * np.cos(np.pi * (item / bins))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(np.log(item) + np.mean(bins)) * np.std(bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.min(bins)) * np.std(bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.max(bins)) * np.std(bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1) * np.exp(np.mean(bins)) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(np.log(item) + np.mean(bins)) * np.std(bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))

def priority_10(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins))
