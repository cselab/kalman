### Solution Code

```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.std(bins) + np.sin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.log(bins)) * np.exp(item - bins) + np.cos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item * np.mean(bins)) * np.exp(item - bins) + np.tan(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.var(bins)) * np.exp(item - bins) + np.arcsin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.max(bins)) * np.exp(item - bins) + np.arccos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.min(bins)) * np.exp(item - bins) + np.arctan(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(item - bins) + np.sin(np.pi * item / bins) + np.cos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.tan(np.pi * item / bins) + np.log(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.log(bins)) * np.exp(item - bins) + np.sin(np.pi * item / bins) + np.cos(np.pi * item / bins) + np.tan(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.sqrt(bins)) * np.exp(item - bins) + np.arcsin(np.pi * item / bins) + np.arccos(np.pi * item / bins) + np.arctan(np.pi * item / bins)
```

### Explanation

Each implementation of the `priority` function uses a unique combination of mathematical operations and functions from NumPy to compute the priority score for each bin. Here's a breakdown of each function:

1. **First Implementation**: Uses `np.exp` and `np.sin` to compute the priority.
2. **Second Implementation**: Combines `np.log` and `np.cos`.
3. **Third Implementation**: Uses `np.sqrt`, `np.mean`, and `np.exp`, along with `np.tan`.
4. **Fourth Implementation**: Uses `np.var`, `np.exp`, and `np.arcsin`.
5. **Fifth Implementation**: Combines `np.max`, `np.exp`, and `np.arccos`.
