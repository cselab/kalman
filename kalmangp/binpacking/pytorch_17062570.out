### Solution Code

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.sin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.sqrt(bins)) ** 2 + np.log(item + np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.tan(item - np.max(bins)) * np.min(bins) + np.log(item + np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.log(item + np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - np.mean(bins)) + np.sin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.cos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.sqrt(bins)) ** 2 + np.log(item + np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.tan(item - np.max(bins)) * np.min(bins) + np.log(item + np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.std(bins) + np.log(item + np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
