def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Best Fit Decreasing
    # Compute priority as (item fits in bin) * some measure of bin's space
    return (bins - item) * np.mean(bins) + np.cos(item - bins)

### Implementation 2: First Fit
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: First Fit
    # Compute priority as the sum of the bin's capacity and the item's size
