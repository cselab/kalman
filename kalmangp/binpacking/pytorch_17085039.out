 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Create a mask where bins >= item
    can_fit = bins >= item
    # For bins that can fit, compute priority
    # For example, priority = 1 / (bins - item + 1e-10)
    # For bins that cannot fit, priority is 0
    # So, the priority array is can_fit * (1 / (bins - item + 1e-10)) + (1 - can_fit) * 0
    # But we need to handle the case where bins - item is zero, so we add a small epsilon to avoid division by zero
    epsilon = 1e-10
    priority_scores = np.zeros_like(bins)
    # For bins that can fit
    priority_scores[can_fit] = 1 / (bins[can_fit] - item + epsilon)
    # For bins that cannot fit, priority is 0
    # So the final priority is priority_scores
    return priority_scores
