### Implementation 2: Worst Fit with Sigmoid Function
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, -np.inf)
    return np.exp(item) / (1 + np.exp(-available)) + np.cos(np.pi * available / item)
```

### Implementation 3: Max Fit with Gaussian Distribution
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, 0)
    mean = np.mean(available)
    std = np.std(available)
    return np.exp(-(available - mean)**2 / (2 * std**2)) + np.sin(np.pi * available / item)
```

### Implementation 4: Min Fit with Linear Scaling
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, np.inf)
    return np.exp(-available) + np.cos(np.pi * available / item)
```

### Implementation 5: Greedy Fit with Logarithmic Penalty
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, -np.inf)
    return np.log(available + 1) + np.sin(np.pi * available / item)
```

### Implementation 6: First Fit with Exponential Growth
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, 0)
    return np.exp(available) + np.cos(np.pi * available / item)
```

### Implementation 7: Worst Fit with Sinusoidal Oscillation
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, -np.inf)
    return np.sin(np.pi * available / item) + np.exp(-available)
```

### Implementation 8: Max Fit with Quadratic Penalty
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, 0)
    return np.exp(-available**2) + np.sin(np.pi * available / item)
```

### Implementation 9: Min Fit with Inverse Tangent
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, np.inf)
    return np.arctan(available) + np.exp(-available)
```

### Implementation 10: Greedy Fit with Logarithmic Scaling
```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available = np.where(bins >= item, bins - item, 0)
    return np.log(available + 1) + np.exp(-available)
