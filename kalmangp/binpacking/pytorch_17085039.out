 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the difference between item and each bin
    diff = item - bins
    # Compute exponential decay based on the difference
    exp_decay = np.exp(diff)
    # Compute sine of the difference
    sine_diff = np.sin(np.pi * diff)
    # Combine using multiplication and addition
    priority_scores = exp_decay * (item * np.std(bins)) + np.sum([np.sin(np.pi * (item / b)) for b in bins])
    return priority_scores
