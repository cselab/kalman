def priority(item: float, bins: np.ndarray) -> np.ndarray:
    space_remaining = bins[:, 0] - bins[:, 1:].sum(axis=1)
    mean = np.mean(bins[:, 1:], axis=1)
    factor = np.sin(np.pi * (item / bins[:, 0])) * mean
    return space_remaining * factor
