### Example Code:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    remaining = np.maximum(remaining, 0)  # Ensure non-negative
    ratio = item / bins
    priority = np.exp(remaining) * np.log(ratio + 1e-10)  # Avoid division by zero
    return priority

