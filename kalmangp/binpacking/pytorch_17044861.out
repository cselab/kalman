def priority(item: float, bins: np.ndarray) -> np.ndarray:
    can_fit = bins >= item
    remaining = bins.max() - bins
    priority = np.where(can_fit, np.exp(remaining) * (item / np.mean(bins)), 0)
    return priority
```

