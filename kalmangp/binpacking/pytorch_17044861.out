import numpy as np
import math
import random

def priority_1(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the smallest available space.
    # The priority is the remaining capacity of each bin.
    # To make it a priority, we want to maximize the remaining space.
    # So, the priority is the remaining capacity.
    # However, to make it a priority score, we can use the remaining capacity.
    # But since we want to place the item in the bin with the smallest remaining space,
    # perhaps we can invert it.
    # Or, perhaps, we can compute the remaining capacity and prioritize the bins with the smallest remaining capacity.
    # Wait, no, because the item can't fit into bins with remaining capacity less than the item.
    # So, we need to find bins where remaining capacity >= item, and choose the one with the smallest remaining capacity.
    # But how to represent this as a priority score.
    # One approach is to compute the remaining capacity for each bin, and for bins where remaining capacity >= item, the priority is remaining capacity. For others, it's 0.
    # Then, we can choose the bin with the smallest remaining capacity that can fit the item.
    # Alternatively, we can compute the remaining capacity and subtract it from the item size, but I'm not sure.
    # Another approach is to compute the remaining capacity and then for each bin, the priority is (remaining capacity - item). But this would be negative for bins that can't fit the item.
    # Alternatively, we can compute the remaining capacity and then take the reciprocal for bins that can fit the item.
    # Or, perhaps, compute the remaining capacity and then for each bin, the priority is (remaining capacity) if remaining capacity >= item, else 0.
    # Then, the bin with the smallest remaining capacity that can fit the item will have the highest priority.
    # So, let's implement this.
    remaining = bins - item
    # We need to ensure that remaining >=0, else the bin can't fit the item.
    # So, for bins where remaining <0, set priority to 0.
    priority = np.maximum(remaining, 0)
    # But we want to prioritize the bins with the smallest remaining capacity that can fit the item.
    # So, the priority should be higher for smaller remaining capacities.
    # So, perhaps, we can take the reciprocal of priority.
    # But since priority is 0 for bins that can't fit, we need to handle that.
    # Alternatively, we can compute 1 / (remaining + 1) for bins that can fit, and 0 otherwise.
    # This way, smaller remaining capacities get higher priority.
    # Let's try that.
    # Compute 1 / (remaining + 1) for bins where remaining >=0, else 0.
    priority = np.where(remaining >= 0, 1 / (remaining + 1), 0)
    return priority

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the largest available space.
    # This is the opposite of the previous heuristic.
    # So, the priority is the remaining capacity, and we want to choose the bin with the largest remaining capacity that can fit the item.
    # So, the priority is the remaining capacity.
    # But to make it a priority score, we can use the remaining capacity.
    # However, to prioritize larger remaining capacities, we can simply use the remaining capacity.
    # So, for each bin, if remaining >=0, priority is remaining, else 0.
    remaining = bins - item
    priority = np.where(remaining >= 0, remaining, 0)
    return priority

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the smallest size that can fit it.
    # So, for each bin, if bin >= item, the priority is bin size.
    # We want to choose the smallest bin that can fit the item.
    # So, the priority should be the bin size for bins that can fit the item, and 0 otherwise.
    # Then, the bin with the smallest size that can fit the item will have the highest priority.
    # So, the priority is bin size for bins >= item, else 0.
    priority = np.where(bins >= item, bins, 0)
    return priority

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the largest size that can fit it.
    # So, for each bin, if bin >= item, the priority is bin size.
    # We want to choose the largest bin that can fit the item.
    # So, the priority is bin size for bins >= item, else 0.
    priority = np.where(bins >= item, bins, 0)
    return priority

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the smallest bin size, regardless of whether it can fit.
    # Wait, but if the bin is smaller than the item, it can't fit. So, perhaps, we should only consider bins that can fit the item.
    # So, for each bin, if bin >= item, the priority is bin size. Else, 0.
    # Then, the bin with the smallest size that can fit the item will have the highest priority.
    # Wait, that's similar to priority_3.
    # Alternatively, perhaps we can compute the bin size minus the item, but only for bins that can fit.
    # Or, perhaps, compute the bin size, and for bins that can fit, the priority is bin size, else 0.
    # So, the priority is bins >= item ? bins : 0.
    # Which is similar to priority_3.
    # So, perhaps, this is the same as priority_3.
    # To make it unique, perhaps we can compute the bin size divided by the item, but only for bins that can fit.
    # Or, perhaps, compute the bin size minus the item, but only for bins that can fit.
    # So, priority = bins - item for bins >= item, else 0.
    # Then, the bin with the smallest (bins - item) will have the highest priority.
    # So, this would prioritize bins that are just slightly larger than the item.
    remaining = bins - item
    priority = np.where(remaining >= 0, remaining, 0)
    return priority

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the smallest bin size that can fit it.
    # So, for each bin, if bin >= item, the priority is bin size. Else, 0.
