### Implementation 1:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    priority = np.where(remaining < 0, 0, np.exp(remaining / (remaining + 1)) * np.mean(bins) + np.log10(item / np.mean(bins)) + np.sin(np.pi * (item / bins)))
    return priority

