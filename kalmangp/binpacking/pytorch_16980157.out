def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(np.mean(bins) + item) + np.exp(item - np.min(bins)) + np.cos(np.pi * item / np.max(bins)) + np.tanh(item / np.std(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item / (np.max(bins) - np.min(bins))) + np.log(1 + item / np.mean(bins)) + np.sin(np.pi * item / np.std(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item + np.mean(bins)) * np.exp(item - np.min(bins)) + np.log(item / np.mean(bins)) + np.cos(np.pi * item / np.max(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item / (np.max(bins) - np.min(bins))) + np.log(item + np.mean(bins)) + np.sin(np.pi * item / np.std(bins)) + np.tanh(item / np.mean(bins))
```

