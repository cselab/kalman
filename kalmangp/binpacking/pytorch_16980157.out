import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.sqrt(np.std(bins)) + np.log(item / np.mean(bins)) + np.log(1 + (item / bins)) + np.exp(item - np.mean(bins)) * np.sqrt(np.std(bins)) + np.log(item / np.mean(bins)) + np.log(1 + (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
