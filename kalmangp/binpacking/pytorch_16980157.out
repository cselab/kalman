    # Compute the remaining space in each bin
    remaining = bins - item
    # Prioritize bins where the remaining space is proportional to the item size
    priority = remaining / (item + 1e-9)
    return priority

7. Least Full Fit:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Prioritize bins that are less full
    # Compute the current usage ratio
    usage = bins / (bins + item)
    priority = 1 - usage
    return priority

8. Least Empty Fit:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Prioritize bins that are more empty
    # Compute the remaining space ratio
    remaining = bins - item
    priority = remaining / (bins + item)
    return priority

