### Implementation:

```python
import numpy as np

def priority_1(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) / (np.log(np.mean(bins)) + np.std(bins))

def priority_2(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.mean(bins)) + np.sin(np.pi * (item / bins))

def priority_3(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(np.sum(bins)) * (np.mean(bins) + item) / (np.std(bins) + 1)

def priority_4(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.mean(bins)) * np.exp(np.std(bins)) - np.log(1 + item / bins)

def priority_5(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sin(np.pi * item) * (np.mean(bins) + np.std(bins)) / (item + np.sum(bins))

def priority_6(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item * np.mean(bins)) * (np.std(bins) + 1) - np.log(1 + item / np.mean(bins))

def priority_7(item: float, bins: np.ndarray) -> np.ndarray:
    return (np.mean(bins) + np.std(bins)) * np.sin(np.pi * item) + np.log(1 + bins)

def priority_8(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (np.mean(bins) + np.std(bins)) / (np.sum(bins) + 1)

def priority_9(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(np.std(bins)) + np.log(1 + item / np.mean(bins))

def priority_10(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sin(np.pi * item) * (np.mean(bins) + np.std(bins)) / (item + np.sum(bins))
