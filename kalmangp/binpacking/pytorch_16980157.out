### Solution Code:

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.mean(bins)) + np.log(item + 1) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins)) + np.tan(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(np.mean(bins)) * np.exp(item - np.mean(bins)) + np.log(item + 1) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins)) + np.tan(np.pi * (item / bins))

