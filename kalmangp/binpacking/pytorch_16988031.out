### Solution Code:

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sin(np.pi * (item / bins)) + np.exp(item - bins) * np.std(bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.cos(np.pi * (item / bins)) + np.log(item) * np.mean(bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.tan(np.pi * (item / bins)) + np.log10(item) * np.std(bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.arcsin(np.pi * (item / bins)) + np.exp(item) * np.max(bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.arccos(np.pi * (item / bins)) + np.log2(item) * np.min(bins)

