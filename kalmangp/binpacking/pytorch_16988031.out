```python
def exp_std_priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.std(bins)

def sin_diff_priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sin(np.pi * (item / bins)) + np.exp(item - bins)

def exp_sin_priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) + np.sin(np.pi * (item / bins))

def mean_diff_priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.mean(bins) * (item - bins)

def std_add_priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.std(bins) + (item - bins)

def exp_cos_priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.cos(np.pi * (item / bins))

def sqrt_diff_priority(item: float, bins: np.ndarray) -> np.ndarray:
