### Implementation 1: First Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    can_fit = bins >= item
    priority_scores = np.where(can_fit, bins, 0)
    priority_scores = np.where(priority_scores > 0, 1, 0)
    return priority_scores

