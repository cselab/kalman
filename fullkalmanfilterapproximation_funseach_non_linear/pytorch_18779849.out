def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply non-local means denoising to y
    from skimage.restoration import denoise_nlmeans
    y_denoised = denoise_nlmeans(y, h=1.0, sigma=0.5)
    S_denoised = P + R
    K = P @ np.linalg.inv(S_denoised)
    x = xp + K @ y_denoised
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_denoised, K, x
