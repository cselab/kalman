def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.diag(1 / S + 1e-11)
    inv_S = V.T @ inv_S @ U.T
    K = P @ inv_S
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
