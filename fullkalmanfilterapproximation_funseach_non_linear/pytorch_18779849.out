function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    x = x + 0.00001 * np.random.randn(*x.shape)
    P = P + 0.00001 * np.random.randn(*P.shape)
    return xp, P, y, S, K, x
