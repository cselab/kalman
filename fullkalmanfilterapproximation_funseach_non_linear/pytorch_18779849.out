def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the square root of determinants
    sqrt_det_S = np.sqrt(np.linalg.det(S))
    sqrt_det_R = np.sqrt(np.linalg.det(R))
    scale = sqrt_det_S / sqrt_det_R
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
