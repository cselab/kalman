function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Use the Frobenius norm of S to scale Q
    frobenius_S = np.linalg.norm(S, 'fro')
    Q_scale = np.exp(-frobenius_S / (2 * S.trace()))
    Q = Q * Q_scale
    return xp, P, y, S, K, x
