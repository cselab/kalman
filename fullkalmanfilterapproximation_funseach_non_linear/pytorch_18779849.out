def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Compute state estimate
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Online update for P and Q
    alpha = 0.1
    dP = (x - xp) @ (x - xp).T
