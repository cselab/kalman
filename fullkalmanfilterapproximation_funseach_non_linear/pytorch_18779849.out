def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = np.linalg.inv(S) @ P.T
    x = xp + K @ y
    return xp, P, S, y, K, x
