def aproximate(x, F, P, Q, z, R):
    from numpy import array, dot, sqrt, diag, outer, ones_like, zeros_like
    from numpy.linalg import inv, norm
    import numpy as np
    xp = dot(F, x)
    y = z - xp
    P = dot(F, dot(P, F.T)) + Q
    S = P + R
    inv_S = inv(S + np.spacing(1))
    K = dot(P, inv_S)
    x = xp + dot(K, y)
    P = np.eye(F.shape[0]) - dot(K, P)
    return xp, P, y, S, K, x
