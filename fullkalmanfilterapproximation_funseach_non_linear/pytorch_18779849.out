def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S + 1e-14 * np.eye(S.shape[0]))
    K = P @ inv_S
    # SGD update
    learning_rate = 0.1
    x = x + learning_rate * (y.T @ K).T
    return xp, P, y, S, K, x
