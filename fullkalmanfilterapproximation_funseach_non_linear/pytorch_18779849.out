def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using Cholesky decomposition
    try:
        L = np.linalg.cholesky(S)
        inv_S = np.linalg.inv(L) @ np.linalg.inv(L).T
    except np.linalg.LinAlgError:
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    loss = np.mean((z - x)**2)
    history.append(loss)
    return xp, P, y, S, K, x
