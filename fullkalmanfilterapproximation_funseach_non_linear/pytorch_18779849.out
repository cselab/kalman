def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    # Compute inverse via Cholesky
    L = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(L.T).dot(np.linalg.inv(L))
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S, K, x
