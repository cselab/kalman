def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD decomposition
    U, S_diag, V = np.linalg.svd(S, full_matrices=True)
    inv_S = V.T @ np.linalg.inv(S_diag) @ U.T
    K = P @ inv_S @ y
    x = xp + K
    # Update P using matrix inversion lemma
    P = (np.eye(F.shape[0]) - K @ F.T) @ P
    return xp, P, y, S, K, x
