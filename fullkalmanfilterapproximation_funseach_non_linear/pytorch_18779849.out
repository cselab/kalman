def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Anisotropic Diffusion Filter
    diffusion = np.exp(-np.sum(y**2, axis=0)/(2*S.trace()))
    P_diff = P * diffusion
    K = P_diff @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_diff
    return xp, S, y, P, K, x
