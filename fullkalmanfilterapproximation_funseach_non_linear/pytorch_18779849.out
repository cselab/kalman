def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + np.trace(Q) * np.eye(F.shape[0])
    y = z - xp
    S = P + R * np.sum(R)
    inv_S = np.linalg.inv(S)
    K = inv_S @ P
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
