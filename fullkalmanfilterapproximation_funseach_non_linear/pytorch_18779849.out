def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = np.einsum('ij,kj->ik', F, P) @ F.T + Q
    y = z - xp
    S = P + R
    K = np.einsum('ij,kj->ik', P, np.linalg.inv(S))
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
