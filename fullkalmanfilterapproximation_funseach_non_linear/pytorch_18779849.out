def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ S) @ P
    loss = np.sum((z - F @ x)**2 / (P.trace() + R.trace())) / len(z)
    return xp, S, y, P, K, x
