    # Use SVD for matrix inversion
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[S != 0] = 1 / S[S != 0]
    inv_S = U @ inv_S @ V.T
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S, K, x
