def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    norm_P = np.linalg.norm(P, 'fro')
    perturbation = np.random.randn(*P.shape) * (0.025 if norm_P > 0 else 0.015)
    P += perturbation
    return xp, P, y, S, K, x
