def aproximate(x, F, P, Q, z, R):
    Fx = F @ x
    P = F @ P @ F.T + Q
    y = z - Fx
    S = P + R
    K = np.linalg.solve(S, F @ y)
    x = Fx + K @ y
    P = P - K @ F.T @ P
    history.append((x, P))
    return Fx, P, y, S, K, x
