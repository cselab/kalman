def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ numpy.linalg.inv(S)
    x = xp + K @ y
    # Add a scaled random perturbation based on the determinant of P
    det_P = numpy.linalg.det(P)
    if det_P < 0:
        det_P = -det_P
    scale = det_P ** 0.5 * 1e-4
    perturbation = numpy.random.randn(*P.shape) * scale
    P += perturbation
    return xp, P, y, S, K, x
