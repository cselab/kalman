def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD decomposition
    U, S, V = np.linalg.svd(S)
    inv_S = np.linalg.inv(S)
    inv_S_full = V.T @ inv_S @ U.T
    K = P @ inv_S_full @ y
    x = xp + K
    # Update P using matrix inversion lemma
    P = (np.eye(F.shape[0]) - K @ F.T) @ P
    return xp, P, y, S, K, x
