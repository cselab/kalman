def aproximate(x, F, P, Q, z, R):
    global history
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S + 1e-5 * np.eye(S.shape[0]))
    inv_S = np.diag(1/S)
    K = P @ (V.T @ inv_S @ U.T)
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    loss = np.sum(y ** 2) / len(y)
    history.append((x.copy(), P.copy(), y.copy(), S.copy(), K.copy()))
    return xp, P, y, S, K, x
