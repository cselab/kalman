def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    # Using Woodbury matrix identity for efficient computation
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = (numpy.eye(F.shape[0]) - K).dot(P)
    return xp, P, y, S, K, x
