def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P_new = (np.eye(F.shape[0]) - K) @ P
    P = 0.9 * P + 0.1 * P_new
    noise = np.random.normal(0, 0.01, P.shape)
    P += noise
    P = np.clip(P, 0, np.inf)
    return xp, P, y, S, K, x
