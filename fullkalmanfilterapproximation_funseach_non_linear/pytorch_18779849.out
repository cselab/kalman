function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = np.matmul(F, x)
    P = np.matmul(F, np.matmul(P, F.T)) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = np.matmul(P, inv_S)
    x = xp + np.matmul(K, y)
    P = np.eye(F.shape[0]) - np.matmul(K, P)
    P = P + np.random.randn(*P.shape) * 0.01
    return xp, P, y, S, K, x
