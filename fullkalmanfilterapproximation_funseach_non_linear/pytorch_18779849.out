def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    damping = 0.01
    S_reg = S + damping * np.mean(np.diag(S)) * np.eye(S.shape[0])
    K = P @ np.linalg.inv(S_reg)
    x = xp + K @ y
    return xp, P, y, S, K, x
