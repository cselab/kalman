def aproximate(x, F, P, Q, z, R):
    import numpy as np
    n = x.shape[0]
    m = z.shape[0]
    F_a = np.zeros((n + m, n + m))
    F_a[:n, :n] = F
    F_a[n:, n:] = np.eye(m)
    P_a = np.zeros((n + m, n + m))
    P_a[:n, :n] = P
    y = z - F @ x
    S = P_a @ F_a.T + R
    K = P_a @ np.linalg.inv(S)
    x = F_a @ x + K @ y
    P = P_a - P_a @ F_a.T @ K
    return F @ x, S, y, P, K, x
