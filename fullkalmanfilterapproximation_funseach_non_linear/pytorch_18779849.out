def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    threshold = 0.01
    anomaly = np.linalg.norm(y) > threshold
    if anomaly:
        x = xp
        P = F @ P @ F.T + Q
    loss = np.linalg.norm(y) if anomaly else np.sum(y**2)
    return xp, P, y, S, K, x
