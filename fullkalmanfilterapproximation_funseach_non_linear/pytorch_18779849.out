def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Modified Kalman Filter with Inflation
    alpha = 0.1
    P = (1 + alpha * np.trace(S) / (P.size)) * P
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
