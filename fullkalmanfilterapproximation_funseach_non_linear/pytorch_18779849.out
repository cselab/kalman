def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x_pred = F @ x
    P_pred = F @ P @ F.T + Q
    y = z - x_pred
    S = P_pred + R
    K = np.linalg.solve(S, y @ P_pred.T)
    x = x_pred + K.T
    P = P_pred - K @ K.T
    return x_pred, P_pred, y, S, K, x
