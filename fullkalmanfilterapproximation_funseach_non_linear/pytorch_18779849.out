def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Bayesian Inference with Variational Approximation
    variational_mean = xp + (P @ np.linalg.inv(S)) @ y
    KL_div = 0.5 * (np.log(np.linalg.det(S)) - np.log(np.linalg.det(P)) + np.trace(P @ np.linalg.inv(S) - np.eye(S.shape[0])))
    P_var = variational_mean @ variational_mean.T
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_var
    return xp, S, y, P, K, x
