def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S @ y
    x = xp + K
    P = P - K @ K.T
    # Online update for Q
    alpha = 0.1
    dQ = (x - xp) @ (x - xp).T
    Q = alpha * dQ + (1 - alpha) * Q
    return xp, P, y, S, K, x
