def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = np.linalg.solve(S, P.T).T @ y
    x = xp + K
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
