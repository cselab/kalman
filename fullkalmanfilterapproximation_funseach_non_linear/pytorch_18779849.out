def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add L2 regularization to K
    reg = 0.01
    K = (K.T + reg * np.ones_like(K.T)).T
    # Add dropout to x
    mask = np.random.binomial(1, 0.9, x.shape)
    x = x * mask
    return xp, P, y, S, K, x
