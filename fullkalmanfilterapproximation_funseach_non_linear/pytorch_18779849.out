def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD
    U, S_diag, Vt = np.linalg.svd(S, full_matrices=True)
    S_inv = np.zeros_like(S)
    for i in range(len(S_diag)):
        if S_diag[i] > 1e-8:
            S_inv[i, i] = 1.0 / S_diag[i]
    S_inv = Vt.T @ S_inv @ U.T
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
