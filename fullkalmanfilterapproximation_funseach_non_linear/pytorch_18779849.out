def aproximate(x, F, P, Q, z, R):
    global history, global_step
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = P * np.exp(-0.45 * np.mean(P)) + F @ (P - Q) @ F.T
    loss = np.mean((z - x)**2)
    history.append((global_step, x, P, loss))
    global_step += 1
    return xp, P, y, S, K, x
