def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Cholesky decomposition
    L = np.linalg.cholesky(S)
    inv_L = np.linalg.inv(L)
    inv_S = inv_L @ inv_L.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return xp, P, y, S, K, x
