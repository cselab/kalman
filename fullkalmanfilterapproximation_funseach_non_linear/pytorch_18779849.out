def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a non-linear transformation to P to reduce uncertainty
    scale = 0.2
    P = P * (1 - scale) + np.log(P + 1) * scale
