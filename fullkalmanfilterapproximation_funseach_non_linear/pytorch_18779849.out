function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Use the eigenvalues of S to scale Q
    eigvals = np.linalg.eigvals(S)
    Q_scale = np.exp(-np.mean(eigvals) / (2 * S.trace()))
