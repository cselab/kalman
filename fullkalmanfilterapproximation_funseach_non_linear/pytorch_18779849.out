def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    I = np.eye(S.shape[0])
    inv_S = np.linalg.inv(S)
    K = np.zeros_like(P)
    for _ in range(10):
        prev_K = K.copy()
        K = np.linalg.solve(F @ F.T + R, P)
    x = xp + K @ y
    P = (I - K) @ P
    return xp, P, y, S, K, x
