def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('init', x, F, P, Q, z, R))
    
    # Implementation 6: Robust Inversion with Tolerance
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S + 0.01 * np.eye(S.shape[0]))
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(('tolerant_inv', xp, P, y, S, K, x))
    return xp, P, y, S, K, x
