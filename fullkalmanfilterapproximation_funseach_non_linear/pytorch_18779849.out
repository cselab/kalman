function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute Cholesky decomposition of S
    try:
        L = np.linalg.cholesky(S)
    except np.linalg.LinAlgError:
        # If S is not positive definite, add a small identity matrix
        I = np.eye(S.shape[0])
        L = np.linalg.cholesky(S + 0.0001*I)
    # Compute K using Cholesky
    L_inv = np.linalg.inv(L)
    K = P @ L_inv.T
    x = xp + K @ y
    P = P * 0.95
    return xp, P, y, S, K, x
