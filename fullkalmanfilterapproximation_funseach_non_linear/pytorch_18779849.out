function:
def aproximate(x, F, P, Q, z, R):
    global history
    
    # Predict step
    x_pred = F @ x
    P_pred = F @ P @ F.T + Q
    
    # Compute innovation
    y = z - x_pred
    
    # Compute covariance of innovation
    S = P_pred + R
    
    # Compute Kalman gain
    K = np.linalg.solve(S, y)
    
    # Update state estimate
    x = x_pred + K @ S.T
    
    # Update covariance
    P = P_pred - K @ y.T
    
    # Store the current state and measurement in history
    history.append((x, z))
    
    return x_pred, P_pred, y, S, K, x
