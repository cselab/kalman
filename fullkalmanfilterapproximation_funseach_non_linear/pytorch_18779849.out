function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use a different solver for linear systems
    from scipy.linalg import solve_triangular
    lower = np.tril(S)
    upper = np.triu(S)
    inv_S_lower = solve_triangular(lower, np.eye(S.shape[0]))
    inv_S_upper = solve_triangular(upper, np.eye(S.shape[0]), lower=False)
    inv_S = inv_S_lower @ inv_S_upper
    K = P @ inv_S
    return xp, S, y, P, K, x
