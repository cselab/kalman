def aproximate(x, F, P, Q, z, R):
    global history
    # Store the current state and parameters in history
    history.append((x.copy(), F.copy(), P.copy(), Q.copy(), z.copy(), R.copy()))
    
    # Compute the state prediction
    xp = F @ x
    
    # Update the covariance matrix
    P = F @ P @ F.T + Q
    
    # Compute the innovation
    y = z - xp
    
    # Compute the residual covariance
    S = P + R
    
    # Calculate the Kalman gain
    K = P @ np.linalg.inv(S)
    
    # Update the state estimate
    x = xp + K @ y
    
    # Update the covariance matrix
    P = (np.eye(F.shape[0]) - K) @ P
    
    return xp, P, y, S, K, x
