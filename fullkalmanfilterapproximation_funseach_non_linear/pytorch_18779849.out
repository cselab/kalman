def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    eps = 1e-8
    S = P + R + eps * np.eye(len(P))
    inv_S = np.linalg.pinv(S)
    K = P @ inv_S
    x = xp + K @ y
