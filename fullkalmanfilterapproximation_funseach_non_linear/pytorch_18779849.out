function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Use the square root of the covariance for numerical stability
    P_sqrt = np.linalg.cholesky(P)
    P_sqrt_inv = np.linalg.inv(P_sqrt)
    P = P_sqrt_inv @ P_sqrt
    return xp, P, y, S, K, x
