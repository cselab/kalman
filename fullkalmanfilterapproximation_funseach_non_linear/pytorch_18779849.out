function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    L = np.linalg.cholesky(S)
    L_inv = np.linalg.solve(L, np.eye(S.shape[0]))
    S_inv = L_inv.T @ L_inv
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    loss = y.T @ S_inv @ y
    history.append(loss)
    return xp, P, y, S, K, x
