def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    u = P @ y
    denom = np.linalg.norm(y) ** 2 + R.trace()
    K = u / denom
    x = xp + K @ y
    P = P - K @ y.T @ P
    return xp, P, y, S, K, x
