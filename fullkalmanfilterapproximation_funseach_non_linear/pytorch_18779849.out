    y = z - xp
    S = P + R
    # Compute inverse using Cholesky
    L = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(L) @ np.linalg.inv(L).T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(np.eye(F.shape[0]) + F @ P @ F.T) - K) @ P
    loss = y.T @ inv_S @ y
    history.append(loss)
    return xp, P, y, S, K, x
