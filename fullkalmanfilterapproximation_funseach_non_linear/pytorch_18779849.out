def aproximate(x, F, P, Q, z, R):
    x_p = F.dot(x)
    P_p = F.dot(P.dot(F.T)) + Q
    y = z - x_p
    S = P_p + R
    K = P_p @ np.linalg.inv(S)
    x = x_p + K.dot(y)
    P = P_p - K.dot(K.T)
    return x_p, P_p, y, S, K, x
