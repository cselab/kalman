function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P_new = F @ P @ F.T + Q
    y = z - xp
    S = P_new + R
    inv_S = np.linalg.inv(S)
    K = P_new @ inv_S
    x = xp + K @ y
    noise = np.random.poisson(10, size=x.shape) * 0.001
    x += noise
    P = (np.eye(F.shape[0]) - K @ P_new) * (1 + np.random.gamma(0.1, 1))
    return xp, P, y, S, K, x
