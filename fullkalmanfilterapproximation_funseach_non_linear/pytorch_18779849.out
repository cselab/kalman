def aproximate(x, F, P, Q, z, R):
    from numpy import diag, linalg
    x = F @ x
    P = F @ P @ F.T + Q
    y = z - x
    S = P + R
    inv_S = linalg.inv(S)
    K = P @ inv_S
    x = x + K @ y
    P = P + 0.1 * diag(1.0)
    return x, P, y, S, K, x
