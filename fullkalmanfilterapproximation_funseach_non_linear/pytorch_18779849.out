function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Use a heuristic to adjust the Kalman gain
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse with a numerical stabilizer
    inv_S = np.linalg.inv(S + np.eye(S.shape[0]) * 1e-8)
    K = P @ inv_S
    x = xp + K @ y
    # Apply a damping factor to P to prevent overconfidence
    damping_factor = 0.999
    P = F @ P @ F.T + Q
    P = damping_factor * P
    return xp, P, y, S, K, x
