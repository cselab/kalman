def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply Tikhonov regularization to P
    lambda_reg = 0.01
    P_reg = P + lambda_reg * np.eye(P.shape[0])
    K = P_reg @ np.linalg.inv(S)
    x = xp + K @ y
    return xp, P, y, S, K, x
