def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    S_eig, S_vec = np.linalg.eigh(S + 1e-5 * np.eye(S.shape[0]))
    inv_S = np.diag(1 / S_eig)
    K = P @ S_vec @ inv_S @ S_vec.T @ y
    x = xp + K
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
