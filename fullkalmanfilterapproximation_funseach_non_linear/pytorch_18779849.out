def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    K_clamped = np.clip(K, -1e3, 1e3)
    x = xp + K_clamped @ y
    P = (F @ P @ F.T + Q) - K_clamped @ y @ K_clamped.T
