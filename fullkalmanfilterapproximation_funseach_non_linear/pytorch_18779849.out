def aproximate(x, F, P, Q, z, R):
    xp = F * x
    P = F * P * F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S + 1e-4 * np.eye(S.shape[0]))
    x = xp + K @ y
    x = np.tanh(x)
    loss = np.mean(-z * np.log(1 + y) - (1 - z) * np.log(1 + 1 - y))
    return xp, P, y, S, K, x
