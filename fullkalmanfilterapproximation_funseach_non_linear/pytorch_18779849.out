def aproximate(x, F, P, Q, z, R):
    x_new = F @ x
    P_new = F @ P @ F.T + Q
    y = z - x_new
    S = P_new + R
    I = np.eye(S.shape[0])
    inv_S = np.linalg.solve(S + 1e-5 * I, I)
    K = P_new @ inv_S
    x = x_new + K @ y
    x = np.clip(x, -5, 5)
    history.append((x, P_new, y, S, K, x))
    return x, P_new, y, S, K, x
