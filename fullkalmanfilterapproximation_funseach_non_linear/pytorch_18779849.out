def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Adaptive damping based on current state
    damping_factor = 0.99 + (np.mean(np.abs(x)) / np.mean(np.abs(xp)))
    x = damping_factor * x + (1 - damping_factor) * xp
    P = damping_factor * P
    return xp, P, y, S, K, x
