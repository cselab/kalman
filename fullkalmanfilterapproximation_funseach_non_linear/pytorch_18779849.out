def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    P_clamped = np.maximum(P, 1e-6)
    K = P_clamped @ np.linalg.inv(S)
    x = xp + K @ y
    P = (F @ P @ F.T + Q) - K @ y @ K.T
    return xp, P, y, S, K, x
