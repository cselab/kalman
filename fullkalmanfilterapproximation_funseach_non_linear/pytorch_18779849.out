def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using gradient descent
    inv_S = np.random.rand(*S.shape)
    for _ in range(100):
        current = inv_S @ S
        target = np.eye(S.shape[0])
        inv_S += 0.1 * (target - current) @ S
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    loss = np.mean((z - x)**2)
    history.append(loss)
    return xp, P, y, S, K, x
