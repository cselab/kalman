def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    y = z - xp
    P_new = F @ P @ F.T + Q
    S = P_new + R
    # Using SVD for matrix inversion
    U, S, V = np.linalg.svd(S)
    inv_S = np.linalg.inv(S)
    K = P_new @ (V.T @ (inv_S * np.ones_like(S)) @ U.T)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_new
    return xp, P, y, S, K, x
