def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Adjusting F dynamically based on previous state
    global history
    history.append(x)
    if len(history) > 1:
        dx = history[-1] - history[-2]
        F = F + 0.1 * dx
    xp = F @ x
