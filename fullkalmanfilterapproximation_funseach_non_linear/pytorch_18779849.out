def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use a different loss function, such as Huber loss
    rho = np.log(1 + y**2 / (S + 1e-8))
    d = 2 * y / (S + 1e-8) / (1 + y**2 / (S + 1e-8))
    # Apply dithering to reduce numerical errors
    epsilon = np.random.randn(*y.shape) * 1e-8
    y = y + epsilon
    S_dithered = S + np.var(epsilon) * y.shape[0]
    K = P @ np.linalg.inv(S_dithered)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_dithered, y, P, K, x
