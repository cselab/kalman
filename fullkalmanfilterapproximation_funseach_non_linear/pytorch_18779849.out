def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    sqrt_S = np.linalg.sqrtm(S + 1e-5 * np.eye(S.shape[0]))
    inv_S = np.linalg.inv(sqrt_S @ sqrt_S)
    K = P @ inv_S @ y.T
    x = xp + K.T @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
