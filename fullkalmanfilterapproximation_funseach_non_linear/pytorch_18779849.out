def aproximate(x, F, P, Q, z, R):
    from numpy import array, dot, sqrt, diag, linalg, random
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    K = P.dot(linalg.inv(S))
    x = xp + K.dot(y)
    # Add a small perturbation for better convergence
    x = x + array([0.01, 0.01])
    return xp, P, y, S, K, x
