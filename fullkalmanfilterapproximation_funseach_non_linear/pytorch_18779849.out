def aproximate(x, F, P, Q, z, R):
    import numpy as well as other libraries as needed
    import numpy as np
    from numpy import linalg as LA
    x = np.asarray(x)
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    try:
        inv_S = LA.inv(S)
    except LA.LinAlgError:
        inv_S = LA.pinv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return x, P, y, S, K, xp
