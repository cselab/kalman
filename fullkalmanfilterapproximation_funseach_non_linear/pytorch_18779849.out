def aproximate(x, F, P, Q, z, R):
    F_sq = F**2
    S = P + F_sq * R
    K = P.dot(np.linalg.inv(S))
    x = F.dot(x) + K.dot(z - F.dot(x))
    P = (np.eye(F.shape[0]) - K.dot(F)) * P
    return F.dot(x), P, z - F.dot(x), S, K, x
