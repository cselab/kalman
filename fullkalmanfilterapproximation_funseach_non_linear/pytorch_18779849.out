def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inv_S using SVD
    U, sigma, V = np.linalg.svd(S)
    inv_sigma = 1 / sigma
    inv_S = V.T @ (np.diag(inv_sigma)) @ U.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
