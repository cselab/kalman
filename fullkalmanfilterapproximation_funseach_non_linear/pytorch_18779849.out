def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    Q, R = np.linalg.qr(S)
    inv_S = np.linalg.solve(R.T, Q.T).T
    K = P @ inv_S
    x = xp + K @ y
    x += np.random.normal(0, 0.1, x.shape)
    return xp, P, y, S, K, x
