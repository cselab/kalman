function:
def aproximate(x, F, P, Q, z, R):
    # Compute the predicted state
    xp = F @ x
    # Compute the predicted covariance
    P = F @ P @ F.T + Q
    # Compute the innovation
    y = z - xp
    # Compute the innovation covariance
    S = P + R
    # Compute the Kalman gain
    K = P @ np.linalg.inv(S)
    # Update the state estimate
    x = xp + K @ y
    # Apply a non-linear transformation to P to reduce uncertainty
    P = np.log(P + 1) * 2
    return xp, P, y, S, K, x
