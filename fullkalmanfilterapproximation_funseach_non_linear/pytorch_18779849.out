def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[np.diag_indices(S.shape[0])] = 1.0 / S
    K = P @ (V.T @ (inv_S * np.eye(S.shape[0])) @ U.T)
    x = xp + K @ y
    P = (F @ P @ F.T + Q) - K @ y @ K.T
    return xp, P, y, S, K, x
