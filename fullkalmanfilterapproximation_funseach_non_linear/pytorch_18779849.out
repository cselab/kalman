def aproximate(x, F, P, Q, z, R):
    global history
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Add random perturbation
    noise = 0.001 * np.random.randn(*P.shape)
    P += noise
    history.append((xp, S, y, P, K, x))
    return xp, S, y, P, K, x
