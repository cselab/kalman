def aproximate(x, F, P, Q, z, R):
    # Implementation 2: Element-wise Noise Handling
    xp = F @ x
    P = F @ P @ F.T + np.sum(Q) * np.eye(F.shape[0])
    y = z - xp
    S = P + np.sum(R) * np.eye(R.shape[0])
    inv_S = np.linalg.inv(S)
    K = inv_S @ P.T
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(x)
    return xp, P, y, S, K, x
