def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Using Cholesky decomposition for solving
    L = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(L.T) @ np.linalg.inv(L)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return xp, P, y, S, K, x
