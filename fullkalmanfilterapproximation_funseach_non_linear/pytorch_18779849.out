    U, S, V = np.linalg.svd(S)
    threshold = 0.01
    S_inv = np.diag(1/(np.maximum(S, threshold)))
    inv_S = U @ S_inv @ V.T
    K = P @ inv_S
    x = xp + K @ y
    return xp, S, y, P, K, x
