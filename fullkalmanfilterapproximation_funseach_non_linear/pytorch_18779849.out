    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a random noise to all variables
    noise_x = np.random.randn(*x.shape) * 1e-5
    noise_P = np.random.randn(*P.shape) * 1e-5
