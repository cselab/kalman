def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Expectation-Maximization approach
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # EM step for P
    P = F @ P @ F.T + Q - K @ R
    return xp, P, y, S, K, x
