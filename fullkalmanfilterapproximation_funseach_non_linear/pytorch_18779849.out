def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.diag(1/S)
    K = (V.T @ inv_S @ U.T @ P.T).T @ y
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
