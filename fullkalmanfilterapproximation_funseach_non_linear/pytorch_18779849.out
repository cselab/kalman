def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    S += 1e-5 * np.eye(S.shape[0])
    S_inv = np.linalg.inv(S)
    K = P @ S_inv @ y
    x = xp + K
    x = np.clip(x, -5, 5)
    history.append(x)
    return (xp, P, y, S, K, x)
