def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R + 0.01 * np.mean(R) * np.ones_like(P)
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(F.T @ F + 0.01 * np.eye(F.shape[1])) - K.T) @ P.T).T
    return xp, P, y, S, K, x
