def aproximate(x, F, P, Q, z, R):
    weight = np.random.rand(*x.shape)
    xp = F @ (x * weight)
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
