def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use a different solver for linear systems
    from scipy.linalg import lstsq
    K, residuals, rank, singular_values = lstsq(S.T, P.T, rcond=None)
    K = K.T
    x = xp + K @ y
    return xp, S, y, P, K, x
