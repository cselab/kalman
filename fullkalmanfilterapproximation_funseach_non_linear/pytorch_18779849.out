def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute K using matrix inversion with regularization
    S_reg = S + np.eye(S.shape[0]) * 1e-6
    K = P @ np.linalg.inv(S_reg)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_reg, y, P, K, x
