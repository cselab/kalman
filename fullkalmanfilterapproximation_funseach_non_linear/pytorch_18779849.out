def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a small discount to the covariance update
    discount = 0.99
    P_new = (np.eye(F.shape[0]) - K) @ P
    P = discount * P + (1 - discount) * P_new
    return xp, P, y, S, K, x
