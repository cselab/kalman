def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using Cholesky decomposition
    L = np.linalg.cholesky(S)
    Linv = np.linalg.inv(L)
    S_inv = Linv.T @ Linv
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
