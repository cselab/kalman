function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # M-estimator with Tukey's loss
    rho = np.sqrt(np.abs(y) / (S + 1e-8))
    rho = np.where(rho > 1, 1, rho)
    rho = rho ** 2
    d = 2 * np.sign(y) / (S + 1e-8) * (rho <= 1)
    Q = Q * np.exp(-rho)
    P = F @ (P - Q) @ F.T + Q
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_robust, K, x
