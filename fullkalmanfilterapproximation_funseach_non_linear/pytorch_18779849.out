function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use SVD for inversion of S
    u, s, v = np.linalg.svd(S)
    inv_S_svd = np.zeros_like(S)
    inv_S_svd = v.T @ (np.diag(1/s)) @ u.T
    K = P @ inv_S_svd
    return xp, P, y, S, K, x
