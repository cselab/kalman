def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use Woodbury matrix identity for updating P
    inv_P = np.linalg.inv(P)
    delta = K @ y
    inv_P = inv_P + delta @ delta.T
    P = np.linalg.inv(inv_P)
    return xp, P, y, S, K, x
