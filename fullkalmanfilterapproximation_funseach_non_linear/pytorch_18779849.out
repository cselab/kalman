def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using matrix inversion lemma
    inv_S = np.linalg.inv(S)
    K = P @ inv_S @ y
    x = xp + K
    # Compute updated P
    P = (np.eye(F.shape[0]) - K @ F.T) @ P
    return xp, P, y, S, K, x
