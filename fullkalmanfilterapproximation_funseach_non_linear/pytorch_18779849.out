def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD
    U, S, V = np.linalg.svd(S, full_matrices=True)
    inv_S = V.T @ np.linalg.inv(np.diag(S)) @ U.T
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S, K, x
