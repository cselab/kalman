def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Tikhonov regularization
    alpha = 1e-8
    S_reg = S + alpha * np.eye(S.shape[0])
    K = P @ np.linalg.inv(S_reg)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_reg, K, x
