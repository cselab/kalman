function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    S_chol = np.linalg.cholesky(S + 1e-5 * np.eye(S.shape[0]))
    K = P @ np.linalg.solve(S_chol.T, np.linalg.solve(S_chol, y))
    x = xp + K
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
