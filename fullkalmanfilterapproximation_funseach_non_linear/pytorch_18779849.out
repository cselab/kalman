def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Batch processing over multiple steps
    x_batch = np.repeat(x, 10, axis=0)
