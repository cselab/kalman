function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = P - K @ F @ P
    loss = np.sum(y**2) / (np.trace(S) + 1e-8)
    return xp, S, y, P, K, x
