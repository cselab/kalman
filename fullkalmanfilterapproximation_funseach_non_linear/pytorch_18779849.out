def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Gradient Descent optimization
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply gradient descent to x
    loss = np.sum((z - x)**2)
    dx = 2 * (z - x) * F.T
    x += dx * 0.01
    return xp, P, y, S, K, x
