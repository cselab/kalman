function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    # Compute square root of P
    sqrt_P = np.linalg.cholesky(P)
    # Update state
    y = z - xp
    S = P + R
    sqrt_S = np.linalg.cholesky(S)
    # Compute Kalman gain
    K = sqrt_P @ np.linalg.inv(sqrt_S)
    x = xp + K @ y
    # Update covariance
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
