def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply wavelet denoising to y
    from scipy import signal
    import numpy as np
    wavelet = 'haar'
    level = 1
    y_denoised = signal.wavelet_denoise(y, wavelet=wavelet, level=level)
    S_denoised = P + R
    K = P @ np.linalg.inv(S_denoised)
    x = xp + K @ y_denoised
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_denoised, K, x
