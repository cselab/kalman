function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Use RMSprop for x update
    beta = 0.99
    epsilon = 1e-8
    g = x - xp
    x = x - (g * (1 - beta)) / (np.sqrt(np.mean(g**2)) + epsilon)
    return xp, P, y, S, K, x
