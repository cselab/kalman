    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Update P using inversion lemma to avoid matrix inversion
    inv_S = np.linalg.inv(S)
    P = F @ P @ F.T + Q - K @ R @ inv_S.T
    return xp, P, y, S, K, x
