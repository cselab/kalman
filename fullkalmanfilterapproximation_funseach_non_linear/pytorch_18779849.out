function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use SVD to compute the pseudo-inverse of S
    U, S_svd, V = np.linalg.svd(S, full_matrices=True)
    inv_S = np.zeros_like(S)
    inv_S[np.diag_indices(S.shape[0])] = 1.0 / S_svd
    inv_S = V.T @ inv_S @ U.T
    K = P @ inv_S @ y
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
