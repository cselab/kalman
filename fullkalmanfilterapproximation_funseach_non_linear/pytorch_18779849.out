def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Use Woodbury matrix identity to update P
    inv_P = np.linalg.inv(P)
    inv_P = inv_P - K @ np.linalg.inv(S) @ K.T
    P = np.linalg.inv(inv_P)
