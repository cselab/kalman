def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a scaled identity matrix to P to prevent singularity
    scale = 0.1
    I = np.eye(P.shape[0])
    P = P + scale * I
    return xp, P, y, S, K, x
