def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    K = P.dot(np.linalg.inv(S))
    x = xp + K.dot(y)
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
