def aproximate(x, F, P, Q, z, R):
    factor = np.random.rand(*x.shape)
    xp = F @ (x * factor)
    P = (F @ P) * factor @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    x = x * factor
    return xp, P, y, S, K, x
