def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Huber loss
    rho = np.where(np.abs(y) < 1, 0.5 * y**2, np.abs(y))
    d = np.sign(y) * np.maximum(1, np.abs(y))
