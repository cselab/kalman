function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Factorize P for efficient updates
    L = np.linalg.cholesky(P)
    P = L @ L.T
    return xp, P, y, S, K, x
