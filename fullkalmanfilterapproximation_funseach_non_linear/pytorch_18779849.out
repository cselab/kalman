def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Optimal inversion using SVD
    U, S, V = numpy.linalg.svd(S, full_matrices=True)
    inv_S = numpy.diag(1 / S)
    inv_S = U @ inv_S @ V.T
    K = P @ inv_S
    x = xp + K @ y
    P = (numpy.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
