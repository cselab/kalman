function:
def aproximate(x, F, P, Q, z, R):
    global history
    # Store the current state and measurement in history
    history.append((x, z))
    
    # Compute the predicted state
    xp = F @ x
    # Update the covariance matrix
    P = F @ P @ F.T + Q
    # Compute the innovation
    y = z - xp
    # Compute the innovation covariance
    S = P + R
    # Compute the Kalman gain
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    # Update the state estimate
    x = xp + K @ y
    # Update the covariance matrix
    P = (np.eye(F.shape[0]) - K @ F) @ P
    return xp, P, y, S, K, x
