def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ numpy.linalg.pinv(S)
    x = xp + K @ y
    P = (numpy.eye(F.shape[0]) - K @ P)
    return xp, P, y, S, K, x
