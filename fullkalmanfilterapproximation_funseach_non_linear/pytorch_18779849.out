def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Huber loss for robust estimation
    rho = 0.01
    l = np.sqrt(np.maximum(0, 1 - (rho * np.abs(y))))
    dl = rho * np.sign(y) / (2 * np.sqrt(np.maximum(0, 1 - rho * np.abs(y))))
    S_robust = (P + R) * dl[:, np.newaxis]
    K = P @ np.linalg.inv(S_robust.T @ S_robust)
    x = xp + K @ y
    return xp, P, y, S_robust, K, x
