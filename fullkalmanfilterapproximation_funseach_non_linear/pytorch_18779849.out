def aproximate(x, F, P, Q, z, R):
    global history
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S_diag, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[np.diag_indices(S.shape[0])] = 1. / S_diag
    inv_S = U @ inv_S @ V.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P) @ F.T
    return xp, P, y, S, K, x
