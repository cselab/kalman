def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Kalman Smoother implementation
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply smoothing
    x_smooth = x + np.linalg.inv(F) @ (x - xp)
    return xp, P, y, S, K, x_smooth
