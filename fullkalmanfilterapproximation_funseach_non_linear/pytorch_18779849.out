def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using diagonal dominance check
    if np.all(S.diagonal() > np.sum(np.abs(S - np.diag(S.diagonal())), axis=1)):
        inv_S = np.diag(1/S.diagonal())
    else:
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    loss = np.mean((z - x)**2)
    history.append(loss)
    return xp, P, y, S, K, x
