function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Use matrix inversion with SVD for numerical stability
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD
    U, S, V = np.linalg.svd(S, full_matrices=True)
    inv_S = np.zeros_like(S)
    inv_S[-len(S):] = 1 / S[-len(S):]
    inv_S = np.diag(inv_S)
    K = P @ (V.T @ inv_S @ U.T)
    x = xp + K @ y
    return xp, P, y, S, K, x
