def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S + 1e-14 * np.eye(S.shape[0]))
    K = P @ inv_S
    x = xp + K @ y
    # Robustification step
    x = x * (1 - np.exp(-np.linalg.norm(y) / 2))
    return xp, P, y, S, K, x
