function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[np.diag_indices(len(S))] = 1. / S
    K = P @ (V.T @ inv_S @ U.T)
    x = xp + K @ y
    return xp, P, y, S, K, x
