function:
def aproximate(x, F, P, Q, z, R):
    # Unscented Kalman filter implementation
    n = x.shape[0]
    m = z.shape[0]
    alpha = 1
    beta = 2
    kappa = n - m
    lambda_ = alpha ** 2 * (n + kappa) / m
    sigma = np.linalg.cholesky(P)
    sigmas = np.zeros((n, 2 * n))
    for i in range(n):
        sigmas[:, 2*i] = x + alpha * sigma[:,i]
        sigmas[:, 2*i+1] = x - alpha * sigma[:,i]
    sigmas = F @ sigmas
    xp = sigmas.mean(axis=1)
    S = (sigmas - xp[:,None]) @ (sigmas - xp[:,None].T) + Q
    y = z - xp
    S_cross = S + R
    W = np.zeros((2 * n, 2 * n))
    for i in range(n):
        W[2*i, 2*i] = W[2*i+1, 2*i+1] = lambda_
        W[2*i, 2*i+1] = W[2*i+1, 2*i] = (1 - alpha ** 2 + beta)
    K = P @ F.T @ np.linalg.inv(S_cross)
    x = xp + K @ y
    P = (np.eye(n) - K @ F) @ P
    return xp, P, y, S_cross, K, x
