function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x_p = F @ x
    P_p = F @ P @ F.T + Q
    y = z - x_p
    S = P_p + R
    # Compute inverse using Cholesky decomposition
    L = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(L.T) @ np.linalg.inv(L)
    K = P_p @ inv_S @ y
    x = x_p + K
    P = P_p - K[:, None] * K[None, :]
    return x_p, P_p, y, S, K, x
