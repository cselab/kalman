function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Use matrix inversion with SVD to handle near-singular matrices
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[S > 1e-8] = 1 / S[S > 1e-8]
    inv_S_full = np.zeros_like(S)
    inv_S_full[:len(inv_S)] = inv_S
    K = P @ (V.T @ inv_S_full @ U.T)
    return xp, S, y, P, K, x
