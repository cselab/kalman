def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    # Compute inverse of S using Cholesky decomposition
    inv_S = np.linalg.cholesky(S).T @ np.linalg.cholesky(S).T.T
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S, K, x
