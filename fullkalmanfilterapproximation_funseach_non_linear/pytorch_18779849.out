function:
def aproximate(x, F, P, Q, z, R):
    batch_size = 100
    n_batches = x.shape[1] // batch_size
    xp_list = []
    P_list = []
    y_list = []
    S_list = []
    K_list = []
    x_list = []
    for i in range(n_batches):
        x_batch = x[:, i*batch_size:(i+1)*batch_size]
        xp = F @ x_batch
        P = F @ P @ F.T + Q
        y = z - xp
        S = P + R
        inv_S = np.linalg.inv(S + 1e-11 * np.eye(S.shape[0]))
        K = P @ inv_S
        x = xp + K @ y
        x = np.clip(x, -5, 5)
        xp_list.append(xp)
        P_list.append(P)
        y_list.append(y)
        S_list.append(S)
        K_list.append(K)
        x_list.append(x)
    xp = np.concatenate(xp_list, axis=1)
    P = np.concatenate(P_list, axis=2)
    y = np.concatenate(y_list, axis=1)
    S = np.concatenate(S_list, axis=2)
    K = np.concatenate(K_list, axis=2)
    x = np.concatenate(x_list, axis=1)
    return xp, P, y, S, K, x
