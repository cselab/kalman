def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Compute the log determinant of P
    log_det_P = np.log(np.linalg.det(P))
    # Update P based on log determinant to avoid singularities
    if log_det_P < -100:
        P = P * 1.01
    elif log_det_P > 0:
        P = P * 0.99
    return xp, P, y, S, K, x
