def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    rank = np.linalg.matrix_rank(S)
    if rank == S.shape[0]:
        S_inv = np.linalg.inv(S)
    else:
        S_inv = np.linalg.pinv(S)
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
