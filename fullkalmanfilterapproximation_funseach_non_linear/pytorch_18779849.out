function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    S_inv = np.zeros_like(S)
    S_inv[:S.size] = 1. / S
    S_inv = np.dot(U, np.dot(np.diag(S_inv), V))
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
