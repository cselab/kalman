def aproximate(x, F, P, Q, z, R):
    import numpy as np
    F_norm = np.linalg.norm(F, ord='fro')
    F = F + 0.01 * F_norm * np.eye(F.shape[0])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(np.eye(F.shape[0]) + F @ P @ F.T) - K) @ P
    return xp, P, y, S, K, x
