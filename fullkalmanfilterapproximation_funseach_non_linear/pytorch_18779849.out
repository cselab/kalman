function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a non-linear scaling to P based on the magnitude of x
    scale = np.exp(-0.1 * np.linalg.norm(x))
    P = P * scale
    # Add a small scaled identity matrix to P
    P += np.eye(P.shape[0]) * 1e-6
    # Ensure P is symmetric
    P = (P + P.T) / 2
    return xp, P, y, S, K, x
