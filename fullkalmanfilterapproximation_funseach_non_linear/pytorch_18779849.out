def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a perturbation scaled by the maximum eigenvalue of P
    eigenvalues = np.linalg.eigvals(P)
    max_eig = eigenvalues.max()
    scale = max_eig * 1e-4
    perturbation = np.random.randn(*P.shape) * scale
    P += perturbation
    return xp, P, y, S, K, x
