function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    threshold = np.sqrt(S.trace())
    rho = np.where(np.abs(y) < threshold, 0.5 * y**2, np.abs(y))
    d = np.sign(y) * np.maximum(1, np.abs(y) / threshold)
    Q_robust = Q * rho
    P = F @ (P - Q_robust) @ F.T + Q_robust
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_robust, y, P, K, x
