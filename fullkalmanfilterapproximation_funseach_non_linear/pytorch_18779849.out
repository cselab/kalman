def aproximate(x, F, P, Q, z, R):
    from numpy.linalg import inv
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    K = P.dot(inv(S))
    x = xp + K.dot(y)
    P = (np.eye(F.shape[0]) - K).dot(P)
    return xp, P, y, S, K, x
