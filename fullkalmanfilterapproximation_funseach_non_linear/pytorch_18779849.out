def aproximate(x, F, P, Q, z, R):
    rank = np.linalg.matrix_rank(F)
    if rank < F.shape[0]:
        F = F + 0.01 * np.eye(F.shape[0])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
