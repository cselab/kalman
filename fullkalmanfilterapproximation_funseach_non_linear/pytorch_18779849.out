def aproximate(x, F, P, Q, z, R):
    from numpy import *
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    K = P.dot(linalg.inv(S))
    x = xp + K.dot(y)
    # Add a small random perturbation to x
    x += random.normal(0, 1e-6, x.shape)
    return xp, P, y, S, K, x
