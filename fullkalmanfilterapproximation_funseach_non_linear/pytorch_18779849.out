def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    # Adjust Q based on current P
    Q_adj = Q + 0.05 * P
    P = F @ P @ F.T + Q_adj
    y = z - xp
    S = P + R
    # Compute K using SVD for better numerical stability
    U, S_diag, V = numpy.linalg.svd(S)
    inv_S = numpy.diag(1/S_diag) @ V.T
    K = P @ inv_S
    x = xp + K @ y
    P = (numpy.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
