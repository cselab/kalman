def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    K = P @ (V.T @ np.linalg.inv(np.diag(S)) @ U.T)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P + 0.05 * Q + 0.01 * np.mean(y**2) * np.eye(F.shape[0])
    return xp, S, y, P, K, x
