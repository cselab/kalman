def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Square Root Kalman Filter implementation
    xp = F @ x
    P chol = np.linalg.cholesky(P + Q)
    y = z - xp
    S chol = np.linalg.cholesky(S + R)
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Update P using square root
    P = F @ P @ F.T + Q - K @ R
    return xp, P, y, S, K, x
