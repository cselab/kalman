def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Use SVD to ensure P is positive definite
    U, S, V = np.linalg.svd(P)
    P = U @ np.diag(np.maximum(S, 1e-8)) @ V
    return xp, S, y, P, K, x
