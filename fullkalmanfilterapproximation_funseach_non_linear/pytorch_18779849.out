def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    beta = 0.9
    P = (beta * P) + (1 - beta) * (F @ (P - (Q / beta)) @ F.T)
    P = F @ P @ F.T + Q
    return xp, P, y, S, K, x
