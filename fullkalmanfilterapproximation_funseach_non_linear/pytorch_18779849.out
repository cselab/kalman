def aproximate(x, F, P, Q, z, R):
    from numpy import array, dot, sqrt, diag, eye, linalg
    F = array(F)
    P = array(P)
    Q = array(Q)
    x = array(x)
    z = array(z)
    R = array(R)
    xp = dot(F, x)
    y = z - xp
    P = dot(F, dot(P, F.T)) + Q
    S = P + R
    try:
        inv_S = linalg.inv(S)
    except linalg.LinAlgError:
        inv_S = linalg.pinv(S)
    K = dot(P, inv_S)
    x = xp + dot(K, y)
    P = eye(len(x)) - dot(K, P)
    x = x.squeeze()
    P = P.squeeze()
    return xp, P, y, S, K, x
