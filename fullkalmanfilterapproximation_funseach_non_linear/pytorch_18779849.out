function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    from numpy import linalg
    x = x.copy()
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    K = P.dot(linalg.inv(S))
    x = xp + K.dot(y)
    # Update P with a dampened version of the new estimate
    P_new = (np.eye(F.shape[0]) - K) @ P
    P = 0.9 * P + 0.1 * P_new
    return xp, P, y, S, K, x
