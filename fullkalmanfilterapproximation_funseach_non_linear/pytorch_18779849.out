def aproximate(x, F, P, Q, z, R):
    y = z - F @ x
    J = F
    H = np.identity(F.shape[0])
    I = np.identity(F.shape[0])
    for _ in range(10):
        K = (J @ (H @ y).T).T @ np.linalg.inv(I + J @ H @ J.T)
        x = x + K @ y
        y = y - H @ K @ y
    xp = F @ x
    P = J @ J.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (I - K @ P)
    return xp, P, y, S, K, x
