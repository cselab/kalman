def aproximate(x, F, P, Q, z, R):
    x_next = F @ x
    P_next = F @ P @ F.T + Q
    y = z - x_next
    S = P_next + R
    inv_S = np.linalg.inv(S)
    K = P_next @ inv_S
    x_new = x_next + K @ y
    # Apply some noise or scaling
    x_new = x_new * (1 + np.random.uniform(-0.02, 0.02, x.shape))
    # Keep track of the state
    history.append(x_new)
    return x_next, P_next, y, S, K, x_new
