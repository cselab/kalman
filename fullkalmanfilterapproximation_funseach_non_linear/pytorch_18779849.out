def aproximate(x, F, P, Q, z, R):
    global history
    if not hasattr(aproximate, 'history'):
        aproximate.history = []
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = inv_S @ P @ y
    x = xp + K
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    loss = np.sum((z - xp)**2)
    aproximate.history.append(loss)
    return xp, P, y, S, K, x
