def aproximate(x, F, P, Q, z, R):
    n = x.shape[0]
    alpha = 1.0
    beta = 2.0
    kappa = 0.0
    lambda_ = alpha**2 * (n + kappa) - n
    sigmas = np.zeros((n, 2n+1))
    sigmas[:,0] = x
    sigmas[:,1:n+1] = np.sqrt(P) * np.random.randn(n, n)
    sigmas[:,n+1:] = -sigmas[:,1:n+1]
    xp = F @ x
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    return xp, P, y, S, K, x
