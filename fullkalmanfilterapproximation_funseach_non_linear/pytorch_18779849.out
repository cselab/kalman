def aproximate(x, F, P, Q, z, R):
    import numpy as np
    import math
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    eigenvalues_S = np.linalg.eigvalsh(S)
    scale = 1 + math.exp(-np.mean(eigenvalues_S))
    R_adj = R * scale
    S_adj = P + R_adj
    K = P.dot(np.linalg.inv(S_adj))
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S_adj, K, x
