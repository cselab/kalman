def aproximate(x, F, P, Q, z, R):
    alpha = 0.1
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    x = alpha * x + (1 - alpha) * x
    P = (np.eye(F.shape[0]) - K @ P)
    return xp, P, y, S, K, x
