def aproximate(x, F, P, Q, z, R):
    import numpy as np
    n = x.shape[0]
    L = np.linalg.cholesky(P)
    y = z - F @ x
    S = F @ P @ F.T + Q + R
    Ls = np.linalg.cholesky(S)
    K = L @ np.linalg.inv(F @ L.T) @ np.linalg.inv(Ls.T) @ y
    x = x + K @ y
    P = L @ L.T
    return F @ x, P, y, S, K, x
