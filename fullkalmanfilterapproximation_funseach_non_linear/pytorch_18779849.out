def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    sqrt_P = np.linalg.cholesky(P)
    sqrt_P_new = F @ sqrt_P
    P_new = sqrt_P_new @ sqrt_P_new.T + np.linalg.cholesky(Q) @ np.linalg.cholesky(Q).T
    y = z - xp
    S = P_new + R
    sqrt_S = np.linalg.cholesky(S)
    inv_sqrt_S = np.linalg.inv(sqrt_S)
    K = sqrt_P_new @ inv_sqrt_S
    x = xp + K @ y
    sqrt_P = (np.linalg.inv(F.T @ F) - K @ F) @ sqrt_P
    P = sqrt_P @ sqrt_P.T
    return xp, P, y, S, K, x
