def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = np.dot(F, x)
    P_new = np.dot(np.dot(F, P), F.T) + Q
    y = z - xp
    S = P_new + R
    inv_S = np.linalg.inv(S)
    K = np.dot(P_new, inv_S)
    x = xp + np.dot(K, y)
    P = np.eye(F.shape[0]) - np.dot(K, P_new)
    return xp, P, y, S, K, x
