def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the largest eigenvalue ratio
    eigs_S = np.linalg.eigvals(S)
    eigs_R = np.linalg.eigvals(R)
    scale = np.max(eigs_S) / np.max(eigs_R)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.linalg.inv(S_adj) @ P)
    return xp, P, y, S_adj, K, x
