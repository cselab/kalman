function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a soft-clipping to y to reduce the effect of outliers
    y_clipped = np.tanh(y)
    x = xp + K @ y_clipped
    # Update P based on the clipped y
    P = F @ (P - K @ y_clipped) @ F.T + Q
    return xp, P, y_clipped, S, K, x
