function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Invert matrices with numerical stability
    S = P + R
    try:
        S_inv = np.linalg.inv(S)
    except np.linalg.LinAlgError:
        # Add small epsilon to diagonal to make S invertible
        eps = 1e-8
        S += eps * np.eye(S.shape[0])
        S_inv = np.linalg.inv(S)
    K = P @ S_inv
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
