def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    eps = 1e-8
    inv_S = np.linalg.inv(S + eps * np.eye(S.shape[0]))
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
