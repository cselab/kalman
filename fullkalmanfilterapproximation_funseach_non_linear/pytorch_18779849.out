    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply dropout to K
    keep_prob = 0.8
    mask = np.random.binomial(1, keep_prob, size=K.shape)
    x = xp + (K * mask) @ y
    return xp, P, y, S, K, x
