function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Add a small noise to x to prevent singular matrices
    epsilon = 1e-8
    x_perturbed = x + np.random.randn(*x.shape) * epsilon
    xp = F @ x_perturbed
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S + np.eye(S.shape[0]) * epsilon)
    x = xp + K @ y
    return xp, P, y, S, K, x
