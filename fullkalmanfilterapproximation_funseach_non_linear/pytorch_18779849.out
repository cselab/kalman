def aproximate(x, F, P, Q, z, R):
    global history
    # Standard Kalman Filter implementation
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
