def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    chol_S = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(chol_S @ chol_S.T)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P) @ F.T
    return xp, P, y, S, K, x
