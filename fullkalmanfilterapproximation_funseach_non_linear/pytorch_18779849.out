def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the Kalman gain with a stabilized inverse
    eps = 1e-8
    S_inv = np.linalg.inv(S + eps * np.eye(S.shape[0]))
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Apply a non-linear transformation to P
    P = np.log(P + 1e-6)
    return xp, S, y, P, K, x
