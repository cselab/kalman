def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Modified Kalman Filter with adaptive scaling
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Scale state based on the magnitude of y
    scale_factor = np.exp(-np.mean(y**2))
    x_scaled = x * scale_factor
    P_scaled = P * scale_factor
    return xp, P_scaled, y, S, K, x_scaled
