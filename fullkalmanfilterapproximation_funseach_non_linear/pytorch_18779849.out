def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Threshold singular values of P to reduce noise
    U, s, V = np.linalg.svd(P)
    s = np.maximum(s - 0.01, 0)
    P = U @ np.diag(s) @ V.T
    return xp, P, y, S, K, x
