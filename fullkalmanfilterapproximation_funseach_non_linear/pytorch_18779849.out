def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R + 1e-8 * np.eye(len(R))
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Detect and remove outliers
    outlier_mask = np.abs(y) > 3 * np.std(y)
    y_clean = y[~outlier_mask]
    x = xp + K @ y_clean
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
