def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a non-linear transformation to P
    P = np.maximum(P, np.zeros_like(P)) + np.minimum(P, np.zeros_like(P))
    return xp, P, y, S, K, x
