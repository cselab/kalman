def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use a weighted average to update P
    alpha = 0.5
    P = alpha * P + (1 - alpha) * (F @ P @ F.T + Q)
    return xp, S, y, P, K, x
