def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Use a numerically stable matrix inversion method
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using Cholesky decomposition
    try:
        L = np.linalg.cholesky(S)
        inv_S = np.linalg.inv(L).T @ np.linalg.inv(L)
    except np.linalg.LinAlgError:
        # If Cholesky fails, use direct inversion
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S, K, x
