function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg_inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Add a non-linear correction
    P = P * (1 + np.tanh(0.1 * y))
    return xp, S, y, P, K, x
