function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    residuals = np.linalg.norm(y, axis=0)
    scale = np.sqrt(np.exp(-residuals**2 / (2 * S.trace())))
    Q_adj = Q * scale
    P = F @ (P - Q_adj) @ F.T + Q_adj
    S_adj = P + R
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P + 0.05 * Q + 0.01 * np.mean(y**2) * np.eye(F.shape[0])
    return xp, S_adj, y, P, K, x
