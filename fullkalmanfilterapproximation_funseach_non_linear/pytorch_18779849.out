def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S + 1e-5 * np.eye(S.shape[0]))
    x = xp + K @ y
    x = np.clip(x, -4, 4)
    return xp, P, y, S, K, x
