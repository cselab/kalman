def aproximate(x, F, P, Q, z, R):
    xp = np.dot(F, x)
    P = np.dot(F, np.dot(P, F.T)) + Q
    y = z - xp
    S = P + R
    eps = 1e-7
    inv_S = np.linalg.inv(S + eps * np.eye(S.shape[0]))
    K = inv_S @ P
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
