def aproximate(x, F, P, Q, z, R):
    xp = np.sum(F * x, axis=1)
    P = np.sum(F[:, np.newaxis] * P * F[np.newaxis,:], axis=2) + Q
    y = z - xp
    S = P + R
    K = np.linalg.solve(S, P.T).T @ y
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
