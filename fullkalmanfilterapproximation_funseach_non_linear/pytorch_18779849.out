def aproximate(x, F, P, Q, z, R):
    sqrt_P = np.linalg.cholesky(P)
    sqrt_xp = F @ x
    sqrt_P = F @ sqrt_P @ F.T + np.linalg.cholesky(Q)
    y = z - sqrt_xp
    S = sqrt_P @ sqrt_P.T + R
    sqrt_S = np.linalg.cholesky(S)
    K = sqrt_P @ np.linalg.inv(sqrt_S)
    x = sqrt_xp + K @ y
    inv_S = np.linalg.inv(S)
    inv_P = np.linalg.inv(P)
    cross = K @ inv_S @ K.T
    inv_P = inv_P - cross
    P = np.linalg.inv(inv_P)
    return sqrt_xp, S, y, P, K, x
