def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S + np.eye(S.shape[0]) * 1e-5)
    x = xp + K @ y
    # Scale P by a factor to reduce uncertainty
    scale_factor = 0.95
    P = P * scale_factor
    return xp, P, y, S, K, x
