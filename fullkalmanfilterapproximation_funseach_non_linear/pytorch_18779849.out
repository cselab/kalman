def aproximate(x, F, P, Q, z, R):
    global history
    
    # Compute the health metric
    health = np.mean(np.abs(z - F @ x))
    
    # Adjust R based on health
    R_adj = R * (1 + 0.1 * health)
    
    # Compute S
    S = P + R_adj
    
    # Compute K
    K = P @ np.linalg.inv(S)
    
    # Update x
    x = F @ x + K @ (z - F @ x)
    
    # Update P
    P = (np.eye(F.shape[0]) - K) @ P
    
    # Compute the loss
    loss = np.mean((z - F @ x)**2)
    
    # Append loss to history
    history.append(loss)
    
    # Return the required outputs
    return F @ x, P, z - F @ x, S, K, x
