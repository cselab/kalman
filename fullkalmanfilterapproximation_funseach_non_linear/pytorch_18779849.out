def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD
    u, s, v = np.linalg.svd(S, full_matrices=True)
    inv_S = v.T @ (np.diag(1/s)) @ u.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    loss = np.mean((z - x)**2)
    history.append(loss)
    return xp, P, y, S, K, x
