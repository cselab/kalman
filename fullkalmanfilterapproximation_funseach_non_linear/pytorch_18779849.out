def aproximate(x, F, P, Q, z, R):
    x_p = F.dot(x)
    P_p = F.dot(P.dot(F.T)) + Q
    y = z - x_p
    S = P_p + R
    U, S_diag, V = np.linalg.svd(S, full_matrices=False)
    inv_S = np.zeros_like(S)
    inv_S[S_diag != 0] = 1 / S_diag[S_diag != 0]
    inv_S = np.diag(inv_S)
    K = P_p @ (V.T @ inv_S @ U.T)
    x = x_p + K.dot(y)
    P = P_p - K[:, None] @ K[None, :]
    return x_p, P_p, y, S, K, x
