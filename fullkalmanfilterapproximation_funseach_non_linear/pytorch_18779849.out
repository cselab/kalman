def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    cho, _ = np.linalg.cholesky(S, lower=True)
    K = np.linalg.solve(cho, P.T).T @ y
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
