def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Add small identity to S for numerical stability
    eps = 1e-5
    S_reg = S + eps * np.eye(S.shape[0])
    K = P @ np.linalg.inv(S_reg)
    x = xp + K @ y
    return xp, P, y, S, K, x
