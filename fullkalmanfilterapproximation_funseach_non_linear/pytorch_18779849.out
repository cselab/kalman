function:
def aproximate(x, F, P, Q, z, R):
    global history
    # Store the current state in history
    history.append((x.copy(), F.copy(), P.copy(), Q.copy(), z.copy(), R.copy()))
    
    # Predict step
    xp = F @ x
    # Compute the predicted covariance
    P = F @ P @ F.T + Q
    # Compute the innovation
    y = z - xp
    # Compute the total covariance
    S = P + R
    # Compute the Kalman gain
    K = P @ np.linalg.inv(S + 1e-5 * np.eye(S.shape[0]))
    # Update the state estimate
    x = xp + K @ y
    # Clip the state to avoid numerical issues
    x = np.clip(x, -5, 5)
    
    # Return the computed values
    return xp, P, y, S, K, x
