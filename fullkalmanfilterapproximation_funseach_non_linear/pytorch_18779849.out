def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply singular value decomposition to y
    u, s, v = np.linalg.svd(y)
    threshold = np.mean(s)
    s_filtered = np.where(s > threshold, s, 0)
    y_svd = np.dot(u, np.dot(np.diag(s_filtered), v))
    S_svd = P + R
    K = P @ np.linalg.inv(S_svd)
    x = xp + K @ y_svd
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_svd, K, x
