def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the inverse of S using Cholesky decomposition
    L = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(L) @ np.linalg.inv(L.T)
    K = P @ inv_S @ y
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
