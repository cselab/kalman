def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute max eigenvalue ratio
    eigs_S = np.linalg.eigvalsh(S)
    eigs_R = np.linalg.eigvalsh(R)
    max_eig_S = np.max(eigs_S)
    max_eig_R = np.max(eigs_R)
    scale = np.clip(max_eig_S / max_eig_R, 0.1, 10)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
