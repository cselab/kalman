def aproximate(x, F, P, Q, z, R):
    sqrt_P = np.linalg.cholesky(P)
    sqrt_Q = np.linalg.cholesky(Q)
    sqrt_S = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(sqrt_S.dot(sqrt_S.T))
    K = (F.dot(sqrt_P).dot(inv_S))
    x = xp + K.dot(y)
    P = (np.eye(F.shape[0]) - K.dot(F.dot(P)))
    return xp, P, y, S, K, x
