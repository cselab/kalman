def aproximate(x, F, P, Q, z, R):
    global history
    # Store the current state and parameters for analysis
    history.append((x.copy(), F.copy(), P.copy(), Q.copy(), z.copy(), R.copy()))
    
    # Perform the state prediction
    xp = F @ x
    
    # Update the covariance matrix
    P = F @ P @ F.T + Q
    
    # Compute the innovation
    y = z - xp
    
    # Compute the updated covariance
    S = P + R
    
    # Calculate the Kalman gain
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    
    # Update the state estimate
    x = xp + K @ y
    
    # Clip the covariance to avoid numerical instability
    P = np.clip(P, 1e-6, None)
    
    # Return the required outputs
    return xp, P, y, S, K, x
