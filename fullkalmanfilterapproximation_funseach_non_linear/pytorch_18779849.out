def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add early stopping based on norm of x
    if np.linalg.norm(x) > 10:
        x = x / np.linalg.norm(x)
    return xp, P, y, S, K, x
