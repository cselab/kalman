def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Apply a non-linear transformation to P to reduce uncertainty
    P = P * (1 - 0.25) + (np.log(P + 1) * 0.25)
    history.append((xp, P, y, S, K, x))
    return xp, P, y, S, K, x
