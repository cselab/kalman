def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    rho = 1.0
    sigma = np.std(y)
    weights = rho - np.sqrt(1 + (y / sigma)**2 / rho)
    K = P @ (S + 1e-15 * np.eye(S.shape[0]))**-1
    x = xp + K @ (weights[:, None] * y)
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
