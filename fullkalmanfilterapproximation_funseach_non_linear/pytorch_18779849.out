def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S + 1e-5 * np.eye(S.shape[0]))
    inv_S = np.where(S > 1e-8, 1/S, 0)
    K = P @ (V.T @ inv_S @ U.T)
    x = xp + K @ y
    return xp, P, y, S, K, x
