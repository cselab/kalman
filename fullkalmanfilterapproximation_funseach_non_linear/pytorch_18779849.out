def aproximate(x, F, P, Q, z, R):
    # Implementation 4: Noisy State Transition
    xp = F @ x + np.random.normal(size=x.shape) * 0.01
    P = F @ P @ F.T + Q + np.random.normal(size=P.shape) * 0.1
    y = z - xp
