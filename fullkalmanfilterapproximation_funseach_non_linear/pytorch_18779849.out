def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    u, s, v = np.linalg.svd(S, full_matrices=True)
    s_inv = np.diag(1/s + 1e-10)
    S_inv = v @ s_inv @ u.T
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ F) @ P
    return xp, S, y, P, K, x
