def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S_svd, V = np.linalg.svd(S)
    inv_S_svd = np.diag(1/S_svd)
    inv_S = V.T @ inv_S_svd @ U.T
    K = P @ inv_S
    x = xp + K @ y
    P = np.eye(F.shape[0]) - K @ P
    return xp, P, y, S, K, x
