function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add noise scaled by the log of the inverse of the determinant of P
    det_P = np.linalg.det(P)
    det_P = det_P + 1e-10  # Avoid division by zero
    scale = 0.01 * np.log(1 / (det_P + 1e-10))
    noise = np.random.randn(*P.shape) * scale
    P += noise
    history.append(P)
    return xp, P, y, S, K, x
