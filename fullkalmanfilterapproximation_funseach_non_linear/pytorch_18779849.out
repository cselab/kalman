def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('init', x, F, P, Q, z, R))
    
    # Implementation 9: Block-wise Inversion
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = np.zeros_like(P)
    for i in range(F.shape[0]):
        K[i] = P[i] @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(('block_inv', xp, P, y, S, K, x))
    return xp, P, y, S, K, x
