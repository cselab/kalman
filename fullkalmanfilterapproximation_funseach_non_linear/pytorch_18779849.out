function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    # Compute S as P + R
    S = P + R
    # Compute the Cholesky decomposition of S
    L = np.linalg.cholesky(S)
    # Solve Ly = y using forward substitution
    Ly = y
    L_T = L.T
    L_T @ y
    y_lower = y
    y_upper = y
    for i in range(L.shape[0]):
        y_lower[i] = y_lower[i] / L[i, i]
        for j in range(i+1, L.shape[1]):
            y_lower[j] -= L[j, i] * y_lower[i]
    # Solve L^T @ y_upper = y_lower
    y_upper = y_lower.copy()
    for i in range(L.shape[0]-1, -1, -1):
        y_upper[i] = y_upper[i] / L[i, i]
        for j in range(i-1, -1, -1):
            y_upper[j] -= L[j, i] * y_upper[i]
    K = P @ y_upper
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
