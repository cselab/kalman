def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Momentum-based update for P
    P_new = F @ P @ F.T + Q - 0.1 * (P - F @ P @ F.T)
    P = P_new
    return xp, S, y, P, K, x
