def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use randomized SVD for inversion
    U, S, V = np.linalg.svd(S, full_matrices=True)
