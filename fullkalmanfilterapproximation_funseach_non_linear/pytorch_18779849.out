def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply expectation-maximization to y
    from sklearn.mixture import GaussianMixture
    gmm = GaussianMixture(n_components=2)
    gmm.fit(y.reshape(-1, 1))
    y_em = gmm.predict(y.reshape(-1, 1))
    S_em = P + R
    K = P @ np.linalg.inv(S_em)
    x = xp + K @ y_em
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_em, K, x
