def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = np.linalg.solve(S, P.T).T
    x = xp + K @ y
    return xp, P, S, y, K, x
