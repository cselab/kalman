def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Sparse Kalman Filter
    sparsity = 0.1
    P_sparse = P * (1 - sparsity * np.exp(-np.sum(y**2)))
    K = P_sparse @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_sparse
    return xp, S, y, P, K, x
