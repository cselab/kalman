def aproximate(x, F, P, Q, z, R):
    from numpy import sqrt
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R + 1e-8 * np.eye(len(R))
    # Compute square root of P and S
    U, S_sqrt, V = np.linalg.svd(S)
    P_sqrt = F @ P @ F.T + Q
    K = P_sqrt @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
