def aproximate(x, F, P, Q, z, R):
    noise = 0.003 * np.random.exponential(1, F.shape)
    F = F + noise
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = inv_S @ (P @ y)
    x = xp + K
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return xp, P, y, S, K, x
