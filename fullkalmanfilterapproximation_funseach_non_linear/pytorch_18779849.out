def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    lr = 0.1 / (1 + np.linalg.norm(y))
    K = P @ np.linalg.inv(S + lr * np.eye(S.shape[0]))
    x = xp + K @ y
    return xp, P, y, S, K, x
