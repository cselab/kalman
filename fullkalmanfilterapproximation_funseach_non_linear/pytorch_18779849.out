function:
def aproximate(x, F, P, Q, z, R):
    x_p = F @ x
    P_p = F @ P @ F.T + Q
    y = z - x_p
    S = P_p + R
    # Compute inverse using pivoted Cholesky
    L, piv = np.linalg.cholesky(S, True)
    inv_S = np.zeros_like(S)
    for i in range(len(piv)):
        inv_S[i, i] = 1.0 / L[i, i]
    inv_S = L.T @ inv_S @ L.T
    K = P_p @ inv_S @ y
    x = x_p + K
    P = P_p - K[:, None] * K[None, :]
    return x_p, P_p, y, S, K, x
