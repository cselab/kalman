def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply moving average to y
    window_size = 3
    y_smooth = np.convolve(y, np.ones(window_size)/window_size, mode='same')
    S_smooth = P + R
    K = P @ np.linalg.inv(S_smooth)
    x = xp + K @ y_smooth
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_smooth, K, x
