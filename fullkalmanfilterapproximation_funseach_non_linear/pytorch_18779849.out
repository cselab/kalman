def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Cholesky decomposition
    L = np.linalg.cholesky(S + 1e-12 * np.eye(S.shape[0]))
    inv_S = np.linalg.inv(L.T) @ np.linalg.inv(L)
    K = P @ inv_S
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    loss = np.sum(y ** 2) / len(y)
    return xp, P, y, S, K, x
