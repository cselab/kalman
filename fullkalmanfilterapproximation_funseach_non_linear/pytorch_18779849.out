function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    # Compute the Kalman gain
    K = np.linalg.solve(S.T, F.dot(P.T)).T
    x = xp + K.dot(y)
    # Add a small perturbation to P based on the determinant
    det_P = np.linalg.det(P + 1e-8 * np.eye(P.shape[0]))
    perturbation = np.random.randn(*P.shape) * (0.02 if det_P > 0 else 0.01)
    P += perturbation
    return xp, P, y, S, K, x
