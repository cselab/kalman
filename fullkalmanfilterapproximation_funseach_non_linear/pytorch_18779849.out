function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using Cholesky
    try:
        L = np.linalg.cholesky(S)
        L_inv = np.linalg.inv(L)
        S_inv = L_inv.T @ L_inv
    except np.linalg.LinAlgError:
        # If S is not positive definite, use pinv
        S_inv = np.linalg.pinv(S)
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
