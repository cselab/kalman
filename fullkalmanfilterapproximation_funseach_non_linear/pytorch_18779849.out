function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Perturb P using a scaled identity matrix
    scale = 1e-4 * np.mean(np.diag(S))
    P += np.eye(P.shape[0]) * scale
    return xp, P, y, S, K, x
