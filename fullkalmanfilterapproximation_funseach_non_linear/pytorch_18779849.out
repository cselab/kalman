def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    # Probabilistic update with confidence
    confidence = 0.9
    K_prob = K * confidence
    x = xp + K_prob.dot(y)
    P = np.eye(F.shape[0]) - K_prob.dot(P)
    return xp, P, y, S, K_prob, x
