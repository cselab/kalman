def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P_scaled = (P + K @ y @ y.T @ K.T) * 0.98
    x_scaled = x * 0.98
    return xp, P_scaled, y, S, K, x_scaled
