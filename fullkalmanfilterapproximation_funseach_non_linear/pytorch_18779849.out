function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Adjust F using spectral norm
    if F.size == 0:
        pass  # handle empty case, but probably not needed
    else:
        s = np.linalg.svd(F, compute_uv=False)
        spectral_norm = s[-1]
        F = F + 0.005 * spectral_norm * np.eye(F.shape[0])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(np.eye(F.shape[0]) + F @ P @ F.T) - K) @ P
    return xp, P, y, S, K, x
