function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add quantization to x
    quantize = 0.1
    x = np.round(x / quantize) * quantize
    return xp, P, y, S, K, x
