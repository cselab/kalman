def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Iterate to refine P
    for _ in range(2):
        xp = F @ x
        P = F @ P @ F.T + Q
        y = z - xp
        S = P + R
        inv_S = np.linalg.inv(S)
        K = P @ inv_S
        x = xp + K @ y
    return xp, P, y, S, K, x
