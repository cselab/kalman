def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply Tikhonov regularization to S
    alpha = 0.01
    S_reg = S + alpha * np.eye(S.shape[0])
    inv_S = np.linalg.inv(S_reg)
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S_reg, K, x
