def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    residuals = np.linalg.norm(y, axis=0)
    robust_weights = np.diag(np.clip(1 - (residuals**2)/(6*S.trace()), 0, 1))
    S_robust = S @ robust_weights
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_robust, K, x
