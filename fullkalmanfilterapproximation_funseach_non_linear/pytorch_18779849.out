def aproximate(x, F, P, Q, z, R):
    from numpy import dot, linalg, random
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    K = P.dot(linalg.inv(S))
    x = xp + K.dot(y)
    # Add a perturbation based on the Frobenius norm of P
    norm_P = np.linalg.norm(P, 'fro')
    perturbation = np.random.randn(*P.shape) * (0.02 if norm_P > 0 else 0.01)
    P += perturbation
    return xp, P, y, S, K, x
