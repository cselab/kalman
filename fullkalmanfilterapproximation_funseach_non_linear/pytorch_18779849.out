def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    # Compute SVD of P
    U, S, V = np.linalg.svd(P, full_matrices=True)
    inv_P = np.zeros_like(S)
    inv_P[S != 0] = 1 / S[S != 0]
    inv_P = np.diag(inv_P)
    inv_P = V.T @ inv_P @ U.T
    K = inv_P @ (P @ y)
    x = xp + K
    P = np.eye(F.shape[0]) - K @ P
    return xp, P, y, S, K, x
