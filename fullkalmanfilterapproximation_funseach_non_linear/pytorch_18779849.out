def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the loss
    loss = np.sum((y**2)/S)
    # Adaptive update
    adaptive_factor = np.mean(1 + y**2/S)
    Q = Q * adaptive_factor
    P = F @ P @ F.T + Q
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    return xp, S, y, P, K, x
