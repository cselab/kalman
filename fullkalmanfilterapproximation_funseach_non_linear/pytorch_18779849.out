def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute K using Cholesky decomposition for S
    L_S = np.linalg.cholesky(S)
    L_P = np.linalg.cholesky(P)
    K = L_P.T @ np.linalg.inv(L_S)
    x = xp + K @ y
    return xp, P, y, S, K, x
