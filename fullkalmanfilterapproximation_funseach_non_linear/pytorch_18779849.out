def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    scale = np.exp(-y**2 / (2 * S))
    y_scaled = y * scale
    K = P @ np.linalg.inv(S)
    x = xp + K @ y_scaled
    inv_P = np.linalg.inv(P)
    inv_P = inv_P - K @ np.linalg.inv(S) @ K.T
    P = np.linalg.inv(inv_P)
    return xp, S, y_scaled, P, K, x
