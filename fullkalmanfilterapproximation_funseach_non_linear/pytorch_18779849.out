function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Scale P by a factor to reduce uncertainty
    scale = 0.9
    P = P * scale
    # Apply a small additive noise to x and P to avoid perfect tracking
    noise_x = np.random.normal(0, 1e-3, x.shape)
    noise_P = np.random.normal(0, 1e-3, P.shape)
    x += noise_x
    P += noise_P
    # Ensure P remains positive definite
    P = np.clip(P, 1e-6, np.inf)
    return xp, P, y, S, K, x
