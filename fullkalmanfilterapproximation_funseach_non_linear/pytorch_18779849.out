def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Compute the predicted state
    xp = F @ x
    # Update the covariance matrix
    P = F @ P @ F.T + Q
    # Compute the residual
    y = z - xp
    # Compute the covariance matrix S
    S = P + R
    # Compute the Kalman gain
    K = P @ np.linalg.inv(S)
    # Update the state estimate
    x = xp + K @ y
    # Add a small identity matrix scaled by 0.01 to P for numerical stability
    P = P + 0.01 * np.eye(F.shape[0])
    return xp, P, y, S, K, x
