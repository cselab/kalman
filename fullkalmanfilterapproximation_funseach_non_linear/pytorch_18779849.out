def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the matrix inversion using QR decomposition
    Qr, Rr = np.linalg.qr(S)
    inv_S = np.linalg.solve(Rr.T, Qr.T).T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
