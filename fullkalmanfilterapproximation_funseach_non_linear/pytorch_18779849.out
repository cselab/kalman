def aproximate(x, F, P, Q, z, R):
    num_particles = 500
    particles = np.random.multivariate_normal(x, P, num_particles)
    weights = np.ones(num_particles) / num_particles
    xp = F @ x
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    return xp, P, y, S, K, x
