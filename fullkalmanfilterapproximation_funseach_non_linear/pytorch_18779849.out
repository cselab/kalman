function:
def aproximate(x, F, P, Q, z, R):
    damping = 0.99
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    # Apply inverse sigmoid to K
    inv_sigmoid = 1 / (1 + np.exp(-K))
    K = inv_sigmoid * damping
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S, K, x
