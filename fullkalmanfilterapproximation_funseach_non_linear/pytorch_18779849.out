def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    u, s, v = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[np.diag_indices(len(s))] = 1/s
    K = P @ (v.T @ (inv_S @ u.T))
    x = xp + K @ y
    P = P - K @ P
    return xp, P, y, S, K
