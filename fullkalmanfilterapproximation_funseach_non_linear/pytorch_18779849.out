function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Predict state
    xp = F @ x
    # Update covariance
    P = F @ P @ F.T + Q
    # Compute measurement residual
    y = z - xp
    # Compute S and K
    S = P + R
    K = P @ np.linalg.inv(S)
    # Update state
    x = xp + K @ y
    # Add noise to the measurement residual to prevent perfect updates
    y += np.random.normal(0, 0.01, y.shape)
    return xp, P, y, S, K, x
