def aproximate(x, F, P, Q, z, R):
    from numpy import dot, linalg
    xp = dot(F, x)
    P = dot(F, dot(P, F.T)) + Q
    y = z - xp
    S = P + R
    K = dot(P, linalg.inv(S))
    x = xp + dot(K, y)
    return xp, P, y, S, K, x
