def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Predict state
    xp = F @ x
    # Update covariance
    P = F @ P @ F.T + Q
    # Compute innovation
    y = z - xp
    # Compute S and K
    S = P + R
    K = P @ np.linalg.inv(S)
    # Update state
    x = xp + K @ y
    # Add noise to the state update
    noise = np.random.normal(0, 0.1, x.shape)
    x = x + noise
    return xp, P, y, S, K, x
