def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    L = np.linalg.cholesky(S)
    L_inv = np.triangular_solve(np.eye(S.shape[0]), L, lower=True)
    K = P @ L_inv.T
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
