def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use conjugate gradient for solving K
    K = scipy.linalg.cg(S, P @ y)[0]
    x = xp + K
    return xp, P, y, S, K, x
