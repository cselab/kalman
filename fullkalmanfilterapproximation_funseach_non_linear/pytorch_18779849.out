def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Symmetric square root
    sqrt_P = np.linalg.cholesky(P).T
    P_sqrt = sqrt_P @ sqrt_P.T
    x = x + 0.1 * np.random.randn(*x.shape) @ sqrt_P
    return xp, P, y, S, K, x
