def aproximate(x, F, P, Q, z, R):
    import numpy as np
    n = x.shape[0]
    m = z.shape[0]
    k = np.shape(F)[0]
    lmb = np.sqrt(n + k)
    sigma = np.zeros((n, 2*lmb))
    sigma[:,0] = x
    for i in range(n):
        sigma[:,i+1] = x + lmb * np.sqrt(P[i,i])
        sigma[:,i+1+n] = x - lmb * np.sqrt(P[i,i])
    sigma = F @ sigma
    y = z - sigma
    S = sigma @ sigma.T + R
    K = sigma @ np.linalg.inv(S) @ y.T
    x = x + K @ y
    P = (np.eye(n) - K @ sigma.T) @ P
    return sigma, P, y, S, K, x
