function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD
    U, S, V = np.linalg.svd(S)
    S_inv = np.zeros_like(S)
    S_inv[S != 0] = 1 / S
    S_inv = np.diag(S_inv)
    S_inv = V.T @ S_inv @ U.T
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ F) @ P
    return xp, S, y, P, K, x
