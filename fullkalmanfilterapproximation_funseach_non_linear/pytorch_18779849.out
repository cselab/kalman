def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = np.block([[P, R], [R, P]])
    inv_S = np.linalg.inv(S)
    K = P @ inv_S[:P.shape[0], :P.shape[0]]
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P) @ F.T
    return xp, P, y, S, K, x
