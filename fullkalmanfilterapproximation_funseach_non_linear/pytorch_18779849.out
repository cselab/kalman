def aproximate(x, F, P, Q, z, R):
    global global_history
    xp = F @ x
    y = z - xp
    P = F @ P @ F.T + Q
    S = P + R
    inv_S = np.linalg.inv(S + np.spacing(1))
    K = P @ inv_S
    x = xp + K @ y
    P = np.eye(F.shape[0]) - K @ P
    global_history.append((x, P))
    return xp, P, y, S, K, x
