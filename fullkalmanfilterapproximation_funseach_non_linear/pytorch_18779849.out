def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Median filter
    h = np.median(np.abs(y))
    y_filtered = np.where(np.abs(y) > 2*h, 0, y)
    S_filtered = P + R
    K = P @ np.linalg.inv(S_filtered)
    x = xp + K @ y_filtered
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_filtered, K, x
