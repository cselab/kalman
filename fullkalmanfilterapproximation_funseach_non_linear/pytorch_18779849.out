def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use Cholesky decomposition for S inverse
    try:
        L = np.linalg.cholesky(S)
        inv_S = np.linalg.inv(L).T @ np.linalg.inv(L)
    except np.linalg.LinAlgError:
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S, K, x
