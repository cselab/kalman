def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using eigenvalue decomposition
    try:
        e, v = np.linalg.eigh(S)
        inv_S = v @ np.diag(1/e) @ v.T
    except np.linalg.LinAlgError:
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
