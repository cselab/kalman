def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute K using matrix inversion with regularization
    S_reg = S + np.eye(S.shape[0]) * 1e-6
    K = P @ np.linalg.inv(S_reg)
    x = xp + K @ y
    return xp, P, y, S, K, x
