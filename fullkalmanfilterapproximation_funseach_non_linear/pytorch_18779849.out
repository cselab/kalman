def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    # Adjust Q based on current P
    Q_adj = Q + 0.1 * P
    P = F @ P @ F.T + Q_adj
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
