def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Invert S using Cholesky decomposition for numerical stability
    chol = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(chol) @ np.linalg.inv(chol).T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
