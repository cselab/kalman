def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Robust estimator with median
    med = np.median(y)
    S_med = np.median(S)
    d = np.sign(y - med) * (np.abs(y - med) < S_med)
    K_med = P @ np.linalg.inv(S_med * np.ones_like(S))
    x_med = xp + K_med @ y
    P_med = (np.eye(F.shape[0]) - K_med) @ P
    # Combine estimates
    x = 0.7 * x + 0.3 * x_med
    P = 0.7 * P + 0.3 * P_med
    return xp, S, y, P, K_med, x
