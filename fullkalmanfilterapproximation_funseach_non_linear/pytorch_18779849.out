def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Robust Kalman filter using Huber loss
    rho = np.abs(y)
    rho = np.where(rho > 1.345, 1.345, rho)
    rho = rho**2
    S_robust = P + R * rho
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_robust, y, P, K, x
