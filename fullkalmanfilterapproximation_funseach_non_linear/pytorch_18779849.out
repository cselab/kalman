function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    from numpy import linalg
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ linalg.inv(S)
    x = xp + K @ y
    # Add a scaled noise based on the determinant of P
    det_P = np.linalg.det(P)
    scale = 0.01 * np.log(det_P + 1e-10)
    noise = np.random.randn(*P.shape) * scale
    P += noise
    return xp, P, y, S, K, x
