def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S + 1e-5 * np.eye(S.shape[0]), full_matrices=False)
    inv_S = np.linalg.inv(np.diag(S))
    K = P @ V.T @ inv_S @ U.T
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
