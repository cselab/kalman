def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use matrix inversion lemma to update P
    rank_P = np.linalg.matrix_rank(P)
    if rank_P < P.shape[0]:
        P = P + 0.1 * np.eye(P.shape[0])
    return xp, P, y, S, K, x
