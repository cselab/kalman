    inv_S = np.linalg.inv(S)
    K = inv_S @ (P @ y)
    x = xp + K
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    global loss
    loss = np.linalg.norm(z - xp, 'fro')
    return xp, P, y, S, K, x
