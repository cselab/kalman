function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Randomized SVD
    n, p = S.shape
    rank = min(n, p)
    A = S + 1e-5 * np.eye(S.shape[0])
    A = A.astype(np.float64)
    Q, Sigma, V = np.linalg.svd(A, full_matrices=False)
    inv_Sigma = np.diag(1/Sigma)
    K = P @ (V.T @ inv_Sigma @ Q.T)
    x = xp + K @ y
    return xp, P, y, S, K, x
