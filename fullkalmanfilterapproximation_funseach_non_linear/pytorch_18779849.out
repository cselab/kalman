def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a small perturbation to K to adjust P
    epsilon = 1e-5
    delta_K = np.random.randn(*K.shape) * epsilon
