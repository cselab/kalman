function:
def aproximate(x, F, P, Q, z, R):
    U, S, V = np.linalg.svd(F, full_matrices=True)
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S_mat = S + np.sqrt(np.diag(S @ S.T))  # Stabilized SVD
    inv_S = np.linalg.inv(S_mat)
    K = (U @ (np.diag(inv_S) @ V.T)) @ P
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    return xp, P, y, S, K, x
