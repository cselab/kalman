function:
def aproximate(x, F, P, Q, z, R):
    from numpy import linalg
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    K = P.dot(linalg.inv(S))
    x = xp + K.dot(y)
    # Apply a small additive noise based on P's trace
    trace_P = P.trace()
    noise = np.random.randn(*P.shape) * (0.01 + 0.005 * (trace_P / 10))
    P += noise
    return xp, P, y, S, K, x
