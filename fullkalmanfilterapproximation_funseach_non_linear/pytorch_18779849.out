function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a small identity matrix scaled by the norm of K
    scale = np.linalg.norm(K)
    P = P + 1e-6 * scale * np.eye(P.shape[0])
    S = S + 1e-6 * scale * np.eye(S.shape[0])
    return xp, P, S, y, K, x
