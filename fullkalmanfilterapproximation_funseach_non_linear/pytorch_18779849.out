def aproximate(x, F, P, Q, z, R):
    # Kalman filter with state constraints
    n = x.shape[0]
    m = z.shape[0]
    S = P + R
    K = P @ np.linalg.inv(S)
    x = x + K @ (z - F @ x)
    P = (np.eye(n) - K @ F) @ P
    # Apply state constraints
    if n == 2:
        x[0] = np.clip(x[0], 0, 1)
        x[1] = np.clip(x[1], 0, 1)
    return F @ x, P, z - F @ x, S, K, x
