def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    Pp = F @ P @ F.T + Q
    y = z - xp
    S = Pp + R
    K = (Pp @ y) / (y.T @ S @ y)
    x = xp + K * y
    P = Pp - K * y[:, None] @ y[None, :]
    return xp, Pp, y, S, K, x
