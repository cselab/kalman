def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    L = np.linalg.cholesky(S + 1e-3 * np.eye(S.shape[0]))
    inv_S = np.linalg.inv(L) @ np.linalg.inv(L.T)
    K = P @ inv_S @ y
    x = xp + K
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
