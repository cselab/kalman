function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    from numpy.linalg import cholesky
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    L = cholesky(S)
    inv_S = np.zeros_like(S)
    inv_S[np.tril_indices()] = 1. / L[np.tril_indices()]
    inv_S = inv_S @ inv_S.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    return xp, P, y, S, K, x
