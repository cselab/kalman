def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    try:
        inv_S = np.linalg.cholesky(S).T @ np.linalg.cholesky(S).T
    except:
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = P - K @ S @ K.T
    return xp, P, y, S, K, x
