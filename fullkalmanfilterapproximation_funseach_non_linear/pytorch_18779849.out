def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a small scaled identity matrix based on the Frobenius norm of P
    frobenius_norm = np.linalg.norm(P, 'fro')
    scaling = 0.0001 * (frobenius_norm / (frobenius_norm + 1e-6))
    P += scaling * np.eye(P.shape[0])
    return xp, P, y, S, K, x
