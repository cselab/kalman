function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # QR decomposition
    Q, R = np.linalg.qr(S, mode='reduced')
    inv_R = np.linalg.inv(R)
    inv_S = inv_R @ Q
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return xp, P, y, S, K, x
