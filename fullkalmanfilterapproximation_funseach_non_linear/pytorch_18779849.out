def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    # Adaptive thresholding
    threshold = 0.5
    Mahalanobis = y.T.dot(inv_S).dot(y)
    if Mahalanobis < threshold:
        x = xp + K.dot(y)
        P = np.eye(F.shape[0]) - K.dot(P)
    else:
        x = x
        P = P
    return xp, P, y, S, K, x
