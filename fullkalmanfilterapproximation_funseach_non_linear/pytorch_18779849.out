def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    inv_S = numpy.linalg.inv(S)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    return xp, P, y, S, K, x
