def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a threshold to P based on the maximum value
    max_P = np.max(P)
    threshold = 0.8 * max_P
    P = np.where(P > threshold, P, threshold)
    return xp, P, y, S, K, x
