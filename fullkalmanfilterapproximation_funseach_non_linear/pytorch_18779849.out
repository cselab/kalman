def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R + 1e-8 * np.eye(len(R))
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Parallel computation using NumPy
    xp_parallel = np.zeros_like(xp)
    for i in range(len(xp)):
        xp_parallel[i] = F[i] @ x
    return xp_parallel, S, y, P, K, x
