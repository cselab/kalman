function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Update P using Riccati equation with learning rate
    learning_rate = 0.1
    P_new = P - learning_rate * (P - F @ P @ F.T - Q)
    P = P_new
    return xp, S, y, P, K, x
