def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    x = F @ x
    y = z - x
    P = F @ P @ F.T + Q
    S = P + R
    K = P @ S.I
    x = x + K @ y
    P = (numpy.eye(len(x)) - K @ P) @ P
    return x, P, y, S, K, x
