function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute determinant ratio
    det_S = np.linalg.det(S)
    det_R = np.linalg.det(R)
    # Avoid division by zero
    det_R += 1e-10
    scale = np.clip(det_S / det_R, 0.1, 10)  # clip to prevent extreme scaling
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
