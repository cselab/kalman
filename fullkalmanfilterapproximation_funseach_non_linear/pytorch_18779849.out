function:
def aproximate(x, F, P, Q, z, R):
    from numpy import dot, linalg
    xp = dot(F, x)
    P = dot(F, dot(P, F.T)) + Q
    y = z - xp
    S = P + R
    inv_S = linalg.inv(S)
    K = dot(P, inv_S)
    x = xp + dot(K, y)
    return xp, dot(P, F.T), y, S, K, x
