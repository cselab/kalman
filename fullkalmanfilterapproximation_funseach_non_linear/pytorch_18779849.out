def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    # Apply non-linear transformation to y
    y_nonlinear = np.tanh(y)
    x = xp + K @ y_nonlinear
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
