def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + np.eye(F.shape[0])
    y = z - xp
    S = P + R * 0.1
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    loss = np.sum((z - xp)**2)
    return xp, P, y, S, K, x
