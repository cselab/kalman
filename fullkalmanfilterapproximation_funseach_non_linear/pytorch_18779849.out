def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    y = z - xp
    P = F @ (P @ F.T) + Q
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    P = P + np.random.randn(*P.shape) * 0.00008
    return xp, P, y, S, K, x
