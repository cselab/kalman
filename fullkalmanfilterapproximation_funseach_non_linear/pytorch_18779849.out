def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Using SVD for more stable inversion
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S_inv, V = np.linalg.svd(S, full_matrices=True)
    S_inv = np.diag(1/S_inv)
    K = P @ V.T @ S_inv @ U.T
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
