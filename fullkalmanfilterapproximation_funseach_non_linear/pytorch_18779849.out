def aproximate(x, F, P, Q, z, R):
    x_p = F.dot(x)
    P_p = F.dot(P.dot(F.T)) + Q
    y = z - x_p
    S = P_p + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[S != 0] = 1 / S[S != 0]
    inv_S = np.diag(inv_S)
    K = P_p @ (V.T @ inv_S @ U.T)
    x = x_p + K @ y
    P = P_p - K @ K.T
    return x_p, P_p, y, S, K, x
