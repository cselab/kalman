function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P_pred = F @ P @ F.T + Q
    y = z - xp
    S = P_pred + R
    inv_S = np.linalg.inv(S)
    K = P_pred @ inv_S
    x = xp + K @ y
    # Update P using standard Kalman update
    P = (np.eye(len(x)) - K @ F) @ P_pred @ (np.eye(len(x)) - K @ F).T + K @ R @ K.T
    return xp, P, y, S, K, x
