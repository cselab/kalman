def aproximate(x, F, P, Q, z, R):
    import numpy as np
    N = z.shape[1]  # Number of measurements
    xp = F @ x
    P = F @ P @ F.T + Q
    Y = z - xp[:, np.newaxis]
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ Y
    P = (np.linalg.inv(F.T @ F) - K) @ P
    return xp, P, Y[:, 0], S, K, x
