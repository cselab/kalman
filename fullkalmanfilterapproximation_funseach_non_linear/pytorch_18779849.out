def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    trace_S = np.trace(S)
    damping = 0.1 * trace_S / len(x)
    inv_S = np.linalg.inv(S + damping * np.eye(len(x)))
    K = P @ inv_S
    x = xp + K @ y
    P = np.eye(F.shape[0]) - K @ P
    return xp, P, y, S, K, x
