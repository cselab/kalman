function:
def aproximate(x, F, P, Q, z, R):
    global history
    history.append((x.copy(), P.copy()))
    
    # Prediction step
    x_p = F @ x
    P_p = F @ (P @ F.T) + Q
    
    # Innovation
    y = z - x_p
    
    # Innovation covariance
    S = P_p + R
    
    # Compute Kalman gain using Cholesky decomposition for numerical stability
    chol_S, logdet_S = scipy.linalg.cho_factor(S, lower=True, overwrite=False)
    K = scipy.linalg.cho_solve((chol_S, logdet_S), P_p @ y)
    
    # Update step
    x = x_p + K
    P = P_p - K @ K.T
    
    return x_p, P_p, y, S, K, x
