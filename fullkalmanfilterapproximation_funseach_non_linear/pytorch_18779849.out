def aproximate(x, F, P, Q, z, R):
    import numpy as np
    import tensorflow as tf
    x = tf.Variable(x)
    F = tf.Variable(F)
    P = tf.Variable(P)
    z = tf.Variable(z)
    Q = tf.Variable(Q)
    R = tf.Variable(R)
    with tf.GradientTape() as tape:
        xp = F @ x
        y = z - xp
        S = P + R
        K = P @ tf.linalg.inv(S)
        x_new = xp + K @ y
        loss = tf.reduce_mean(tf.square(y))
    optimizer = tf.keras.optimizers.Adam()
    optimizer.minimize(loss, [x])
    x = x.numpy()
    return xp.numpy(), S.numpy(), y.numpy(), P.numpy(), K.numpy(), x
