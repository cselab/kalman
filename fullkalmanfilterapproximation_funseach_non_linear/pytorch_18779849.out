def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Apply a different scaling to P
    scale = 0.2
    P = P * scale + (1 - scale) * Q
    return xp, S, y, P, K, x
