function:
def aproximate(x, F, P, Q, z, R):
    global history, count
    # Store the current state and covariance in history
    history.append((x, P))
    count += 1
    
    # Compute the predicted state
    xp = F @ x
    # Update the covariance matrix
    P = F @ P @ F.T + Q
    # Compute the innovation
    y = z - xp
    # Compute the error covariance
    S = P + R
    # Compute the Kalman gain
    inv_S = np.linalg.inv(S)
    K = inv_S @ P
    # Update the state estimate
    x = xp + K @ y
    # Update the covariance matrix
    P = (np.eye(F.shape[0]) - inv_S @ inv_S.T) @ P
    return xp, P, y, S, K, x
