function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S + 1e-5 * np.eye(S.shape[0]))
    inv_S = np.diag(1/S)
    K = P @ (V.T @ inv_S @ U.T)
    x = xp + K @ y
    loss = np.sum((x - z)**2)
    print(f"Loss: {loss}")
    return (xp, P, y, S, K, x)
score: inf
function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    x += np.random.normal(0, 0.01, x.shape)
    x = x * (1 + np.random.uniform(-0.02, 0.02, x.shape))
    x = x + np.random.normal(0, 0.01, x.shape)
    return xp, P, y, S, K, x
