function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using conjugate gradient method
    I = np.eye(S.shape[0])
    S_inv = np.zeros_like(S)
    for i in range(S.shape[0]):
        b = I[:, i]
        r = b.copy()
        p = r.copy()
        rsold = np.dot(r, r)
        while rsold > 1e-10:
            Ap = S @ p
            alpha = rsold / (np.dot(p, Ap))
            x = b + alpha * p
            rsnew = np.dot(r, x)
            p = r - rsnew * x
            rsold = rsnew
        S_inv[:, i] = x
    K = P @ S_inv
    x = xp + K @ y
    P = (I - K) @ P
    return xp, P, y, S, K, x
