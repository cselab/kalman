def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD with thresholding
    U, S, V = np.linalg.svd(S, full_matrices=True)
    # Threshold singular values
    threshold = 0.01 * np.max(S)
    S_thresh = np.where(S > threshold, S, 0)
    inv_S = V.T @ np.linalg.inv(np.diag(S_thresh)) @ U.T
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S, K, x
