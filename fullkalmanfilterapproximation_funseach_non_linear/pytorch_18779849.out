def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P_new = (np.eye(F.shape[0]) - K) @ P
    P = 0.9 * P + 0.1 * P_new
    return xp, P, y, S, K, x
