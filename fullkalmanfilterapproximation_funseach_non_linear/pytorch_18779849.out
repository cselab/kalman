def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Adjust Q based on residual magnitude
    residual_magnitude = np.linalg.norm(y)
    Q_adjustment = np.exp(-residual_magnitude**2 / (2 * S.trace()))
    Q = Q * Q_adjustment
    return xp, P, y, S, K, x
