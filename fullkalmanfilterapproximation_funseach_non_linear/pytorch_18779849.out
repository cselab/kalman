def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Adaptive scaling based on the ratio of P and R
    ratio = np.trace(P) / np.trace(R)
    scale = 0.2 * (ratio - 1) / (ratio + 1)
    P = P * (1 - scale) + np.log(P + 1) * scale
    return xp, P, y, S, K, x
