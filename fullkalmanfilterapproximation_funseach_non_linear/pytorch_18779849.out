function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a normalization layer for stability
    x_mean = np.mean(x, axis=0, keepdims=True)
    x_std = np.std(x, axis=0, keepdims=True)
    x = (x - x_mean) / x_std
    return xp, P, y, S, K, x
