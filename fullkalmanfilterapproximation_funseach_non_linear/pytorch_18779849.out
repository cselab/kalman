def aproximate(x, F, P, Q, z, R):
    F += np.random.normal(0, 0.01, F.shape)
    xp = F @ x
    P = F @ P @ F.T + Q + 0.01 * np.random.normal(0, 0.1, P.shape)
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    loss = np.sum(y**2)
    history.append(loss)
    return xp, P, y, S, K, x
