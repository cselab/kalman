def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # State prediction
    xp = F @ x
    # Covariance prediction
    P = F @ P @ F.T + Q
    # Innovation
    y = z - xp
    # Compute S
    S = P + R
    # Compute K
    K = P @ np.linalg.inv(S)
    # Update state
    x = xp + K @ y
    # Update covariance
    P = (np.eye(F.shape[0]) - K @ S) @ P
    return xp, P, y, S, K, x
