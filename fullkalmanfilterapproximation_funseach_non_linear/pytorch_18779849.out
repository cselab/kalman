    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add noise scaled by the log of the square root of the Frobenius norm of P
    norm_P = np.linalg.norm(P, 'fro')
    sqrt_norm_P = np.sqrt(norm_P + 1e-10)
    scale = 0.01 * np.log(sqrt_norm_P + 1e-10)
    noise = np.random.randn(*P.shape) * scale
    P += noise
    history.append(P)
    return xp, P, y, S, K, x
