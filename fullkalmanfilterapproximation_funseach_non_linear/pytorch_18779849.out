def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a damping factor to P
    damping = 0.01
    P = (1 - damping) * P + damping * np.mean(P)
    return xp, P, y, S, K, x
