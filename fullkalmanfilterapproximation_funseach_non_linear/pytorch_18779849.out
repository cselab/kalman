def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute square root of S
    S_sqrt = np.linalg.cholesky(S)
    K = P @ np.linalg.inv(S_sqrt) @ S_sqrt.T
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
