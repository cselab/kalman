def aproximate(x, F, P, Q, z, R):
    damping = 0.99
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    K_damped = K * damping**np.sum(abs(y))
    x = xp + K_damped @ y
    P = (np.eye(F.shape[0]) - K_damped) @ P
    return xp, P, y, S, K_damped, x
