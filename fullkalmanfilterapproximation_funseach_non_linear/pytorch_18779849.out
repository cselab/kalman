def aproximate(x, F, P, Q, z, R):
    noise = np.random.normal(size=x.shape)
    xp = F.dot(x) + noise * 0.01
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = (np.eye(F.shape[0]) - K.dot(P)) * (1 + 0.0000001 * np.random.randn())
    return xp, P, y, S, K, x
