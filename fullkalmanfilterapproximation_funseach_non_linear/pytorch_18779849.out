def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    original_x = x.copy()
    
    # Implementation 1: Additive Gaussian Noise
    x = x + np.random.normal(0, 0.025, x.shape)
    loss = np.mean((original_x - x)**2)
    history.append(loss)
    return xp, P, y, S, K, x
