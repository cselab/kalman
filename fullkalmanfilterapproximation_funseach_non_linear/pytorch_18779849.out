def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Optimal inversion using SVD with dynamic damping
    U, S, V = np.linalg.svd(S, full_matrices=True)
    damping = np.mean(S) * 1e-3
    S_damped = S + damping
    inv_S = np.linalg.inv(S_damped)
    inv_S = U @ inv_S @ V.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
