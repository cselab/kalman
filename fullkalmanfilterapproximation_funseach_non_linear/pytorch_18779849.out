def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Hampel filter for robust estimation
    h = np.std(y) * 2
    y_filtered = np.where(np.abs(y) > h, 0, y)
    S_filtered = P + R
    K = P @ np.linalg.inv(S_filtered)
    x = xp + K @ y_filtered
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
