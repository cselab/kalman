def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Scale Q based on the determinant of S
    det_S = np.linalg.det(S)
    Q_scale = np.exp(-det_S / (2 * S.trace()))
    Q = Q * Q_scale
    return xp, P, y, S, K, x
