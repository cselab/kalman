def aproximate(x, F, P, Q, z, R):
    import numpy as np
    F = F + np.random.choice([0, 0.02], size=F.shape)
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return xp, P, y, S, K, x
