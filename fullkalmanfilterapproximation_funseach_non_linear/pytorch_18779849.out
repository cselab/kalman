def aproximate(x, F, P, Q, z, R):
    global history, global_step
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    x_scaled = x * (0.94 + 0.05 * np.sin(global_step / 10))
    P_scaled = P * (0.94 + 0.05 * np.sin(global_step / 10))
    loss = np.mean((z - x_scaled)**2)
    history.append((global_step, x_scaled, P_scaled, loss))
    global_step += 1
    return xp, P_scaled, y, S, K, x_scaled
