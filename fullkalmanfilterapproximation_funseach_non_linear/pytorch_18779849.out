def aproximate(x, F, P, Q, z, R):
    F_perturbed = F + 0.01 * np.random.binomial(1, 0.5, F.shape)
    xp = F_perturbed @ x
    P = F_perturbed @ P @ F_perturbed.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F_perturbed.shape[0]) - K) @ P
    return xp, P, y, S, K, x
