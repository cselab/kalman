function:
def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    # Regularization to make S invertible
    reg = 1e-8 * np.max(np.diag(S)) * np.eye(S.shape[0])
    S_reg = S + reg
    inv_S = np.linalg.inv(S_reg)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S_reg, K, x
