def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    inv_S = inv(S)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    history.append((x, P))
    return xp, P, y, S, K, x
