def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use square-root for numerical stability
    sqrt_P = np.linalg.cholesky(P)
    P = sqrt_P @ sqrt_P.T
    return xp, P, y, S, K, x
