def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Regularization with scaled identity
    alpha = 0.1
    S_reg = S + alpha * np.eye(S.shape[0])
    inv_S = np.linalg.inv(S_reg)
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S_reg, K, x
