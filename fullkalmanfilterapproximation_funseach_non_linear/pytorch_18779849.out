def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Robust update using Huber loss
    rho = np.abs(y) / np.sqrt(S + 1e-8)
    w = 1 - rho / (1 + rho)
    yw = y * w
    Sw = S * (1 - w)
    K = P @ np.linalg.inv(Sw)
    x = xp + K @ yw
    P = (np.eye(F.shape[0]) - K) @ P + Q * (1 - w)
    return xp, Sw, y, P, K, x
