def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Add a small identity matrix to S for numerical stability
    S = S + np.eye(S.shape[0]) * 1e-6
    return xp, P, y, S, K, x
