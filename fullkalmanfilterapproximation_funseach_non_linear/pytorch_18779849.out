def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Implement a forgetting factor approach
    P = (P - Q) @ F.T + 0.99 * F @ P
    return xp, P, y, S, K, x
