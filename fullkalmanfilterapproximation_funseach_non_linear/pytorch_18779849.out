def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R + 0.01 * np.trace(R) * np.eye(P.shape[0])
    inv_S = np.linalg.inv(S)
