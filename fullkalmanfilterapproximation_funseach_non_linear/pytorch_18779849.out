def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    K = P.dot(np.linalg.solve(S, np.eye(S.shape[0])))
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S, K, x
