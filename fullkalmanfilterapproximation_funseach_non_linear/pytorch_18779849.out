def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse of S using SVD
    U, S_diag, V = np.linalg.svd(S, full_matrices=True)
    inv_S = np.zeros_like(S)
    inv_S = V.T @ np.linalg.inv(np.diag(S_diag)) @ U.T
    K = P @ inv_S
    x = xp + K @ y
    P = np.eye(F.shape[0]) - K @ P
    return xp, P, y, S, K, x
