def aproximate(x, F, P, Q, z, R):
    # Implementation 6: Efficient Matrix Operations
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P) @ F.T
    return xp, P, y, S, K, x
