def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply total variation denoising to y
    lambda_tv = 0.1
    y_tv = np.zeros_like(y)
    for i in range(y.shape[0]):
        y_tv[i] = y[i] + lambda_tv * np.abs(y[i] - y[i-1])
    S_tv = P + R
    K = P @ np.linalg.inv(S_tv)
    x = xp + K @ y_tv
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_tv, K, x
