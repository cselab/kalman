def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    I = np.eye(S.shape[0])
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    eps = 1e-3
    loss_prev = np.mean((z - xp)**2)
    for _ in range(10):
        dK = (y @ y.T - y @ S.T @ K.T - K @ y @ y.T + K @ S @ K.T) @ P
        dK /= (1 + np.linalg.norm(dK))
        K += eps * dK
    x = xp + K @ y
    P = (I - K) @ P
    loss = np.mean((z - xp)**2)
    return xp, P, y, S, K, x
