def aproximate(x, F, P, Q, z, R):
    x_p = F @ x
    P_p = F @ P @ F.T + Q
    y = z - x_p
    S = P_p + R
    L = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(L.T) @ np.linalg.inv(L)
    K = P_p @ inv_S
    x = x_p + K @ y
    P = P_p - K @ K.T
    return x_p, P_p, y, S, K, x
