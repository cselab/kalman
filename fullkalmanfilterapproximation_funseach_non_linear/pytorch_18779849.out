def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Update P using the residual and K
    P = P - K @ y[:, None] * (K @ y)[None, :]
    return xp, P, y, S, K, x
