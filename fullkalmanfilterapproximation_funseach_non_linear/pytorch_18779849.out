def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    sqrt_P = np.linalg.cholesky(P)
    sqrt_P = F @ sqrt_P
    P = (sqrt_P.T @ sqrt_P) + Q
    y = z - xp
    S = P + R
    sqrt_S = np.linalg.cholesky(S)
    inv_sqrt_S = np.linalg.inv(sqrt_S)
    K = (sqrt_P @ inv_sqrt_S.T) @ inv_sqrt_S
    x = xp + K @ y
    sqrt_P_new = sqrt_P - K @ sqrt_S
    P = sqrt_P_new.T @ sqrt_P_new
    return xp, P, y, S, K, x
