def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use iterative inversion for S
    inv_S = np.zeros_like(S)
    for i in range(S.shape[0]):
        inv_S[i, i] = 1 / S[i, i]
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
