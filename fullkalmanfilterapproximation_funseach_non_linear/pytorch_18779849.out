def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Using symmetric square-root-free update to compute S and K
    chol_P, _ = np.linalg.cholesky_factorization(P, pivot=True)
    chol_S, _ = np.linalg.cholesky_factorization(S, pivot=True)
    inv_S = np.linalg.inv(chol_S @ chol_S.T)
    K = (chol_P @ (chol_P.T @ (inv_S @ y))) / (y.T @ inv_S @ y)
    x = xp + K @ y
    P = P - K @ (S @ K.T)
    return xp, P, y, S, K, x
