def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use SVD for more stable inversion
    U, S, V = np.linalg.svd(S)
    S_inv = np.zeros_like(S)
    S_inv[S > 1e-10] = 1 / S[S > 1e-10]
    S_inv = V.T @ np.diag(S_inv) @ U.T
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
