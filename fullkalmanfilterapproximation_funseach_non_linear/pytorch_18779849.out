def aproximate(x, F, P, Q, z, R):
    import numpy as np
    from numpy.linalg import cholesky
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    L = cholesky(S)
    inv_S = np.triangular_solve(np.eye(L.shape[0]), L, lower=True)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
