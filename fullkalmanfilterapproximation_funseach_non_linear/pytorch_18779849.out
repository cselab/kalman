def aproximate(x, F, P, Q, z, R):
    if not np.allclose(F.dot(F.T), F.dot(F.T).T):
        raise ValueError("F must be a valid state transition matrix.")
    xp = F.dot(x)
    y = z - xp
    P = F.dot(P.dot(F.T)) + Q
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = (np.eye(F.shape[0]) - K.dot(P))
    x = x.squeeze()
    P = P.squeeze()
    return xp, P, y, S, K, x
