def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use matrix inversion lemma for efficiency
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
