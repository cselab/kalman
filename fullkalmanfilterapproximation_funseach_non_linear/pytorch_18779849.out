def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    damping = 0.01 * np.mean(np.diag(S)) * np.eye(S.shape[0])
    S_damped = S + damping
    inv_S = np.linalg.inv(S_damped)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S_damped, K, x
