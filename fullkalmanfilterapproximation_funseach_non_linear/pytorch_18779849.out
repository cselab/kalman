def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Eigenvalue decomposition
    D, V = np.linalg.eigh(S)
    inv_D = np.diag(1/D)
    inv_S = V @ inv_D @ V.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return xp, P, y, S, K, x
