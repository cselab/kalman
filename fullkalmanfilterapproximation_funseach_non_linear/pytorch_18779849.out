def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Iterative method to compute K
    max_iter = 10
    for _ in range(max_iter):
        inv_S = np.linalg.inv(S)
        K = P @ inv_S
        # Update S and P
        S = P + R + K.T @ y
        P = (np.eye(F.shape[0]) - K) @ P
    x = xp + K @ y
    return xp, P, y, S, K, x
