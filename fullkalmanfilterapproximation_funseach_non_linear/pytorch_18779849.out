def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Online learning parameters
    learning_rate = 0.1
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Adapt F and P
    F += learning_rate * (x - xp)
    P += learning_rate * (P - F @ P @ F.T)
    return xp, P, y, S, K, x
