def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using Sherman-Morrison formula
    inv_P = np.linalg.inv(P)
    u = P @ y
    v = R @ inv_P
    inv_S = inv_P - (inv_P @ u @ v @ inv_P) / (1 + v @ inv_P @ u)
    K = inv_P @ u @ (1 + v @ inv_P @ u)
    x = xp + K
    P = (np.eye(F.shape[0]) - K @ F.T) @ P
    return xp, P, y, S, K, x
