function:
def aproximate(x, F, P, Q, z, R):
    damping = 0.99
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    K_damped = K * damping
    x = xp + K_damped.dot(y)
    P = (np.eye(F.shape[0]) - K_damped.dot(P)).dot(F.T)
    return xp, P, y, S, K_damped, x
