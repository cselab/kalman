def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ S) @ P
    # Update F using gradient descent for online learning
    dF = (x - xp) @ P.T
    F = F + 0.001 * dF
    return xp, P, y, S, K, x
