def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P chol = np.linalg.cholesky(P)
    P_new chol = np.linalg.cholesky(F @ P @ F.T + Q)
    y = z - xp
    S chol = np.linalg.cholesky(P_new + R)
    inv_S chol = np.linalg.inv(S chol)
    K = P_new @ inv_S chol.T
    x = xp + K @ y
    P chol = P_new chol - K @ S chol.T @ K.T
    P = P chol @ P chol.T
    history.append(x)
    return xp, P, y, S, K, x
