def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Add a small noise to S to prevent singularities
    eps = 1e-8 * np.ones_like(S)
    S = S + eps
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    return xp, P, y, S, K, x
