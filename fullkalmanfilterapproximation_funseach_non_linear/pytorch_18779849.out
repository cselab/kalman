def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    S = S + 1e-4 * np.eye(S.shape[0])
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    x = x.clip(-10, 10)
    return xp, P, y, S, K, x
