def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    from scipy.linalg import sqrtm
    n = x.shape[0]
    sqrt_P = sqrtm(P)
    sqrt_Q = sqrtm(Q)
    x = F @ x + sqrt_P @ np.random.randn(n)
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
