function:
def aproximate(x, F, P, Q, z, R):
    # Ensemble initialization
    n_ens = 10
    x_ens = x[:, np.newaxis] + 0.1 * np.random.randn(n_ens)
    xp_ens = F @ x_ens
    y_ens = z - xp_ens
    S_ens = np.zeros((F.shape[0], F.shape[0]))
    for i in range(n_ens):
        S_ens += (xp_ens[:, i] - np.mean(xp_ens, axis=1))[:, np.newaxis] @ (xp_ens[:, i] - np.mean(xp_ens, axis=1))[:, np.newaxis].T
    S_ens += R
    inv_S_ens = np.linalg.inv(S_ens + 1e-14 * np.eye(S_ens.shape[0]))
    K_ens = (F @ P @ F.T + Q) @ inv_S_ens
    x = np.mean(xp_ens + K_ens @ y_ens, axis=1)
    return xp, P, y, S, K, x
