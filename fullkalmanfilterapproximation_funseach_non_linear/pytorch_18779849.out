function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F.dot(x)
    y = z - xp
    S = F.dot(P).dot(F.T) + Q + R
    K = F.dot(P).dot(np.linalg.inv(S - F.dot(P).dot(F.T)))
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(F.dot(P))
    return xp, P, y, S, K, x
