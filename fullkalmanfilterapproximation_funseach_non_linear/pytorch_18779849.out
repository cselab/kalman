function:
def aproximate(x, F, P, Q, z, R):
    F += np.random.normal(0, 0.01, F.shape)
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    # Compute K using least squares
    K, _, _, _ = np.linalg.lstsq(inv_S @ y, inv_S @ P, rcond=None)
    x = xp + K
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    loss = np.sum(y**2)
    history.append(loss)
    return xp, P, y, S, K, x
