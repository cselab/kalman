function:
def aproximate(x, F, P, Q, z, R):
    global global_history
    global_history.append(('aproximate', x, F, P, Q, z, R))
    
    # Perform matrix multiplication for x prediction
    x_pred = F @ x
    # Calculate the predicted covariance matrix
    P_pred = F @ P @ F.T + Q
    # Compute the innovation
    y = z - x_pred
    # Calculate the covariance matrix of the innovation
    S = P_pred + R
    # Compute the Kalman gain
    inv_S = np.linalg.inv(S)
    K = P_pred @ inv_S @ y
    # Update the state estimate
    x = x_pred + K
    # Update the covariance matrix
    P = P_pred - K @ K.T
    
    # Return the computed values
    return x_pred, P_pred, y, S, K, x
