def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    K = P.dot(np.linalg.inv(S))
    x = xp + K.dot(y)
    # Add a scaled perturbation based on the trace of P
    trace_P = np.trace(P)
    perturbation = np.random.randn(*P.shape) * (0.02 if trace_P > 5 else 0.01)
    P += perturbation
    return xp, P, y, S, K, x
