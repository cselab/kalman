function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    y = z - xp
    P = F @ P @ F.T + Q
    S = P + R
    # Compute inverse of S using SVD
    U, s, Vt = np.linalg.svd(S, full_matrices=False)
    S_inv = np.zeros_like(S)
    for i in range(len(s)):
        S_inv[i, i] = 1. / s[i]
    K = P @ (Vt.T @ S_inv @ U.T)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K.T @ P)
    return xp, P, y, S, K, x
