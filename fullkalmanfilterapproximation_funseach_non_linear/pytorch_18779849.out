def aproximate(x, F, P, Q, z, R):
    S = P + R
    u, s, v = np.linalg.svd(S)
    s_inv = np.diag(1/s + 1e-10)
    S_inv = v.T @ s_inv @ u.T
    K = P @ S_inv
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    loss = np.mean((z - xp)**2)
    return xp, P, y, S, K, x
