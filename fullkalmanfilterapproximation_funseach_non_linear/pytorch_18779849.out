def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # State prediction
    xp = F @ x
    # Update state covariance with dynamic noise
    P_new = F @ P @ F.T + Q
    # Measurement residual
    y = z - xp
    # Compute S
    S = P_new + R
    # Calculate Kalman gain
    K = P_new @ np.linalg.inv(S)
    # Update state estimate
    x = xp + K @ y
    # Update covariance
    P = (np.eye(F.shape[0]) - K) @ P_new
    return xp, P, y, S, K, x
