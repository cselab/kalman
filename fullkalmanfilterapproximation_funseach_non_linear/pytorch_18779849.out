def aproximate(x, F, P, Q, z, R):
    x_next = F @ x
    P_new = F @ P @ F.T + Q
    innovation = z - x_next
    S = P_new + R
    inv_S = np.linalg.inv(S)
    K = P_new @ inv_S
    x = x_next + K @ innovation
    P = (np.eye(F.shape[0]) - K @ P_new)
    x = x + np.random.exponential(0.1, x.shape)
    return x_next, P_new, innovation, S, K, x
