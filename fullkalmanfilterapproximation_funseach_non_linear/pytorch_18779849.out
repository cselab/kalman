def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Apply adaptive thresholding based on S
    threshold = np.mean(S)
    y_filtered = np.where(np.abs(y) > threshold, y, 0)
    S_filtered = P + R
    K = P @ np.linalg.inv(S_filtered)
    x = xp + K @ y_filtered
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_filtered, K, x
