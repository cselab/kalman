def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Apply Huber loss to y
    rho = 1
    huber_y = np.where(np.abs(y) > rho, rho * np.sign(y), y**2)
    P = F @ (P - Q) @ F.T + Q
    return xp, P, y, S, K, x
