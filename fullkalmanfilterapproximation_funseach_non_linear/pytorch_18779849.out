function:
def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    eps = 1e-9
    inv_S = np.zeros_like(S)
    inv_S[S > eps] = 1 / S[S > eps]
    inv_S_full = np.zeros_like(S)
    inv_S_full[U.shape[0]:] = inv_S
    inv_S_matrix = V.T.dot(inv_S_full * U.T)
    K = P.dot(inv_S_matrix)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S, K, x
