function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Using Cholesky decomposition for more stable inversion
    try:
        L = np.linalg.cholesky(S)
        inv_S = np.linalg.inv(L) @ np.linalg.inv(L.T)
    except np.linalg.LinAlgError:
        inv_S = np.linalg.inv(S + np.eye(S.shape[0]) * 1e-9)
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S, K, x
