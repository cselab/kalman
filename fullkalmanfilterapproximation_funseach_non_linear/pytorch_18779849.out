def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ numpy.linalg.inv(S)
    x = xp + K @ y
    # Add a check for singular matrices
    try:
        np.linalg.inv(S)
    except np.linalg.LinAlgError:
        pass
    return xp, P, y, S, K, x
