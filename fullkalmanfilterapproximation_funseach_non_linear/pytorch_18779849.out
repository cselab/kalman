function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Use Sherman-Morrison formula to update P
    u = K @ y
    v = y
    a = 1 + v @ K @ P
    inv_P = np.linalg.inv(P) + (K @ (np.outer(u, v) / a)) @ K.T
    P = np.linalg.inv(inv_P)
    return xp, S, y, P, K, x
