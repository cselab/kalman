function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    # Apply threshold to inverse matrix
    inv_S[inv_S < 1e-6] = 1e-6
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(np.eye(F.shape[0]) + F @ P @ F.T) - K) @ P
    loss = y.T @ inv_S @ y
    history.append(loss)
    return xp, P, y, S, K, x
