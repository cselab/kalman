def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use the Woodbury matrix identity to compute the inverse of S
    inv_S = np.linalg.inv(R) - (R @ np.linalg.inv(S0) @ R) where S0 = P
    # Compute K
    K = P @ inv_S @ y
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
