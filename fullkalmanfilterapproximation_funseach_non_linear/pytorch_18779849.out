function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Compute state estimate
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Online update for all parameters with momentum
    alpha = 0.1
    beta = 0.9
    dF = (x - xp) @ P.T
    F += alpha * (beta * dF + (1 - beta) * dF)
    dQ = (x - xp) @ (x - xp).T
    Q = alpha * dQ + (1 - alpha) * Q
    R = alpha * y.T @ y + (1 - alpha) * R
    return xp, P, y, S, K, x
