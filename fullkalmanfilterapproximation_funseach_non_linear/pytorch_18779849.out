def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Threshold the diagonal elements of P
    P_diag = np.diag(P)
    P_diag = np.where(P_diag < 1e-6, 1e-6, P_diag)
    P = np.diag(P_diag) + P - np.diag(P_diag)
    return xp, P, y, S, K, x
