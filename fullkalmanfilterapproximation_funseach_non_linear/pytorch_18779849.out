def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Using RMSprop for P update
    beta = 0.99
    epsilon = 1e-8
    P = F @ P @ F.T + Q
    P = P - beta * (P - F @ P @ F.T - Q) / (np.sqrt(np.mean((P - F @ P @ F.T - Q)**2)) + epsilon)
    return xp, S, y, P, K, x
