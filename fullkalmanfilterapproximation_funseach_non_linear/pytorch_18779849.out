function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S + 1e-5 * np.eye(S.shape[0]))
    x = xp + K @ y
    x = x.flatten()
    loss = np.sum((x - z)**2)
    print(f"Loss: {loss}")
    return (xp, P, y, S, K, x)
