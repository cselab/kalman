def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # U-D decomposition
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Update P using U-D
    U, D = np.linalg.eigh(P)
    P_new = F @ P @ F.T + Q - K @ R
    return xp, P_new, y, S, K, x
