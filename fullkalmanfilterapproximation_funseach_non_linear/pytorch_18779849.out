function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Using SVD for more stable inversion
    U, S_diag, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[np.diag_indices(S.shape[0])] = 1/S_diag
    inv_S = V.T @ inv_S @ U.T
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S, K, x
