def aproximate(x, F, P, Q, z, R):
    import numpy as np
    from numpy.linalg import svd
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = svd(S)
    inv_S = np.zeros_like(S)
    inv_S[np.diag_indices(S.shape[0])] = 1. / S
    inv_S = V.T @ inv_S @ U.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    return xp, P, y, S, K, x
