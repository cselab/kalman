def aproximate(x, F, P, Q, z, R):
    global history
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S + 1e-4 * np.eye(S.shape[0]))
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    loss = np.sum(y ** 2) / len(y)
    history.append((x.copy(), P.copy(), y.copy(), S.copy(), K.copy()))
    return xp, P, y, S, K, x
