def aproximate(x, F, P, Q, z, R):
    import numpy as np
    sqrt_P = np.linalg.cholesky(P)
    sqrt_Pn = F @ sqrt_P
    Pn = sqrt_Pn @ sqrt_Pn.T + Q
    sqrt_Pn, _ = np.linalg.ordsvd(sqrt_Pn, 0)
