def aproximate(x, F, P, Q, z, R):
    xp = F.dot(x)
    y = z - xp
    P = F.dot(P.dot(F.T)) + Q
    S = P + R
    inv_S = np.linalg.inv(S) if np.allclose(S, S.T) and np.all(S.diagonal() > 0) else np.linalg.pinv(S)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    x = x.squeeze()
    P = P.squeeze()
    return xp, P, y, S, K, x
