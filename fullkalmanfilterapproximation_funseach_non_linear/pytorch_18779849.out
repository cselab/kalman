def aproximate(x, F, P, Q, z, R):
    import numpy as np
    epsilon = 1e-6
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    diag_S = np.diag(S) + epsilon
    S_inv = np.diag(1/diag_S) @ S.T @ 1/diag_S
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
