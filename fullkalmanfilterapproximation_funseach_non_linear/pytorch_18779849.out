def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R + 1e-8 * np.eye(F.shape[0])  # Regularization
    inv_S = np.linalg.inv(S)
    K = inv_S @ (P @ y)
    x = xp + K
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    global loss
    loss = np.linalg.norm(z - xp, 'fro')
    return xp, P, y, S, K, x
