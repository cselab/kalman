    y = z - Fx
    P = F @ P @ F.T + Q
    S = P + R
    inv_S = LA.inv(S)
    K = P @ inv_S @ y
    x = Fx + K
    P = P - K @ K.T
    history.append((x.copy(), P.copy()))
    return Fx, P, y, S, K, x
