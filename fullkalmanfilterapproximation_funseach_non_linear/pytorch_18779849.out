def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    u, s, v = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[np.diag_indices(len(s))] = 1/s
    K = P @ (v.T @ (inv_S @ u.T))
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    return xp, P, y, S, K, x
