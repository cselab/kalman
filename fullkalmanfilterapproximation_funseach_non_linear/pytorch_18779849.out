def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Cholesky decomposition for efficient inversion
    L = np.linalg.cholesky(S)
    L_inv = np.linalg.inv(L)
    S_inv = L_inv.T @ L_inv
    K = P @ S_inv
    x = xp + K @ y
    return xp, P, y, S, K, x
