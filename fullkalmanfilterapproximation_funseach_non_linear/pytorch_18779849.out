def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Add a small value to the diagonal to avoid singular matrix
    S += 1e-8 * np.eye(S.shape[0])
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(np.eye(F.shape[0]) + F @ P @ F.T) - K) @ P
    loss = y.T @ inv_S @ y
    history.append(loss)
    return xp, P, y, S, K, x
