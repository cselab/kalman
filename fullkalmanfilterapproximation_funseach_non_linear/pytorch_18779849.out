function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    try:
        chol_S = np.linalg.cholesky(S)
        inv_S = np.linalg.inv(chol_S) @ np.linalg.inv(chol_S.T)
    except np.linalg.LinAlgError:
        inv_S = np.linalg.inv(S + 1e-6 * np.eye(S.shape[0]))
    K = P @ inv_S
    x = xp + K @ y
    P = (F @ P @ F.T + Q) - K @ y @ K.T
    return xp, P, y, S, K, x
