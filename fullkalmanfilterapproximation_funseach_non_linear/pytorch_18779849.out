def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # SVD based update
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute SVD of P and S
    U, S, V = np.linalg.svd(P)
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Update P using SVD
    P = F @ P @ F.T + Q - K @ R
    return xp, P, y, S, K, x
