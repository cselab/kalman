function:
def aproximate(x, F, P, Q, z, R):
    import numpy as newnp
    xp = newnp.dot(F, x)
    P = newnp.dot(F, newnp.dot(P, F.T)) + Q
    y = z - xp
    S = P + R
    K = newnp.dot(P, newnp.linalg.inv(S))
    x = xp + newnp.dot(K, y)
    # Add a small random noise to P to prevent numerical issues
    noise = newnp.random.randn(*x.shape) * 0.001
    P = P + newnp.dot(noise, noise.T)
    return xp, P, y, S, K, x
