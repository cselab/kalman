def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P_p = F @ P @ F.T + Q
    y = z - xp
    S = P_p + R
    K = np.linalg.solve(S, P_p @ y)
    x = xp + K
    P = P_p - K @ K.T
    loss = np.mean(np.square(z - xp))
    history.append(loss)
    global loss
    loss = loss
    return xp, P_p, y, S, K, x
