def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    L = np.linalg.cholesky(S + 1e-15 * np.eye(S.shape[0]))
    inv_S = np.linalg.inv(L) @ np.linalg.inv(L).T
    K = P @ inv_S
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
