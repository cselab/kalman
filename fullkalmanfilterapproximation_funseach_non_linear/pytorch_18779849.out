def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('Example 7', x))
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S + 1e-6 * np.eye(S.shape[0]))
    K = P @ inv_S
    x = xp + K @ y
    x = x * (1 + np.random.uniform(-0.01, 0.01, x.shape))
    return xp, P, y, S, K, x
