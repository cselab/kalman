def aproximate(x, F, P, Q, z, R):
    # Implementation 4: Adjusted Kalman Gain
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S + 1e-8 * np.eye(S.shape[0]))
    K = inv_S @ (P + 1e-8 * np.eye(P.shape[0])).T
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S.T) @ P
    history.append(x)
    return xp, P, y, S, K, x
