def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    residuals = np.abs(y)
    weights = np.where(residuals < 1.345, 1 - (residuals**2)/(2*(1.345**2)), np.exp(-residuals**2/2))
    S_weighted = S * weights[:, None, None]
    K = P @ np.linalg.inv(S_weighted)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
