function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S + 1e-5 * np.eye(S.shape[0]))
    x = xp + K @ y
    x = x.reshape(-1)
    loss = np.sum((x - z)**2)
    print(f"Loss: {loss}")
    return (xp, P, y, S, K, x)
score: inf
function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    x = x + np.random.exponential(0.1, x.shape)
    return xp, P, y, S, K, x
