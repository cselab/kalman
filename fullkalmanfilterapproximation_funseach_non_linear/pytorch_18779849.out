def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using sparse matrix inversion
    from scipy.sparse import csc_matrix
    S_sparse = csc_matrix(S)
    S_inv = np.array(S_sparse.inv().toarray())
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
