def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # M-estimator with Tukey biweight
    rho = (y**2) / (S + 1e-8)
    rho = np.where(rho < 4, rho, 4)
    d = 2 * y / (S + 1e-8)
    Q = Q * np.exp(-rho)
    P = F @ (P - Q) @ F.T + Q
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
