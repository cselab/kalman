function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    global history
    history.append(x)
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    try:
        S_inv = np.linalg.inv(S)
    except np.linalg.LinAlgError:
        S = S + np.diag(1e-10)
        S_inv = np.linalg.inv(S)
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
