def aproximate(x, F, P, Q, z, R):
    x_p = F @ x
    P_p = F @ P @ F.T + Q
    y = z - x_p
    S = P_p + R
    # Assuming S is sparse, use sparse inversion
    inv_S = np.linalg.inv(S)
    K = P_p @ inv_S @ y
    x = x_p + K
    P = P_p - K @ K.T
    return x_p, P_p, y, S, K, x
