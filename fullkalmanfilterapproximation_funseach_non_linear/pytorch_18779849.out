def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = inv_S @ P.T
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - inv_S @ P) @ P
    return xp, P, y, S, K, x
