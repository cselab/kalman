def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x_next = F @ x
    new_P = F @ P @ F.T + Q
    innovation = z - x_next
    measurement_cov = new_P + R
    K = new_P @ np.linalg.inv(measurement_cov)
    x = x_next + K @ innovation
    return x_next, new_P, innovation, measurement_cov, K, x
