def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using randomized SVD
    from sklearn.utils import linear_map
    U, S_diag, Vt = linear_map(lambda x: np.linalg.solve(S, x))(np.eye(S.shape[0]))
    S_inv = Vt.T @ (np.diag(1/S_diag)) @ U.T
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
