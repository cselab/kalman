def aproximate(x, F, P, Q, z, R):
    x_prev = F @ x
    P = F @ P @ F.T + Q
    y = z - x_prev
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = x_prev + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return x_prev, P, y, S, K, x
