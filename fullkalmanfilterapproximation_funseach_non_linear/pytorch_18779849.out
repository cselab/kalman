def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('aproximate', x, F, P, Q, z, R))
    xp = F @ x
    P_new = F @ P @ F.T + Q
    y = z - xp
    S = P_new + R
    try:
        inv_S = np.linalg.inv(S)
    except np.linalg.LinAlgError:
        inv_S = np.linalg.pinv(S)
    K = P_new @ inv_S
    x = xp + K @ y
    P = np.eye(F.shape[0]) - K @ P_new
    return xp, P, y, S, K, x
