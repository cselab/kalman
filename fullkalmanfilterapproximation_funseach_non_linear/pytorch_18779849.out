def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    det = np.linalg.det(S)
    if abs(det) < 1e-10:
        S += np.eye(S.shape[0]) * 1e-10
    S_inv = np.linalg.inv(S)
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
