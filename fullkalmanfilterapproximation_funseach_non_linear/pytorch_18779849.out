function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    x = x * (1 + 0.00001 * (np.random.rand(*x.shape) - 0.5))
    P = P * (1 + 0.00001 * (np.random.rand(*P.shape) - 0.5))
    return xp, P, y, S, K, x
