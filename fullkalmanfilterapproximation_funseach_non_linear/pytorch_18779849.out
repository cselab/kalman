def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Computing the inverse using the matrix determinant lemma
    # det(S) = det(P + R) = det(R + P)
    # If R is low-rank, this can be useful, but assuming R is full rank
    # Proceeding with standard inversion
    S_inv = np.linalg.inv(S)
    K = P @ S_inv
    x = xp + K @ y
    return xp, P, y, S, K, x
