def aproximate(x, F, P, Q, z, R):
    import numpy as np
    N = 1000
    particles = np.random.multivariate_normal(x, P, N)
    for _ in range(10):
        weights = np.exp(-0.5 * np.sum((z - F @ particles.T) ** 2 / R, axis=0))
        weights /= np.sum(weights)
        particles = np.mean(particles * weights, axis=1)
    xp = F @ particles
    P = np.cov(particles)
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
