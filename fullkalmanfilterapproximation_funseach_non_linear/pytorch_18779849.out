def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a rank-aware update to P
    rank_P = np.linalg.matrix_rank(P)
    if rank_P < P.shape[0]:
        P = np.diag(np.diag(P) * (1 + 0.01))
    return xp, P, y, S, K, x
