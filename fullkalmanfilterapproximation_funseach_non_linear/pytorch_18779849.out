def aproximate(x, F, P, Q, z, R):
    from numpy import linalg, random
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    K = P @ linalg.inv(S)
    x = xp + K @ y
    # Add a perturbation based on the trace of P
    tr_P = np.trace(P)
    perturbation = random.randn(*P.shape) * (0.03 if tr_P > 0 else 0.02)
    P += perturbation
    return xp, P, y, S, K, x
