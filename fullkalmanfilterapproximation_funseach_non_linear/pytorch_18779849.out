def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    x_p = F @ x
    P_p = F @ P @ F.T + Q
    y = z - x_p
    S = P_p + R
    K = (P_p @ numpy.linalg.inv(S)) @ y
    x = x_p + K
    P = P_p - (P_p @ (numpy.linalg.inv(S) @ P_p.T))
    return x_p, P_p, y, S, K, x
