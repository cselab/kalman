def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    residual_norm = np.linalg.norm(y, axis=0)
    if np.max(residual_norm) > 3:
        P = P * 0.9
    return xp, P, y, S, K, x
