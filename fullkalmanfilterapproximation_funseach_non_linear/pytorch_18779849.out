function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a scaled identity matrix to P based on the maximum eigenvalue of S
    max_eig_S = np.linalg.eigvalsh(S).max()
    scale = 0.01 * max_eig_S
    P = (np.eye(F.shape[0]) - K) @ P + scale * np.eye(F.shape[0])
    history.append(P)
    return xp, S, y, P, K, x
