def aproximate(x, F, P, Q, z, R):
    xp = F(x)
    J = F.jacobian(x)
    P = J @ P @ J.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ J) @ P
    return xp, P, y, S, K, x
