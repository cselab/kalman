def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use a Mahalanobis distance-based loss
    dist = np.sqrt(y @ S_inv @ y.T)
    loss = dist**2 / (dist + 1)
    d = 2 * y / (S + 1e-8)
    # Scale the loss for optimization
    scaled_loss = np.sum(loss)
    # Compute the Kalman gain with loss scaling
    K = P @ np.linalg.inv(S + scaled_loss * np.eye(S.shape[0]))
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
