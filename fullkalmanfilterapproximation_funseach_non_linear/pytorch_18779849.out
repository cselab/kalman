def aproximate(x, F, P, Q, z, R):
    import numpy as np
    c=1.0
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    mahalanobis = y.T @ np.linalg.inv(S) @ y
    scale = 1 + c * np.clip(mahalanobis - 1, 0, None)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
