def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Update P using a moving average approach
    alpha = 0.1
    P = (1 - alpha) * P + alpha * (F @ P @ F.T + Q)
    return xp, P, y, S, K, x
