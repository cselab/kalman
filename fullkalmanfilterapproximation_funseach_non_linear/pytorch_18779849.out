def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Probabilistic Filter with Mahalanobis Distance
    md = np.linalg.norm(y, axis=0) / np.sqrt(S.trace())
    weights = np.exp(-md**2 / 2)
    Q_wei = Q * weights
    P = F @ (P - Q_wei) @ F.T + Q_wei
    S_wei = P + R
    K = P @ np.linalg.inv(S_wei)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_wei, y, P, K, x
