function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use SVD for more stable matrix inversion
    U, S, V = np.linalg.svd(S, full_matrices=True)
    inv_S = np.diag(1/S)
    S_inv = V.T @ inv_S @ U.T
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ F) @ P
    # Add a scaled identity matrix to P for numerical stability
    P = P + 0.01 * np.eye(F.shape[1])
    return xp, P, y, S, K, x
