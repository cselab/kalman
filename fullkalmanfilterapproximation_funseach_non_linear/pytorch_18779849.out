def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a random perturbation scaled by the square root of the trace of P
    sqrt_trace_P = np.sqrt(np.trace(P))
    perturbation_P = np.random.randn(*P.shape) * sqrt_trace_P * 1e-4
    P += perturbation_P
    return xp, P, y, S, K, x
