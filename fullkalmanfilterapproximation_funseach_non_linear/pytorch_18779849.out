def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('init', x, F, P, Q, z, R))
    
    # Implementation 4: Cholesky Decomposition for Inversion
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    try:
        inv_S = np.linalg.cholesky(S).T @ np.linalg.cholesky(S).T
    except:
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(('cholesky', xp, P, y, S, K, x))
    return xp, P, y, S, K, x
