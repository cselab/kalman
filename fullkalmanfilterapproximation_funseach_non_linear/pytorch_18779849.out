def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Store the current state for future reference
    history.append(x)
    # Apply a transformation using the history
    P = P * np.mean(np.exp(history))
    return xp, S, y, P, K, x
