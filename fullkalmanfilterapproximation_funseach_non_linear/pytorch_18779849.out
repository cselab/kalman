def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using block matrix inversion
    block_size = 2
    S_inv = np.zeros_like(S)
    for i in range(0, S.shape[0], block_size):
        block = S[i:i+block_size, i:i+block_size]
        inv_block = np.linalg.inv(block)
        S_inv[i:i+block_size, i:i+block_size] = inv_block
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
