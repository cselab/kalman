def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a damping factor to P based on the trace
    trace_P = np.trace(P)
    damping = 0.01 if trace_P > 5 else 0.02
    P = P + damping * np.eye(P.shape[0])
    return xp, P, y, S, K, x
