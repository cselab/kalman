function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    weights = np.exp(-np.linalg.norm(y, axis=0)**2 / (2*S.trace()))
    Q_robust = Q * weights
    P = F @ (P - Q_robust) @ F.T + Q_robust
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_robust, y, P, K, x
