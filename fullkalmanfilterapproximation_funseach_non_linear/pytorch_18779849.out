def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Online update for F using gradient descent with momentum
    dF = (x - xp) @ P.T
    F += 0.01 * dF
    # Update P with gradient descent
    dP = np.zeros_like(P)
    dP = y @ K.T @ P.T
    P -= 0.01 * dP
    return xp, P, y, S, K, x
