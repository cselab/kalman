def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use Sherman-Morrison formula for updating P
    u = K @ y
    v = y
    P = P - (P @ u) @ v.T @ inv(S) @ (v @ u.T)
    return xp, P, y, S, K, x
