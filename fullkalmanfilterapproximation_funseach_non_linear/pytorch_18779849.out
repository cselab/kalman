def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    L = np.linalg.cholesky(S)
    y_chol = np.linalg.solve(L.T, y)
    x = xp + L @ y_chol
    P = (np.linalg.inv(F.T @ F) @ P) - (L @ np.linalg.solve(S, L.T @ P))
    return xp, P, y, S, L, x
