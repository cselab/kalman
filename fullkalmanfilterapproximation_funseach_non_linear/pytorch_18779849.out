function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, Sigma, V = np.linalg.svd(S + 1e-6 * np.eye(S.shape[0]))
    inv_Sigma = np.diag(1/Sigma)
    inv_S = V @ inv_Sigma @ U.T
    K = P @ inv_S
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    loss = np.sum(y ** 2) / len(y)
    return xp, P, y, S, K, x
