def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S_inv, V = np.linalg.svd(S, full_matrices=True)
    K = P @ (V.T @ np.diag(1/S_inv) @ U.T)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
