def aproximate(x, F, P, Q, z, R):
    xp = np.maximum(F @ x, 0)
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    x = np.tanh(x)
    return xp, P, y, S, K, x
