def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    block_size = 50
    inv_S = np.zeros_like(S)
    for i in range(0, S.shape[0], block_size):
        inv_S[i:i+block_size, i:i+block_size] = np.linalg.inv(S[i:i+block_size, i:i+block_size])
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
