def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[:S.size] = 1/S[:S.size]
    K = P @ (V.T @ (inv_S * U.T @ y))
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
