def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F(x)  # F is now a nonlinear function
    J = jacobian(F, x)  # Compute Jacobian of F at x
    P = J @ P @ J.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(J.T @ J) - K @ J) @ P
    return xp, P, y, S, K, x
