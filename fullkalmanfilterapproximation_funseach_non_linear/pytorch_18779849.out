def aproximate(x, F, P, Q, z, R):
    # Implementation 3: SVD for Inverse of S
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    _, _, inv_S = np.linalg.svd(S, compute_uv=False, full_matrices=True)
    K = inv_S @ P.T
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S.T) @ P
    history.append(x)
    return xp, P, y, S, K, x
