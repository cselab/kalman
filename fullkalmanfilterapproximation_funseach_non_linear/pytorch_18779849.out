def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Recursive least squares with forgetting factor
    lambda_f = 0.99
    inv_S = np.linalg.inv(S)
    inv_S = inv_S * lambda_f + (1 - lambda_f) * np.linalg.inv(y @ y.T)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
