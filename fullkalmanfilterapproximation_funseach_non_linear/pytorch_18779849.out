def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using parallelized inversion
    S_inv = np.zeros_like(S)
    for i in range(S.shape[0]):
        S_inv[i, :] = np.linalg.solve(S, np.eye(S.shape[0])[i, :])
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
