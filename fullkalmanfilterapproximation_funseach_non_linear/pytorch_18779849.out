function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Scale P based on the magnitude of y
    scale = np.linalg.norm(y) * 0.1
    P *= scale
    # Add a small scaled identity to maintain positive definiteness
    P += np.eye(P.shape[0]) * 1e-6
    return xp, P, y, S, K, x
