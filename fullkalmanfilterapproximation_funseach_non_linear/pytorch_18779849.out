def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = np.block([[F @ P[:, :F.shape[1]], F @ P[:, F.shape[1]:]], 
                 [P[:F.shape[1], :], P[F.shape[1]:, :]]]) + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
