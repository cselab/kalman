def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the Mahalanobis distance
    md = (y.T @ np.linalg.inv(S)) @ y
    # Scale Q based on Mahalanobis distance
    scale = np.exp(-md / (2 * S.shape[0]))
    Q_adj = Q * scale
    P = F @ (P - Q_adj) @ F.T + Q_adj
    S_adj = P + R
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_adj, y, P, K, x
