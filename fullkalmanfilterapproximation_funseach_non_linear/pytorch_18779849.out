def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Using SVD for more stable inversion
    U, S_diag, V = np.linalg.svd(S)
    S_inv = np.diag(1/S_diag) @ V.T
    K = P @ S_inv
    x = xp + K @ y
    return xp, P, y, S, K, x
