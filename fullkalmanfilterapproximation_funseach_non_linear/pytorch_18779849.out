def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Robust Kalman Filter with Huber loss
    rho = 0.5 * y**2 / (S + 1e-8)
    d = y / (S + 1e-8)
    Q = Q * np.exp(-rho)
    P = F @ (P - Q) @ F.T + Q
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_robust, K, x
