def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[S != 0] = 1 / S[S != 0]
    inv_S = V.T @ np.diag(inv_S) @ U.T
    K = P @ inv_S @ y
    x = xp + K
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return xp, P, y, S, K, x
