def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = np.matmul(F, x)
    P = np.matmul(np.matmul(F, P), F.T) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = np.matmul(P, inv_S)
    x = xp + np.matmul(K, y)
    P = (np.eye(F.shape[0]) - np.matmul(K, P)) + 0.000001 * np.random.randn(*P.shape)
    return xp, P, y, S, K, x
