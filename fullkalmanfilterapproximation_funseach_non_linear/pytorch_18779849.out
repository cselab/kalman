def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Extended Kalman Filter with Symplectic Integration
    sympl_step = 0.1
    x = x + sympl_step * (F @ y)
    P = F @ P @ F.T + Q
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
