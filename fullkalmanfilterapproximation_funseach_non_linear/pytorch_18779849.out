def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Second-order approximation for P
    hessian = 2 * F @ F.T
    step_size = 0.1
    P = P - step_size * np.linalg.inv(hessian) @ (P - F @ P @ F.T - Q)
    return xp, S, y, P, K, x
