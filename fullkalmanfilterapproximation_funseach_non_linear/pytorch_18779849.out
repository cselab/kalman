def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    scale = np.exp(-np.sum(y**2) / (2 * S.trace()))
    P_scaled = P * scale
    K = P_scaled @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_scaled
    return xp, P, y, S, K, x
