def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    eigenvals, eigenvecs = np.linalg.eigh(S)
    eigenvals[eigenvals < 1e-8] = 1e-8
    inv_S = eigenvecs @ np.diag(1/eigenvals) @ eigenvecs.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
