def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    # Add a small identity matrix for numerical stability
    epsilon = 1e-6
    S += epsilon * np.eye(S.shape[0])
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S, K, x
