def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('init', x, F, P, Q, z, R))
    
    # Implementation 3: Singular Value Decomposition for Inversion
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[S > 1e-8] = 1 / S[S > 1e-8]
    inv_S = np.diagflat(inv_S)
    inv_S = V.T @ inv_S @ U.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(('svd_inv', xp, P, y, S, K, x))
    return xp, P, y, S, K, x
