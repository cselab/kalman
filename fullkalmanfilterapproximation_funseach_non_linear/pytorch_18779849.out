def aproximate(x, F, P, Q, z, R):
    from numpy import linalg, random
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ linalg.inv(S)
    x = xp + K @ y
    # Add a scaled noise based on the Frobenius norm of P
    frob_P = linalg.norm(P, 'fro')
