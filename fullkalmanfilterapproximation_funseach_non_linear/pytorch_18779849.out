function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = np.linalg.inv(S) @ F @ P.T
    x = xp + K @ y
    # Update P using the inverse of S
    P = F @ (P - K @ S @ K.T) @ F.T
    return xp, P, y, S, K, x
