def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Implementation 10: Add a small value to P using np.maximum
    epsilon = 1e-6
    P = np.maximum(P, epsilon)
    return xp, P, y, S, K, x
