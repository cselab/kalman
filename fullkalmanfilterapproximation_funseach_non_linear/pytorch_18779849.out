def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Sparse matrix techniques
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply sparsity to P
    P_sparse = np.where(np.abs(P) < 0.1, 0, P)
    return xp, P_sparse, y, S, K, x
