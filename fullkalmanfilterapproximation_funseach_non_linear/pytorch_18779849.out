def aproximate(x, F, P, Q, z, R):
    noise = np.random.normal(0, 0.1, x.shape)
    xp = F @ (x + noise)
    P = F @ P @ F.T + Q + np.random.normal(0, 0.1, P.shape)
    y = z - xp
    S = P + R + np.random.normal(0, 0.1, P.shape)
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = P + np.random.normal(0, 0.1, P.shape)
    return xp, P, y, S, K, x
