def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    x = x.copy()
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    inv_S = numpy.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = F.dot(P).dot(F.T) + Q * 0.95
    return xp, P, y, S, K, x
