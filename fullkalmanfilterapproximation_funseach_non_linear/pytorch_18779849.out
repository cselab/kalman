def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ numpy.linalg.inv(S)
    x = xp + K @ y
    # Scale the Kalman gain by a factor to reduce the loss
    scale_K = 0.9
    K_scaled = K * scale_K
    x = xp + K_scaled @ y
    # Update P with the scaled K
    P = (numpy.eye(F.shape[0]) - K_scaled) @ P
    return xp, P, y, S, K_scaled, x
