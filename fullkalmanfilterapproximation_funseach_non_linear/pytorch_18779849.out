def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Update P using inversion lemma
    P = F @ P @ F.T + Q - K @ R
    # Add a small random noise to x to prevent getting stuck
    x = x + np.random.randn(*x.shape) * 0.01
    return xp, P, y, S, K, x
