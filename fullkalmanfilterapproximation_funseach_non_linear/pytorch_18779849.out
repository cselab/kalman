def aproximate(x, F, P, Q, z, R):
    if F.shape[0] != x.shape[0]:
        F = F.T
    if F.shape[0] != P.shape[0]:
        P = P.T
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = np.linalg.inv(S) @ P
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ F) @ P
    return xp, P, y, S, K, x
