def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    cross = np.zeros((F.shape[0], F.shape[0]))
    for i in range(F.shape[0]):
        for j in range(F.shape[0]):
            if i != j:
                cross[i,j] = 0.1 * F[i,j] * F[j,i]
    P = F @ P @ F.T + Q + cross
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
