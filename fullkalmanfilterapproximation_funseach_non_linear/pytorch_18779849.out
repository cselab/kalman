def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = (np.eye(F.shape[0]) - K.dot(P))
    x = x + np.random.normal(0, 0.01, x.shape)
    x = x * (1 + np.random.uniform(-0.01, 0.01, x.shape))
    return xp, P, y, S, K, x
