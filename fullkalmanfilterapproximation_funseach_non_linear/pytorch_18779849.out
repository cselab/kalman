def aproximate(x, F, P, Q, z, R):
    from numpy import array, dot, sqrt, diag, eye, inv, outer
    xp = dot(F, x)
    P = dot(F, dot(P, F.T)) + Q
    y = z - xp
    S = P + R
    K = dot(P, inv(S))
    x = xp + dot(K, y)
    P = dot(eye(x.shape[0]) - K, P)
    return xp, P, y, S, K, x
