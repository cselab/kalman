def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    epsilon = 1e-11
    S_inv = np.linalg.inv(S)
    S_inv += np.where(np.diag(S) < epsilon, 1e-11, 0) * np.eye(S.shape[0])
    K = P @ S_inv
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
