def aproximate(x, F, P, Q, z, R):
    import numpy as note
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the matrix inversion using Cholesky decomposition
    try:
        L_S = np.linalg.cholesky(S)
        inv_S = np.linalg.inv(L_S.T @ L_S)
    except np.linalg.LinAlgError:
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
