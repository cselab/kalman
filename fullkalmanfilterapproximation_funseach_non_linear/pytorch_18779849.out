def aproximate(x, F, P, Q, z, R):
    import numpy as np
    global history
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute Cholesky decomposition
    L = np.linalg.cholesky(S)
    inv_L = np.linalg.inv(L)
    inv_S = inv_L @ inv_L.T
    K = P @ inv_S @ y
    x = xp + K
    P = P - K @ K.T
    history.append(x.copy())
    return xp, P, y, S, K, x
