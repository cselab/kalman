def aproximate(x, F, P, Q, z, R):
    from numpy import linalg, random
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ linalg.inv(S)
    x = xp + K @ y
    # Probabilistic perturbation based on the confidence level
    confidence = np.clip(np.dot(y, S.T @ y), 0, 1)
    perturbation = random.randn(*P.shape) * 0.015 * confidence
    P += perturbation
    return xp, P, y, S, K, x
