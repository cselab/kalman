def aproximate(x, F, P, Q, z, R):
    # Implementation 3: Robust Kalman Filter with outlier detection
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    loss = np.sum(np.square(y)) / np.trace(S)
    if np.max(np.abs(y)) > 3 * np.sqrt(np.mean(S.diagonal())):
        x = x
        P = P + 0.1 * Q
    history.append(loss)
    return xp, S, y, P, K, x
