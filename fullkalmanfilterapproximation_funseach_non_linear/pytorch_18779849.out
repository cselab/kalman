def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S, full_matrices=True)
    inv_S = np.linalg.inv(S + 1e-11 * np.eye(S.shape[0]))
    K = P @ (V.T @ (inv_S @ U.T))
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
