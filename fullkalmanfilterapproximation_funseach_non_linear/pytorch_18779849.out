function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Add a small value to P to avoid singular matrix
    epsilon = 1e-6
    P += epsilon * np.eye(P.shape[0])
    return xp, P, y, S, K, x
