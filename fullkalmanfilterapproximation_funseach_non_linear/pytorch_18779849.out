def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Online update for F using gradient descent with momentum
    dF = (x - xp) @ P.T
    F += 0.01 * dF
    # Online update for P using gradient descent
    dP = y @ K.T @ P.T
    P -= 0.01 * dP
    # Online update for Q using gradient descent
    dQ = F @ P @ F.T - P
    Q += 0.01 * dQ
    # Online update for R using gradient descent
    dR = y @ K.T
    R += 0.01 * dR
    # Online update for z using gradient descent
    dz = x - z
    z += 0.01 * dz
    # Online update for x using gradient descent
    dx = x - xp
    x += 0.01 * dx
    # Online update for all parameters using gradient descent with adaptive learning rate
    learning_rate = 0.01
    d_params = [dF, dP, dQ, dR, dz, dx]
    params = [F, P, Q, R, z, x]
    for param, d in zip(params, d_params):
        param += learning_rate * d
    return xp, P, y, S, K, x
