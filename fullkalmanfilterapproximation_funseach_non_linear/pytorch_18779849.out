def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Distributed processing
    node_results = []
    for i in range(len(z)):
        xp = F @ x
        P = F @ P @ F.T + Q
        y = z[i] - xp
        S = P + R
        K = P @ np.linalg.inv(S)
        x = xp + K @ y
        P = (np.eye(F.shape[0]) - K) @ P
        node_results.append((xp, P, y, S, K, x))
    return node_results
