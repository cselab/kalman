def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD
    U, S_diag, V = np.linalg.svd(S, full_matrices=True)
    S_inv = np.zeros_like(S)
    S_inv[np.arange(S.shape[0]), np.arange(S.shape[0])] = 1. / S_diag
    S_inv = V.T @ S_inv @ U.T
    K = P @ S_inv
    x = xp + K @ y
    return xp, P, y, S, K, x
