def aproximate(x, F, P, Q, z, R):
    import numpy as np
    global history
    if 'history' not in globals():
        history = []
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    prev_K = history[-1] if history else K
    K = K * 0.5 + prev_K * 0.5
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(K)
    return xp, P, y, S, K, x
