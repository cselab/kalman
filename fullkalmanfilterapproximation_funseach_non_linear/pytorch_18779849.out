def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Clipped residuals
    y_clipped = np.clip(y, -2.5, 2.5)
    rho = 0.5 * y_clipped**2
    d = y_clipped
    Q_robust = Q * rho
    P = F @ (P - Q_robust) @ F.T + Q_robust
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_robust, y, P, K, x
