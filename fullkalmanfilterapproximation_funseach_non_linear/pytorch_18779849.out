function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Compute predicted state
    xp = F @ x
    # Update covariance matrix
    P = F @ P @ F.T + Q
    # Compute innovation
    y = z - xp
    # Compute total uncertainty
    S = P + R
    # Compute Kalman gain
    K = P @ np.linalg.inv(S) @ y
    # Update state estimate
    x = xp + K
    # Update covariance
    P = P - K[:, None] * K[None, :]
    # Apply additive noise
    x = x + np.random.randn(*x.shape) * 0.05
    # Record state
    history.append(x)
    return xp, P, y, S, K, x
