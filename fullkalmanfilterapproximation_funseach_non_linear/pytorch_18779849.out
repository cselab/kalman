function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F.dot(x)
    P = F.dot(P).dot(F.T) + Q
    y = z - xp
    S = P + R
    # Use SVD for robust inversion
    U, S_diag, V = np.linalg.svd(S, full_matrices=False)
    inv_S = V.T @ np.linalg.inv(S_diag) @ U.T
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P)
    return xp, P, y, S, K, x
