def aproximate(x, F, P, Q, z, R):
    import numpy as np
    beta = 0.5
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    det_S = np.linalg.det(S)
    det_R = np.linalg.det(R)
    scale = 1 + beta * (det_S / det_R)
    R_adj = R * scale
    S_adj = P + R_adj
    inv_S_adj = np.linalg.inv(S_adj)
    K = P @ inv_S_adj
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
