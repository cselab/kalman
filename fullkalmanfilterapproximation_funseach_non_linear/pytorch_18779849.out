function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S + 1e-14 * np.eye(S.shape[0]))
    K = P @ inv_S
    # Batch normalization
    x_mean = np.mean(x, axis=0)
    x_var = np.var(x, axis=0)
    x = (x - x_mean) / np.sqrt(x_var + 1e-8)
    x = xp + K @ y
    return xp, P, y, S, K, x
