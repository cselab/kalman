function:
def aproximate(x, F, P, Q, z, R):
    global state, history
    
    # Current state
    current_state = x
    
    # Compute the predicted state
    xp = F @ current_state
    
    # Update the covariance matrix
    P = F @ P @ F.T + Q
    
    # Compute the innovation
    y = z - xp
    
    # Compute the innovation covariance
    S = P + R
    
    # Compute the Kalman gain
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    
    # Update the state estimate
    x = xp + K @ y
    
    # Add noise to the state estimate
    noise = np.random.normal(0, 0.01, x.shape)
    x = x + noise
    
    # Store the updated state in history
    history.append(x)
    
    # Return the required outputs
    return xp, P, y, S, K, x
