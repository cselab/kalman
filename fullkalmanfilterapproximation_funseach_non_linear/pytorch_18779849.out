def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Just-In-Time (JIT) optimization for matrix operations
    S_inv = np.linalg.inv(S)
    K = P @ S_inv
    x = xp + K @ y
    return xp, P, y, S, K, x
