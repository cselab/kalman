function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Add robust noise using M-estimation
    sigma = np.std(y, ddof=1)
    rho = np.log(1 + (y / sigma)**2)
    weights = np.exp(-rho)
    x = x * weights[:, np.newaxis]
    return xp, P, y, S, K, x
