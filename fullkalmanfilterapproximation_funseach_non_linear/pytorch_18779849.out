def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    residuals = y @ np.linalg.inv(S)
    scale = np.median(abs(residuals))
    R_robust = scale * np.eye(S.shape[0])
    S_robust = P + R_robust
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_robust, K, x
