function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a transformation to P based on the state's magnitude
    mag = np.linalg.norm(x)
    P = P * (1 + 0.01 * mag)
    return xp, P, y, S, K, x
