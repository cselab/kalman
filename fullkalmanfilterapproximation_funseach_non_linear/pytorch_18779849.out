def aproximate(x, F, P, Q, z, R):
    import numpy as np
    n = x.size
    m = z.size
    k = 0.1
    beta = 2.0
    alpha = k
    gamma = alpha + m - n
    lambda_ = alpha * (n + gamma)
    chi = np.sqrt(lambda_ * np.ones((n, 1)))
    sigma_points = np.zeros((n, 2n))
    sigma_points[:, 0] = x
    for i in range(n):
        sigma_points[:, i+1] = x + chi[i]
    X = F @ sigma_points
    XP = np.mean(X, 1)
    P = np.cov(X, rowvar=True) + Q
    y = z - XP
    S = P + R
    K = P @ np.linalg.inv(S)
    x = XP + K @ y
    P = (np.eye(F.shape[0]) - K @ F) @ P
    return XP, P, y, S, K, x
