def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Scale P based on maximum diagonal element of S
    scale = np.max(np.diag(S)) * 0.5
    P *= scale
    # Add small noise to x and P
    noise_x = np.random.normal(0, 1e-3, x.shape)
    noise_P = np.random.normal(0, 1e-4, P.shape)
    x += noise_x
    P += noise_P
    return xp, P, y, S, K, x
