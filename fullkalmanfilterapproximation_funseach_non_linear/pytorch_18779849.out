def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Robust loss function using Huber
    rho = lambda s: s**2 if np.abs(s) <= 1 else 2 * np.abs(s) - 0.5
    robust_factor = rho(np.sqrt(np.diag(S)))
    S_adj = S * (robust_factor[:, None] * robust_factor[None,:])
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append((x, P, y, S_adj, K))
    return xp, P, y, S_adj, K, x
