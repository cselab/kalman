def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Use matrix inversion with eigenvalues
    eigvals, eigvecs = np.linalg.eigh(S)
    inv_S = np.zeros_like(S)
    inv_S = eigvecs @ (np.diag(1 / eigvals)) @ eigvecs.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
