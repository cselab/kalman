def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    try:
        S_cho, low = np.linalg.cholesky(S), True
    except:
        S_cho, low = np.linalg.inv(S), False
    if low:
        S_inv = np.linalg.solve_triangular(S_cho, np.eye(S.shape[0]), lower=True)
    else:
        S_inv = np.linalg.inv(S)
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ F) @ P
    return xp, S, y, P, K, x
