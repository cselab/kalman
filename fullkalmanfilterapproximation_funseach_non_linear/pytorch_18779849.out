def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the Frobenius norm of S and R
    frob_S = np.linalg.norm(S, 'fro')
    frob_R = np.linalg.norm(R, 'fro')
    scale = 1 + np.clip(frob_S / frob_R - 1, 0, None)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
