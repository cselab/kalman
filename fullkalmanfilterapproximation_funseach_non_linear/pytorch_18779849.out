def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = P - K @ R @ K.T + np.eye(P.shape[0]) * 1e-6
    return xp, P, y, S, K, x
