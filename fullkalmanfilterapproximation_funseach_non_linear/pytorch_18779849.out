def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x_pred = F @ x
    P_pred = F @ P @ F.T + Q
    residual = z - x_pred
    S = P_pred + R
    inv_S = np.linalg.inv(S)
    K = P_pred @ inv_S
    x = x_pred + K @ residual
    P = (np.eye(F.shape[0]) - K @ P_pred) + 0.00001 * np.random.randn(*P.shape)
    return x_pred, P_pred, residual, S, K, x
