def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Adaptive update based on Mahalanobis distance
    dist = np.sqrt(np.sum(y**2 / S))
    scale_factor = 1 + (dist - np.mean(dist)) / np.std(dist)
    Q = Q * scale_factor
    P = F @ P @ F.T + Q
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    return xp, S, y, P, K, x
