def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute K using SVD for numerical stability
    U, S_inv, V = np.linalg.svd(S, full_matrices=True)
    K = P @ (U.T @ (np.diag(1/S_inv) @ V))
    x = xp + K @ y
    return xp, P, y, S, K, x
