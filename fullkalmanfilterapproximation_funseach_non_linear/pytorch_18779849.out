def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Compute predicted state
    xp = F @ x
    # Update Q based on previous P
    Q_new = Q + 0.01 * P
    # Update P matrix
    P = F @ P @ F.T + Q_new
    # Compute innovation
    y = z - xp
    # Compute S
    S = P + R
    # Calculate Kalman gain
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    # Update state
    x = xp + K @ y
    # Update covariance
    P = (np.eye(F.shape[0]) - K @ inv_S) @ P
    return xp, P, y, S, K, x
