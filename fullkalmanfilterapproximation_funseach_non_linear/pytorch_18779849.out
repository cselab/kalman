def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    rho = np.log(1 + y**2 / (S + 1e-8))
    d = 2 * y / (S + 1e-8) / (1 + y**2 / (S + 1e-8))
    Q_robust = Q * np.exp(-rho)
    P = F @ (P - Q_robust) @ F.T + Q_robust
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_robust, y, P, K, x
