def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P_new = F @ P @ F.T + Q
    y = z - xp
    S = P_new + R
    try:
        inv_S = np.linalg.inv(S)
    except np.linalg.LinAlgError:
        inv_S = np.linalg.pinv(S)
    K = P_new @ inv_S
    x_new = xp + K @ y
    P_new = np.eye(F.shape[0]) - K @ P_new
    return xp, P_new, y, S, K, x_new
