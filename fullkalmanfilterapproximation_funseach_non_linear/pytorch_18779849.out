def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.array([np.linalg.inv(Si) for Si in S])
    K = P @ inv_S
    x = xp + K @ y
    x = x + np.random.normal(0, 0.04, x.shape)
    x = x * (1 + np.random.uniform(-0.04, 0.04, x.shape))
    return xp, P, y, S, K, x
