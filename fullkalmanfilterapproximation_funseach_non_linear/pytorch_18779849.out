function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    S_inv = np.linalg.inv(S + 1e-5 * np.eye(S.shape[0]))
    K = P @ S_inv
    x = K @ y + xp
    return xp, P, y, S, K, x
