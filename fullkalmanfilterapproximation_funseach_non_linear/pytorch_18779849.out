def aproximate(x, F, P, Q, z, R):
    x_p = F @ x
    P_p = F @ P @ F.T + Q
    y = z - x_p
    S = P_p + R
    # Using SVD for more stable inversion
    U, S, V = np.linalg.svd(S)
    inv_S = V.T @ np.diag(1/S) @ U.T
    K = P_p @ inv_S @ y
    x = x_p + K
    P = P_p - K @ K.T
    return x_p, P_p, y, S, K, x
