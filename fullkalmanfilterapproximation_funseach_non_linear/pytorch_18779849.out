def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    residuals = np.abs(y)
    weights = np.exp(-residuals ** 2 / (2 * S.trace()))
    Q_adj = Q * weights
    P = F @ (P - Q_adj) @ F.T + Q_adj
    S_adj = P + R
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
