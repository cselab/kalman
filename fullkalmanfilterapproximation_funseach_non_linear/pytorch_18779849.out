def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R + 1e-8 * np.eye(len(R))
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Augment state with additional variables
    x_aug = np.concatenate([x, np.zeros(len(R))])
    P_aug = np.block([[P, np.zeros((len(P), len(R)))], [np.zeros((len(R), len(P))), R]])
    return xp, S, y, P, K, x_aug
