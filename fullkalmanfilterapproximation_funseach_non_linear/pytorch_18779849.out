def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    dF = (x - xp) @ P.T
    lr = 0.1 / (1 + np.linalg.norm(dF))
    F += lr * dF
    loss = np.mean((z - xp)**2)
    return xp, P, y, S, K, x
