def aproximate(x, F, P, Q, z, R):
    from numpy.linalg import sqrtm, inv
    xp = F @ x
    sqrt_P = sqrtm(P)
    sqrt_P_update = sqrt_P @ F.T
    P_update = sqrt_P_update @ sqrt_P_update.T + sqrtm(Q)
    y = z - xp
    S = P_update @ inv(P_update) @ P_update.T + R
    K = (sqrt_P_update @ inv(S)) @ y
    x = xp + K
    P = (sqrtm(P_update) @ inv(sqrtm(S))) @ sqrt_P
    return xp, P, y, S, K, x
