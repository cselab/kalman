function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = P.T @ np.linalg.inv(S) @ P
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    x = x + np.random.poisson(0, x.shape)
    return xp, P, y, S, K, x
