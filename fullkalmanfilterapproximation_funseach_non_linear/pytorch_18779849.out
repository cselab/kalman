def aproximate(x, F, P, Q, z, R):
    import numpy as numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Update P with a small random noise to avoid singularities
    P = (np.eye(F.shape[0]) - K @ P) + 0.00004 * np.random.randn(*P.shape)
    return xp, P, y, S, K, x
