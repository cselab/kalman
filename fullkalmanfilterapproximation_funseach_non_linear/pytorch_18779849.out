function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Use a rank-one update to P
    u = np.mean(P, axis=0)
    v = np.mean(P, axis=1)
    P = P + u * v.T
    return xp, P, y, S, K, x
