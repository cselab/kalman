def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Modified Kalman Filter with a different approach to updating the state
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a non-linear transformation to x to reduce uncertainty
