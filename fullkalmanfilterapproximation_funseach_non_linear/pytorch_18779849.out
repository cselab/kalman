def aproximate(x, F, P, Q, z, R):
    import numpy as  numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Use a sparse matrix solver for better performance
    from scipy.sparse import csr_matrix
    S_sparse = csr_matrix(S)
    K_sparse = P @ S_sparse.inv()
    x = xp + K_sparse @ y
    return xp, P, y, S, K, x
