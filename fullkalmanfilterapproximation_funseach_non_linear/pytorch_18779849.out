function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the innovation covariance
    try:
        inv_S = np.linalg.inv(S)
    except LinAlgError:
        inv_S = np.linalg.pinv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ F.T) @ P
    # Add a small noise to P to prevent numerical issues
    P += np.random.normal(0, 0.001, size=P.shape)
    return xp, S, y, P, K, x
