def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Ensemble sampling
    n_samples = 10
    y_samples = np.random.normal(y, np.sqrt(S))
    Q_samples = Q * np.exp(-np.linalg.norm(y_samples, axis=0)**2 / (2*S.trace()))
    P_samples = F @ (P - Q_samples) @ F.T + Q_samples
    S_samples = P_samples + R
    K_samples = P_samples @ np.linalg.inv(S_samples)
    x_samples = xp + K_samples @ y_samples
    x = np.mean(x_samples, axis=0)
    P = np.mean(P_samples, axis=0)
    return xp,
