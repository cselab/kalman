def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Use iterative scaling for P
    alpha = 1
    for _ in range(5):
        inv_P = np.linalg.inv(P)
        inv_P_scaled = inv_P + alpha * K @ np.linalg.inv(S) @ K.T
        P = np.linalg.inv(inv_P_scaled)
        alpha *= 0.5
    return xp, S, y, P, K, x
