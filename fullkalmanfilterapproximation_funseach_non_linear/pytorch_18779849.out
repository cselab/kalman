def aproximate(x, F, P, Q, z, R):
    # Implementation 5: Matrix Inversion with Tolerance
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    try:
        inv_S = np.linalg.inv(S)
    except np.linalg.LinAlgError:
        inv_S = np.linalg.pinv(S)
    K = inv_S @ P.T
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ inv_S.T) @ P
    history.append(x)
    return xp, P, y, S, K, x
