def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    history.append(('P', P))
    P_avg = (P + history[-1])/2 if history else P
    y = z - xp
    S = P_avg + R
    inv_S = np.linalg.inv(S)
    K = P_avg.dot(inv_S)
    x = xp + K.dot(y)
    P = np.eye(F.shape[0]) - K.dot(P_avg)
    return xp, P, y, S, K, x
