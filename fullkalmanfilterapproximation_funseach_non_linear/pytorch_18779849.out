def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse of S using eigenvalue decomposition
    eigvals, eigvecs = np.linalg.eigh(S)
    inv_S = eigvecs @ np.diag(1/eigvals) @ eigvecs.T
    K = P @ inv_S
    x = xp + K @ y
    return xp, S, y, P, K, x
