def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using Sherman-Morrison formula
    I = np.eye(S.shape[0])
    u = np.zeros_like(I[:, 0])
    v = np.zeros_like(I[:, 0])
    for i in range(S.shape[0]):
        u = I[:, i]
        v = np.linalg.solve(S, u)
        S_inv = I - np.outer(u, v) / (1 + np.dot(u, v))
    K = P @ S_inv
    x = xp + K @ y
    P = (I - K) @ P
    return xp, P, y, S, K, x
