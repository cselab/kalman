def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    eigvals = np.linalg.eigvals(S)
    if np.all(eigvals > 0):
        K = P @ np.linalg.inv(S)
    else:
        K = np.zeros_like(P)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
