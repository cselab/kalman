def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Dynamic adjustment of Q
    Q = np.clip(Q, 1e-8, None)
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
