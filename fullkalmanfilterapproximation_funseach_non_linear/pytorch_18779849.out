def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse of S using Cholesky decomposition
    L = np.linalg.cholesky(S)
    inv_S = np.linalg.inv(L.T) @ np.linalg.inv(L)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S, y, P, K, x
