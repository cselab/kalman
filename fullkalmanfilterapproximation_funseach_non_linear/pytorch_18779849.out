def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add elastic net regularization to x
    alpha = 0.01
    l1_ratio = 0.5
    x = x - alpha * (l1_ratio * np.sign(x) + (1 - l1_ratio) * x)
    return xp, P, y, S, K, x
