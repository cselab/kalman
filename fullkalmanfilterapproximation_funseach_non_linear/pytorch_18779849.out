def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S + 1e-10 * np.eye(len(S)))
    K = P @ inv_S
    x = xp + K @ y
    P = np.eye(F.shape[0]) - K @ P
    return xp, P, y, S, K, x
