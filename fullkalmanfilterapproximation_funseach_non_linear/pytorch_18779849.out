def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S, full_matrices=True)
    inv_S = np.zeros_like(S)
    inv_S[S != 0] = 1 / S[S != 0]
    inv_S = np.diag(inv_S)
    inv_S = np.dot(V.T, np.dot(inv_S, U.T))
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(F.T @ F) - K) @ P
    return xp, P, y, S, K, x
