def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.atleast_2d(x)
    F = np.atleast_2d(F)
    P = np.atleast_2d(P)
    Q = np.at least_2d(Q)
    z = np.atleast_2d(z)
    R = np.atleast_2d(R)
    xp = F @ x
    y = z - xp
    P = F @ P @ F.T + Q
    S = P + R
    inv_S = np.linalg.inv(S + np.spacing(1))
    K = P @ inv_S
    x = xp + K @ y
    P = np.eye(F.shape[0]) - K @ P
    x = x.squeeze()
    P = P.squeeze()
    return xp, P, y, S, K, x
