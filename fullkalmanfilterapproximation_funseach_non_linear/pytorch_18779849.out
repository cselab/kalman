def aproximate(x, F, P, Q, z, R):
    import numpy as np
    from scipy.sparse import csr_matrix
    F_sparse = csr_matrix(F)
    P_sparse = csr_matrix(P)
    xp = F_sparse @ x
    P = F_sparse @ P_sparse @ F_sparse.T + Q
    y = z - xp
    S = P + R
    K = P_sparse @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
