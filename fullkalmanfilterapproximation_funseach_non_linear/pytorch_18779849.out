function:
def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Robust Kalman Filter with Huber Loss
    rho = 1
    residuals = np.linalg.norm(y, axis=0)
    weights = np.where(residuals <= rho, 1 - (residuals**2)/(2*rho), np.exp(-residuals**2/(2*rho)))
    Q_robust = Q * weights
    P = F @ (P - Q_robust) @ F.T + Q_robust
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, S_robust, y, P, K, x
