function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Use matrix inversion lemma for efficiency
    inv_P = np.linalg.inv(P)
    inv_S = inv_P + np.linalg.inv(S)
    # Update P using the lemma
    P = np.linalg.inv(inv_S) @ np.linalg.inv(inv_P)
    return xp, S, y, P, K, x
