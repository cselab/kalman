def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    original_x = x.copy()
    
    # Implementation 7: Additive Gamma Noise
    shape = 2
    scale = 0.025
    x = x + np.random.gamma(shape, scale, x.shape)
    loss = np.mean((original_x - x)**2)
    history.append(loss)
    return xp, P, y, S, K, x
score: inf
function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    original_x = x.copy()
    
    # Implementation 8: Additive Chi-Squared Noise
    df = 2
    x = x + np.random.chi2(df, size=x.shape)
    loss = np.mean((original_x - x)**2)
    history.append(loss)
    return xp, P, y, S, K, x
