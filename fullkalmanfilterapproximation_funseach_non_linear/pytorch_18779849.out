def aproximate(x, F, P, Q, z, R):
    import numpy as np
    global history
    history.append(x)
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    S = S + np.diag([1e-10]*S.shape[0]) if np.isclose(np.linalg.det(S), 0) else S
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
