def aproximate(x, F, P, Q, z, R):
    xp = np.einsum('ij,kj->ki', F, x)
    P = np.einsum('ij,kjl->kil', F, P) + Q
    y = z - xp
    S = P + R
    K = np.linalg.solve(S, y) @ P
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
