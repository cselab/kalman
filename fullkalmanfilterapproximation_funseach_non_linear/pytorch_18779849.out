def aproximate(x, F, P, Q, z, R):
    from numpy import dot, diag, sqrt
    xp = dot(F, x)
    P_p = dot(F, dot(P, F.T)) + Q
    y = z - xp
    S = P_p + R
    K = P_p @ inv(S)
    x = xp + dot(K, y)
    P = P_p - dot(K, K.T)
    return xp, P_p, y, S, K, x
