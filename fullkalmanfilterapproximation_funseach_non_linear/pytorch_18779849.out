def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a small regularization to the covariance matrix
    reg = 1e-8
    P = P + reg * np.eye(P.shape[0])
    return xp, P, y, S, K, x
