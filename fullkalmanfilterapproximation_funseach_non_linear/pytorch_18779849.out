def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Predict step
    xp = F.dot(x)
    # Compute P
    P = F.dot(P).dot(F.T) + Q
    # Compute innovation
    y = z - xp
    # Compute S
    S = P + R
    # Compute K
    K = P.dot(np.linalg.inv(S)).dot(y)
    # Update state
    x = xp + K
    # Update P
    P = P - K[:, None] * K[None, :]
    # Add some noise for regularization
    P = P + 0.01 * np.random.randn(*P.shape)
    return xp, P, y, S, K, x
