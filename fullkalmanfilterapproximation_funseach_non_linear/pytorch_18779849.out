def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('scale', 'mean', 'original'))
    
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    det_S = np.linalg.det(S)
    det_R = np.linalg.det(R)
    
    # Compute scale factor using mean of determinant ratio
    det_ratio = det_S / det_R
    scale = np.mean(det_ratio)
    
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    
    return xp, P, y, S_adj, K, x
