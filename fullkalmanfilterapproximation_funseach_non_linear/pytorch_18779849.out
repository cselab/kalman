def aproximate(x, F, P, Q, z, R):
    import numpy as np
    rho = 1
    xp = F @ x
    y = z - xp
    S = P + R
    weights = np.exp(-y.T @ np.linalg.inv(S) @ y / (2*rho))
    x = xp + weights @ y
    P = (np.eye(F.shape[0]) - weights @ F) @ P
    return xp, P, y, S, weights, x
