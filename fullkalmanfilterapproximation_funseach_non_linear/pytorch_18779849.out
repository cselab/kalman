def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    sparse_P = np.where(np.abs(P) < 0.1, 0, P)
    K = sparse_P @ np.linalg.inv(S)
    x = xp + K @ y
