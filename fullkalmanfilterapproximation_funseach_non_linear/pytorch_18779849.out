def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # M-estimator with Cauchy loss
    rho = np.log(1 + np.abs(y) / (S + 1e-8))
    d = 2 * np.sign(y) / (S + 1e-8) / (1 + np.abs(y)/(S + 1e-8))
    Q = Q * np.exp(-rho)
    P = F @ (P - Q) @ F.T + Q
    S_robust = P + R
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) @ P - K) @ P
    return xp, P, y, S_robust, K, x
