def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Eigenvalue decomposition
    eigvals, eigvecs = np.linalg.eigh(S + 1e-12 * np.eye(S.shape[0]))
    inv_S = eigvecs @ np.diag(1/eigvals) @ eigvecs.T
    K = P @ inv_S
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    loss = np.sum(y ** 2) / len(y)
    return xp, P, y, S, K, x
