function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    try:
        L = np.linalg.cholesky(S)
        inv_S = np.linalg.inv(L).T @ np.linalg.inv(L)
    except np.linalg.LinAlgError:
        U, S, V = np.linalg.svd(S)
        inv_S = V.T @ np.diag(1/S) @ U.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
