def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P_new = F @ P @ F.T + Q
    y = z - xp
    S = P_new + R
    max_S = np.max(S)
    max_R = np.max(R)
    scale = max_S / max_R
    R_adj = R * scale
    S_adj = P_new + R_adj
    K = P_new @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_new
    return xp, P, y, S_adj, K, x
