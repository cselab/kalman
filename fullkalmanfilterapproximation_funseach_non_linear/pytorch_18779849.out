def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Using the Sherman-Morrison formula for efficient inversion
    # Sherman-Morrison formula is used when updating an inverse matrix
    # For S = P + R, if R is rank 1, this can be efficient
    # However, in this case, R is likely full rank, so it might not help
    # Proceeding with standard inversion
    S_inv = np.linalg.inv(S)
    K = P @ S_inv
    x = xp + K @ y
    return xp, P, y, S, K, x
