def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Apply a non-linear transformation to P to reduce uncertainty
    scale = 0.1
    P = P * (1 - scale) + (np.log(P + 1) * scale)
    # Add a small noise to P to prevent numerical issues
    noise = np.random.normal(0, 0.01, P.shape)
    P += noise
    # Clip P values to ensure they are positive
    P = np.clip(P, 0, np.inf)
    # Add a small identity matrix to P to ensure it is invertible
    P += np.eye(P.shape[0]) * 1e-6
    # Ensure P is symmetric
    P = (P + P.T) / 2
    return xp, P, y, S, K, x
