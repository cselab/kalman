def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Low-rank approximation of S
    U, S_diag, V = np.linalg.svd(S, full_matrices=False)
    inv_S = V.T @ np.linalg.inv(np.diag(S_diag)) @ U.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    P = np.maximum(P, 1e-6 * np.eye(P.shape[0]))
    return xp, P, y, S, K, x
