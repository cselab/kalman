def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse using SVD
    U, D, V = np.linalg.svd(S)
    D_inv = np.diag(1/D)
    inv_S = U @ D_inv @ V.T
    K = P @ inv_S
    x = xp + K @ y
    return xp, P, y, S, K, x
