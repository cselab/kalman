def aproximate(x, F, P, Q, z, R):
    global history
    if not hasattr(aproximate, 'history'):
        approximate.history = []
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    try:
        L = np.linalg.cholesky(S)
        L_inv = np.linalg.inv(L)
        S_inv = L_inv.T @ L_inv
    except np.linalg.LinAlgError:
        U, S_diag, V = np.linalg.svd(S)
        S_inv = np.zeros_like(S)
        S_inv[np.diag_indices(S.shape[0])] = 1. / S_diag
        S_inv = V.T @ S_inv @ U.T
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    approximate.history.append((x.copy(), P.copy()))
    return xp, P, y, S, K, x
