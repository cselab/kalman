def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Factorize S
    S_L = np.linalg.cholesky(S)
    K = P @ np.linalg.solve(S_L.T, np.linalg.solve(S_L, y))
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
