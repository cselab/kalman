def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    I = np.eye(S.shape[0])
    alpha = 1e-8
    S_reg = S + alpha * I
    K = P @ np.linalg.inv(S_reg)
    x = xp + K @ y
    P = (I - K) @ P
    return xp, P, y, S_reg, K, x
