function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Efficient inversion using Cholesky decomposition
    try:
        L = np.linalg.cholesky(S)
        L_inv = np.linalg.inv(L)
        S_inv = L_inv.T @ L_inv
    except np.linalg.LinAlgError:
        S_inv = np.linalg.inv(S)
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
