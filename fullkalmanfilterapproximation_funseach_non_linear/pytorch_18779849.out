def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Add a small scaled identity matrix based on the trace of P
    trace = np.trace(P)
    scaling = 0.0001 * (trace / (trace + 1e-6))
    P += scaling * np.eye(P.shape[0])
    return xp, P, y, S, K, x
