def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    S_pseudo = np.linalg.pinv(S + 1e-6 * np.eye(S.shape[0]))
    K = P @ S_pseudo @ y
    x = xp + K
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
