function:
def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute the loss
    loss = np.mean((y**2)/S)
    # Update Q based on loss
    Q = Q * (1 + loss)
    P = F @ P @ F.T + Q
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
