def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Avoid singular matrix by adding a small identity matrix
    epsilon = 1e-6
    inv_S = np.linalg.inv(S + epsilon * np.eye(S.shape[0]))
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ P)
    # Add noise to P for numerical stability
    noise = epsilon * np.random.randn(*P.shape)
    P = P + noise
    return xp, P, y, S, K, x
