def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Scaled Kalman Filter
    scaling_factor = np.exp(-np.sum(y**2) / (2 * S.trace()))
    P_scaled = scaling_factor * P
    K = P_scaled @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_scaled
    return xp, S, y, P, K, x
