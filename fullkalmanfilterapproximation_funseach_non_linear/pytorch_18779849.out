def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    try:
        S_inv = np.linalg.inv(S)
    except np.linalg.LinAlgError:
        # If S is singular, use the Moore-Penrose pseudoinverse
        S_inv = np.linalg.pinv(S)
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
