def aproximate(x, F, P, Q, z, R):
    import numpy as np
    # Particle Filter approach
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Resample particles
    particles = np.random.multivariate_normal(x, P, 1000)
    x_est = np.mean(particles, axis=0)
    return xp, P, y, S, K, x_est
