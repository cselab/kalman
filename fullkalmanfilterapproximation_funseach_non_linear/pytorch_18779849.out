function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S + 1e-5 * np.eye(S.shape[0]))
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    loss = np.sum((x - z)**2)
    print(f"Loss: {loss}")
    return (xp, P, y, S, K, x)
score: inf
function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    noise = np.random.normal(0, 0.005, x.shape)
    x += noise
    return xp, P, y, S, K, x
