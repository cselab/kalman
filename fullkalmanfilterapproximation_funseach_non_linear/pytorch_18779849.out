def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x_pred = F @ x
    P_pred = F @ P @ F.T + Q
    innovation = z - x_pred
    S = P_pred + R
    inv_S = np.linalg.inv(S)
    K = P_pred @ inv_S @ innovation
    x = x_pred + K
    P = P_pred - K[:, None] * K[None, :]
    return x_pred, P_pred, innovation, S, K, x
