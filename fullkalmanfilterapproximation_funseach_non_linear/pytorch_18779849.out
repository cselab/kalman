def aproximate(x, F, P, Q, z, R):
    x = x.copy()
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    # Robust loss function
    rho = lambda s: np.where(s <= 1, 0.5 * s**2, s)
    weights = rho(np.linalg.norm(y, axis=0, keepdims=True))
    P = P * weights
    return xp, P, y, S, K, x
