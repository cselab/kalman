def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x_pred = F @ x
    P_pred = F @ P @ F.T + Q
    y = z - x_pred
    S = np.multiply(P_pred, R) + R
    inv_S = np.linalg.inv(S)
    K = inv_S @ (P_pred.T @ y)
    x = x_pred + K
    P = P_pred - K @ K.T
    return x_pred, P_pred, y, S, K, x
