def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Online update for F using adaptive learning rate
    dF = (x - xp) @ P.T
    learning_rate = 0.1 / (1 + np.linalg.norm(dF))
    F += learning_rate * dF
    return xp, P, y, S, K, x
