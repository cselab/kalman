def aproximate(x, F, P, Q, z, R):
    h = lambda x: F @ x
    H = jacobian(h, x)
    xp = h(x)
    P = H @ P @ H.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(H.shape[0]) - K @ P)
    return xp, P, y, S, K, x
