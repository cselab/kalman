def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    I = np.eye(S.shape[0])
    K = np.zeros_like(P)
    lr = 1e-4
    for _ in range(100):
        SK = S + 1e-15 * I
        inv_SK = np.linalg.inv(SK)
        K_new = P @ inv_SK
        grad_K = P @ (inv_SK.T @ y)[:, None] * y[None, :]
        K += lr * grad_K
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
