function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[S != 0] = 1 / S[S != 0]
    inv_S = np.diag(inv_S)
    Vt = V.T
    inv_S_full = Vt @ inv_S @ U.T
    K = P @ inv_S_full
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
