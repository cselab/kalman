function:
def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('init', x, F, P, Q, z, R))
    
    # Implementation 7: Gradient Descent for K
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = np.zeros_like(P)
    lr = 0.01
    for _ in range(100):
        error = (z - xp).T @ inv_S @ (z - xp)
        dK = 2 * P @ inv_S @ y
        K += lr * dK
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(('gradient_descent', xp, P, y, S, K, x))
    return xp, P, y, S, K, x
