def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Robust KF with Huber loss
    rho = 0.0001
    w = np.exp(-rho * y.T @ y / 2)
    x = w * x
    P = w * P
    return xp, P, y, S, K, x
