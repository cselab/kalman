def aproximate(x, F, P, Q, z, R):
    x_new = F @ x
    S = P + R
    K = P @ np.linalg.inv(S)
    x_new += K @ (z - F @ x)
    P_new = (np.eye(F.shape[0]) - K @ F) @ P
    return x_new, P_new, z - F @ x, S, K, x_new
