def aproximate(x, F, P, Q, z, R):
    import numpy as np
    N = 1000  # Number of particles
    particles = np.random.multivariate_normal(x, P, N)
    weights = np.ones(N) / N
    for i in range(len(z)):
        z_pred = F(particles)
        y = z[i] - z_pred
        S = P + R
        inv_S = np.linalg.inv(S)
        K = P @ inv_S
        x = particles + K @ y
        weights = np.exp(-0.5 * np.sum(y**2, axis=1) / R)
        particles = np.random.multivariate_normal(x, P, N)
    return xp, P, y, S, K, x
