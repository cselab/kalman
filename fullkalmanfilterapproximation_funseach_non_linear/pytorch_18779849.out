def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S_diag, V = np.linalg.svd(S)
    inv_S = np.diag(1/S_diag)
    K = P @ (V.T @ inv_S @ U.T)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
