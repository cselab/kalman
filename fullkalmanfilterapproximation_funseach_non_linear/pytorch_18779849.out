def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    U, S, V = np.linalg.svd(S + 1e-15 * np.eye(S.shape[0]))
    inv_S = np.zeros_like(S)
    inv_S[S != 0] = 1 / S[S != 0]
    inv_S = V.T @ np.diag(inv_S) @ U.T
    K = P @ inv_S
    x = xp + K @ y
    x = np.clip(x, -5, 5)
    return xp, P, y, S, K, x
