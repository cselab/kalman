def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    # Recursive update with momentum based on previous P
    global history
    if len(history) > 0:
        prev_P = history[-1]
        damping = 0.01 * np.trace(prev_P - P)
        P += damping * np.eye(P.shape[0])
    history.append(P)
    return xp, P, y, S, K, x
