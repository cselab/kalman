def aproximate(x, F, P, Q, z, R):
    import numpy as np
    damping = 0.95
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = damping * P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ F) @ P
    return xp, P, y, S, K, x
