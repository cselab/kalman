def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse of S with SVD
    u, s, v = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S = v.T @ (np.diag(1/s)) @ u.T
    K = P @ inv_S
    x = xp + K @ y
    P = (np.linalg.inv(F) @ (np.eye(F.shape[0]) - K)) @ P
    return xp, P, y, S, K, x
