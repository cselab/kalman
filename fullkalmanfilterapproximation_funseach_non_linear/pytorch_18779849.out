def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Compute inverse with SVD for numerical stability
    U, S_diag, V = np.linalg.svd(S, full_matrices=True)
    S_inv = np.diag(1/S_diag) @ V.T @ U.T
    K = P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
