def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))
