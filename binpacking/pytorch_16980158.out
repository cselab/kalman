```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * np.log(bins + 1e-8) + np.sin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.max(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) * np.cos(np.pi * bins) + np.log(item + bins + 1e-8)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item / np.mean(bins)) * np.exp(bins) + np.sin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * np.max(bins) * np.log(item + bins + 1e-8)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) * np.sin(np.pi * bins) + np.log(item + bins + 1e-8)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.min(bins)) * np.exp(item - bins) + np.cos(np.pi * bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * np.mean(bins) + np.sin(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1) * np.max(bins) + np.cos(np.pi * bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) * np.exp(bins) + np.sin(np.pi * (item / bins))
```

