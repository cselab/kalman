import numpy as np
import math

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item * np.mean(bins)) + np.sin(np.pi * item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins) + np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (np.log(bins + 1e-10) * item) * np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    priority = np.zeros_like(bins)
    for i in range(len(bins)):
        priority[i] = (item * bins[i]) ** 2 + np.exp(item - bins[i])
    return priority

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.where(bins > item, np.exp(item - bins), np.log(bins + 1e-10) * item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * (bins - np.mean(bins)) ** 2) * np.exp(item / (bins + 1e-10))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.dot(np.array([item]), bins) * np.exp(item - np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (abs(item - bins) * np.exp(item)) + np.log(bins + 1e-10)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.array([item * b * np.exp(item - b) for b in bins])

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (np.sin(np.pi * item) * np.cos(np.pi * bins)) * item
```

