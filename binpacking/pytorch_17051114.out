 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins - item
    # Only consider bins where remaining >=0
    # But since we can't use conditions, we can use where to mask
    # However, in this case, we need to return an array of same size
    # So, for bins where remaining <0, set priority to 0
    priority = np.where(remaining >= 0, np.exp(remaining), 0)
    return priority
