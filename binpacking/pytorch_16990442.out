### Examples of Unique Implementations:

Here are a few examples of how you might implement different heuristics:

#### Example 1: Best Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available_space = bins.max() - bins
    # Ensure available_space is non-negative
    available_space[available_space < 0] = 0
    # Priority is the available space, lower is better
    return available_space

#### Example 2: Worst Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    available_space = bins.max() - bins
    # Priority is the current available space, higher is better
    return bins.max() - bins

#### Example 3: Max Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Priority is the available space, but only for bins that can fit the item
    can_fit = (bins.max() - bins) >= item
    available_space = bins.max() - bins
    # Set priority to available space where can_fit is True, else 0
    return available_space * can_fit

#### Example 4: Spare Bin Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Priority is 1 if the bin's size is exactly equal to the item, else 0
    return np.where(bins == item, 1, 0)

#### Example 5: Descending Order Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Priority is higher for larger bins that can fit the item
    can_fit = (bins.max() - bins) >= item
    # Use bin size as priority, but only for bins that can fit the item
    return bins * can_fit

#### Example 6: First Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Priority is 1 if the bin can fit the item, else 0
    can_fit = (bins.max() - bins) >= item
    return can_fit.astype(float)

#### Example 7: Min Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Priority is the minimal possible leftover space
    leftover = bins.max() - bins - item
    # Ensure leftover is non-negative
    leftover[leftover < 0] = 0
    return leftover

#### Example 8: Middle Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Priority is the absolute difference between bin's available space and half of the bin's capacity
    available_space = bins.max() - bins
    target = bins.max() / 2
    return np.abs(available_space - target)

#### Example 9: Random Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Priority is a random value for each bin that can fit the item
    can_fit = (bins.max() - bins) >= item
    random_priorities = np.random.rand(*bins.shape)
    return random_priorities * can_fit

#### Example 10: Fallback Fit Heuristic

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Priority is the available space for bins that can fit the item, else a very low value
    can_fit = (bins.max() - bins) >= item
    available_space = bins.max() - bins
    fallback = np.full_like(available_space, -np.inf)
    return np.where(can_fit, available_space, fallback)

