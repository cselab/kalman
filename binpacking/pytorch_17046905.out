 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the remaining capacity of each bin
    remaining = bins.max() - bins
    # Sort bins by remaining capacity in descending order
    sorted_bins = np.argsort(-remaining)
    # Assign priority based on the sorted order
    priority = np.zeros_like(remaining)
    priority[sorted_bins] = np.arange(len(sorted_bins)) + 1
    return priority
