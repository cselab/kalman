### Solution Code:

```
import numpy as np

# Implementation 1
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.mean(bins)) + np.sin(np.pi * (item / bins)) + 4

# Implementation 2
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + np.sin(np.pi * (item / bins)) 

# Implementation 3
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + 4

# Implementation 4
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + np.cos(np.pi * (item / bins)) 

# Implementation 5
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + np.tanh(np.pi * (item / bins)) 

# Implementation 6
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + np.log(np.pi * (item / bins)) 

# Implementation 7
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + np.log10(np.pi * (item / bins)) 

# Implementation 8
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + np.sqrt(np.pi * (item / bins)) 

# Implementation 9
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + np.arcsin(np.pi * (item / bins)) 

# Implementation 10
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item * np.mean(bins)) + np.arccos(np.pi * (item / bins)) 
```

