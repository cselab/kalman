import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * (bins ** 2).mean()) * np.exp(item - bins) + np.sin(np.pi * (item / bins)) + np.cos(item * bins) * np.log(bins + 1)
```

