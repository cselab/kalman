    fit_ratio = item / bins
    priority = np.where(bins > 0, fit_ratio, 0)
    return priority
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - np.mean(bins)) + np.sin(np.pi * (item / bins)) + np.cos(np.pi * (item / bins)) + np.sqrt(item - np.max(bins))
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + bins) * np.mean(bins) * np.exp(item - np.mean(bins)) + np.sin(item) + np.cos(bins)
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.max(bins) * np.min(bins) * item / (np.mean(bins) + 1)
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (item - np.mean(bins)) + np.mean(bins) * np.sin(item)
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.mean(bins) * np.max(bins) * np.min(bins) * (item + np.sum(bins))
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item) * np.mean(bins) + np.sin(bins) * np.cos(item)
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.mean(bins) * np.std(bins) * item + np.log(item)
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item ** 2) * np.mean(bins) + np.sin(np.pi * bins) * np.cos(item)
```

```python
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) * np.mean(bins) + np.exp(bins) * np.log(item)
