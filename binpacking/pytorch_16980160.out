    return np.sin(np.pi * (item / (bins + 1e-8))) + np.cos(np.pi * (item / (bins + 1e-8))) + np.exp(item - bins) * np.std(bins)

4. def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item / (bins + 1e-8)) * np.exp(item - np.mean(bins)) + np.log(np.sum(bins) / item)

5. def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * np.std(bins) + np.log(item) * np.mean(bins) / item

