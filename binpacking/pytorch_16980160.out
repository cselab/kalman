import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.std(bins)) + np.sin(np.pi * (item / bins)) * np.sin(np.pi * (item / bins)) + np.sin(np.pi * (item / bins)) * np.sin(np.pi / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.where(bins > 0, np.sqrt(item / bins), 0)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(bins + item) / (np.max(bins) - item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(-bins) * np.sin(2 * np.pi * item / bins) + (item * np.cos(np.pi * bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(-bins) * (item + np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(bins) * np.cos(np.pi * item / bins) + np.log(bins) * np.sin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(np.log(bins) + np.log(item))

