 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the difference between item and each bin
    diff = item - bins
    # Apply exponential decay to the difference
    exp_term = np.exp(diff)
    # Calculate standard deviation of bins
    std_dev = np.std(bins)
    # Combine with exponential term and standard deviation
    priority_scores = exp_term * (item * std_dev)
    return priority_scores
