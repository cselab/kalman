```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * (item * np.mean(bins)) + np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item * np.max(bins)) + np.sin(np.pi * (item / np.min(bins)))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item - bins) ** 2 + np.tanh(item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + bins) * np.cos(np.pi * (item / bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item ** bins) + np.exp(item - np.mean(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item / (bins + 1)) + np.log10(item * np.max(bins))

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.arcsin(item / (bins + 1)) + np.cos(np.pi * (item - bins))

