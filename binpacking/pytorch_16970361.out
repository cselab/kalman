def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # For each bin, compute a priority score
    # bins is a 1D array, each element is the size of the bin
    # item is the size of the item to pack
    # We want to prioritize bins that can fit the item and have minimal remaining space
    # One possible heuristic is to compute for each bin the remaining space after placing the item
    # and prioritize bins with smaller remaining space
    remaining = bins - item
    # Only consider bins that can fit the item
    # For bins that cannot fit, set remaining to a large negative value
    remaining = np.where(remaining >= 0, remaining, -np.inf)
    # The priority is the remaining space; lower is better
    # So, we can use 1/(remaining + 1) to make it a positive score that decreases as remaining increases
    priority_score = 1 / (remaining + 1)
    return priority_score

