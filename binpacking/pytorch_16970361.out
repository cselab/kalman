### Implementation 1:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    remaining = bins[:,0] - bins[:,1]
    fit = np.maximum(item / remaining, 0.1)
    diversity = np.abs(bins[:,0] - np.mean(bins[:,0]))
    return (fit * diversity) + (remaining / (item + 1))

