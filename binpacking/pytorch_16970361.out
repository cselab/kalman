### Implementation 1:
def priority(item: float, bins: np.ndarray) -> np.ndarray:
    mask = bins >= item
    remaining = bins - item
    capacity = bins
    priority = (remaining * capacity) / (1 + np.max(bins))
    priority[~mask] = 0
    return priority

