### Solution Code:

```
import numpy as np

def priority1(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.max(bins)) * np.sin(item - np.mean(bins))

def priority2(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * np.log(bins + 1) + np.mean(bins)

def priority3(item: float, float, bins: np.ndarray) -> np.ndarray:
    return (item * np.log(item + 1) + np.mean(bins)) * np.exp(item - bins)

def priority4(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (np.min(bins) * np.max(bins)) + np.sin(np.pi * item)

def priority5(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1) * (np.mean(bins) + np.std(bins))

def priority6(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - np.mean(bins)) * np.sqrt(np.sum(bins))

def priority7(item: float, bins: np.ndarray) -> np.ndarray:
    return (np.exp(item) - np.mean(bins)) * np.max(bins)

def priority8(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * (np.mean(bins) - np.std(bins))

def priority9(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1) * (np.max(bins) - np.min(bins))

def priority10(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item) * np.mean(bins) + np.sin(np.pi * item)
```

