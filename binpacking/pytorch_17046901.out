 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Calculate the remaining capacity after adding the item
    remaining = bins - item
    # Calculate the waste (difference between bin capacity and item size)
    waste = np.abs(bins - item)
    # Calculate the bin capacity
    capacity = bins
    
    # Priority is based on remaining capacity (lower is better), then waste (lower is better), then capacity (lower is better)
    priority = 1 / remaining + 1 / waste + 1 / capacity
    return priority
