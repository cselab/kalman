 def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Heuristic: Place the item in the bin with the smallest remaining space.
    # This minimizes the number of bins by filling them as much as possible.
    remaining_space = bins.max() - item
    return remaining_space

