### Solution Code

```python
import numpy as np

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.std(bins) + np.sin(np.pi * item / bins) + np.cos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.std(bins)) * np.exp(item - bins) + np.sin(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1e-8) * np.exp(bins - item) + np.sin(np.pi * bins / item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) * np.exp(item - bins) + np.cos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item + np.mean(bins)) * np.exp(item - bins) + np.sin(np.pi * bins / item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(item - bins) * np.log(bins + 1e-8) + np.cos(np.pi * item / bins)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.log(item + 1e-8) * np.sin(np.pi * bins / item) + np.cos(np.pi * bins / item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.sqrt(item) * np.sin(np.pi * bins / item) + np.cos(np.pi * bins / item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return (item * np.mean(bins)) * np.exp(bins - item) + np.sin(np.pi * bins / item)

def priority(item: float, bins: np.ndarray) -> np.ndarray:
    return np.exp(bins - item) * np.log(item + 1e-8) + np.sin(np.pi * item / bins)
