def priority(item: float, bins: np.ndarray) -> np.ndarray:
    # Implementation 1: Use the remaining space after placing the item, multiplied by the standard deviation of bins
    remaining = np.maximum(0, bins - item)
    return remaining * np.std(bins) + np.exp(item - bins)

