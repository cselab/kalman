function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S, U, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[np.diag(S) > 1e-8] = 1 / S[np.diag(S) > 1e-8]
    K = P @ (U @ (inv_S * V.T))
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
