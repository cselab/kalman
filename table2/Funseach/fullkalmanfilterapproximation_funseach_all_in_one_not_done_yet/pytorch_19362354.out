def aproximate(x, F, P, Q, z, R):
    import numpy as numpy
    x = numpy.array([0.05 * x[0]**3 - 2*x[0], 0.1 * numpy.sin(x[1])])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
