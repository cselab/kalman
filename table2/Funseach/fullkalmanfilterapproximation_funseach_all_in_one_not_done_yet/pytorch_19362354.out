def aproximate(x, F, P, Q, z, R):
    reg = 1e-8
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    xp = F @ x
    P = F @ (P + reg * np.eye(P.shape[0])) @ F.T + Q + reg * np.eye(Q.shape[0])
    y = z - xp
    S = P + R + reg * np.eye(R.shape[0])
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
