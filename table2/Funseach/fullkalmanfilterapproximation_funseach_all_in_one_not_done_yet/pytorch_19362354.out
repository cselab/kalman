def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    particles = np.random.normal(x, np.sqrt(P))
    weights = np.ones(len(particles))
    xp = np.mean(particles, axis=0)
    P = np.cov(particles - xp)
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(('Particle Filter', np.mean((z - x)**2)))
    return xp, P, y, S, K, x
