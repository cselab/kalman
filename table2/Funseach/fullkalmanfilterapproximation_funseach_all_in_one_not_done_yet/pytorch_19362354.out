def aproximate(x, F, P, Q, z, R):
    from numpy.random import normal
    n = x.size
    m = z.size
    particles = normal(x, np.sqrt(P))[:, None]
    weights = np.ones((len(particles), 1)) / len(particles)
    xp = np.mean(particles, axis=0)
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(n) - K) @ P
    return xp, P, y, S, K, x
