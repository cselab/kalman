def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([0.05 * x[0]**3 - 2 * x[0], 0.1 * np.sin(x[1])])
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    # Exploiting sparsity in S for faster inversion
    if scipy.sparse.issparse(S):
        inv_S = scipy.sparse.linalg.inv(S)
    else:
        inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
