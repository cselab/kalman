def aproximate(x, F, P, Q, z, R):
    from numpy import sqrt, eye
    xp = F @ x
    chol_P = np.linalg.cholesky(P)
    chol_S = np.linalg.cholesky(P + R)
    K = chol_P @ np.linalg.inv(chol_S)
    x = xp + K @ (z - xp)
    P = (eye(F.shape[0]) - K) @ P
    return xp, P, z - xp, P + R, K, x
