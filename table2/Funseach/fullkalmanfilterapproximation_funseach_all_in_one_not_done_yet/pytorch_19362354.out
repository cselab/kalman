def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([0.05 * x[0]**3 - 2 * x[0], 0.1 * np.sin(x[1])])
    xp = F @ x
    P = F @ (P @ F.T) + Q
    y = z - xp
    S = P + R
    # Using SVD for more stable matrix inversion
    U, S, V = np.linalg.svd(S)
    inv_S = np.linalg.inv(S)
    inv_S_matrix = np.zeros_like(S)
    inv_S_matrix[np.where(S != 0)] = inv_S
    inv_S = np.dot(V.T, np.dot(inv_S_matrix, U.T))
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
