def aproximate(x, F, P, Q, z, R):
    x = np.array([
        x[0]**2 - 1.5 * x[0],
        0.1 * np.cos(x[1])
    ])
    F = np.array([
        [1, 0],
        [0, 0.9 * np.cos(x[1])]
