def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([0.05 * x[0]**3 - 2*x[0], 0.1 * np.sin(x[1])])
    Q_scaled = 0.1 * np.eye(F.shape[0])
    P = F @ P @ F.T + Q_scaled
    xp = F @ x
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
