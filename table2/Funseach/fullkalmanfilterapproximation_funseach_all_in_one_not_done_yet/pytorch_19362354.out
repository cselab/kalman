def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3-2*x[0],
        0.1 * np.sin(x[1])
    ])
    sqrt_P = np.linalg.cholesky(P)
    sqrt_Q = np.linalg.cholesky(Q)
    sqrt_S = np.linalg.cholesky(S)
    sqrt_P_new = np.linalg.cholesky(F @ sqrt_P @ F.T + Q)
    y = z - F @ x
    S_inv = np.linalg.inv(S)
    K = sqrt_P_new @ S_inv @ sqrt_P_new.T
    x = F @ x + K @ y
    sqrt_P = np.linalg.cholesky((np.eye(F.shape[0]) - K @ F) @ P)
    return F @ x, P, y, S, K, x
