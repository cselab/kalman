def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    U, S, V = np.linalg.svd(S)
    inv_S = np.zeros_like(S)
    inv_S[S > 1e-8] = 1 / S[S > 1e-8]
    K = P @ (V.T @ (inv_S * (U.T @ y)))
    x = xp + K
    P = (np.eye(F.shape[0]) - K @ np.linalg.inv(S) @ K.T) @ P
    return xp, P, y, S, K, x
