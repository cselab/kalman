def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([0.05 * x[0]**3 - 2*x[0], 0.1 * np.sin(x[1])])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    mahalanobis = y.T @ inv_S @ y
    threshold = 9.21  # For 95% confidence in chi-squared distribution
    scale = 1 + np.where(mahalanobis > threshold, 2, 1)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
