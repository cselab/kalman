def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    components = 3
    weights = np.ones(components) / components
    means = np.random.multivariate_normal(x, P, components)
    covariances = np.array([P] * components)
    xp = np.mean(means, axis=0)
    P = np.mean(weights[:, None, None] * covariances, axis=0)
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(('Gaussian Mixture Filter', np.mean((z - x)**2)))
    return xp, P, y, S, K, x
