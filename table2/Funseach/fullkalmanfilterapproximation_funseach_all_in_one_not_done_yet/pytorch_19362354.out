def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('Runge-Kutta 4th Order', x))
    k1 = F @ x
    k2 = F @ (x + k1 / 2)
    k3 = F @ (x + k2 / 2)
    k4 = F @ (x + k3)
    x_new = x + (k1 + 2*k2 + 2*k3 + k4) / 6
    xp = F @ x_new
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
