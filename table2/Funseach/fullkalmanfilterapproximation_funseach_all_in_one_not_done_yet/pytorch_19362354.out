function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    mahalanobis = y.T @ np.linalg.inv(S) @ y
    scale = 1 + 1.0 * np.clip(mahalanobis - 1, 0, None)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
score: 31.29364410179473
function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Add small epsilon to diagonal to avoid singular matrix
    if np.count_nonzero(S.diagonal()) == 0:
        epsilon = 1e-8
        S += np.eye(S.shape[0]) * epsilon
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
