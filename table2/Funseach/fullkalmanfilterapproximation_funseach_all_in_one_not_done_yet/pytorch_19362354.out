def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('Unscented Kalman Filter', x))
    n = x.shape[0]
    m = z.shape[0]
    lambda_ = 0.0
    sigma = np.sqrt(P)
    sigma = np.concatenate((sigma, -sigma))
    sigma = np.concatenate((sigma, np.zeros(n)))
    x_aug = np.concatenate((x, sigma))
    x_aug = x_aug.reshape(-1, 1)
    X = F @ x_aug
    P_x = F @ P @ F.T + Q
    y = z - X
    S = P_x + R
    K = P_x @ np.linalg.inv(S)
    x = X + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_x
    return X, P, y, S, K, x
