def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    innovation_magnitude = np.linalg.norm(y)
    K = K * np.clip(innovation_magnitude / np.sqrt(S.diagonal()).mean(), 0.5, 2)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
