def aproximate(x, F, P, Q, z, R):
    sqrt_P = np.linalg.cholesky(P)
    sqrt_Pn = F @ sqrt_P
    Pn = sqrt_Pn @ sqrt_Pn.T + Q
    y = z - F @ x
    S = Pn + R
    inv_S = np.linalg.inv(S)
    K = sqrt_Pn @ (sqrt_Pn.T @ (F.T @ (inv_S @ y)))
    x = F @ x + K
    P = Pn - K @ (F @ K.T)
    return F @ x, P, y, S, K, x
