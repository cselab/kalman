def aproximate(x, F, P, Q, z, R):
    import numpy as np
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = np.linalg.solve(S, P @ y)
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
