def aproximate(x, F, P, Q, z, R):
    global history
    # Update state
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    # Save the current state for history
    history.append(x.copy())
    # Compute predicted state
    xp = F @ x
    # Update covariance matrix
    P = F @ P @ F.T + Q
    # Compute innovation
    y = z - xp
    # Compute total error covariance
    S = P + R
    # Compute Kalman gain
    K = P @ np.linalg.inv(S)
    # Update state estimate
    x = xp + K @ y
    # Update covariance
    P = (np.eye(F.shape[0]) - K) @ P
    # Return the computed values
    return xp, P, y, S, K, x
