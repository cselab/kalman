function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Add a small epsilon to S to avoid singular matrices
    epsilon = 1e-8 * np.eye(S.shape[0])
    S_inv = np.linalg.inv(S + epsilon)
    K = 0.5 * P @ S_inv
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
