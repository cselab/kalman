function:
def aproximate(x, F, P, Q, z, R):
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Add cross-correlation between measurements
    y = y + 0.5 * np.mean(y) * np.random.randn(*z.shape)
    S = P + R + 0.5 * np.mean(y) * np.eye(S.shape[0])
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
