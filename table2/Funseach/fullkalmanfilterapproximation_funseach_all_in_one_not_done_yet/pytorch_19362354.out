def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    reg = 1e-8
    xp = F @ x
    P = F @ P @ F.T + Q + reg * np.eye(F.shape[0])
    y = z - xp
    S = P + R + reg * np.eye(F.shape[0])
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
