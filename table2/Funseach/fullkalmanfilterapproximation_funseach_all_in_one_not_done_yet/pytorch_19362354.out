function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    n = x.shape[0]
    sigma_points = np.zeros((2n + 1, n))
    sigma_points[0] = x
    for i in range(n):
        sigma_points[i+1] = x + np.sqrt(P[i,i])
        sigma_points[i+1+n] = x - np.sqrt(P[i,i])
    sigma_points = np.array(sigma_points)
    sigma_x = F @ sigma_points.T
    xp = np.mean(sigma_x.T, axis=0)
    P_x = np.cov(sigma_x.T) + Q
    y = z - xp
    S = P_x + R
    inv_S = np.linalg.inv(S)
    K = P_x @ inv_S
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P_x
    history.append(('Unscented Kalman Filter', np.mean((z - x)**2)))
    return xp, P, y, S, K, x
