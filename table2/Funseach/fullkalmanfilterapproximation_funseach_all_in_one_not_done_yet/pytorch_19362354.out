def aproximate(x, F, P, Q, z, R):
    import numpy as vectorized operations.
    x = np.array([0.05 * x[0]**3 - 2*x[0], 0.1 * np.sin(x[1])])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    mahalanobis = np.dot(y.T, inv_S @ y)
    scale = 1 + 0.1 * np.exp(mahalanobis - 2)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
