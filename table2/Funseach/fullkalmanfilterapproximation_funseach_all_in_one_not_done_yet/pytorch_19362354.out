def aproximate(x, F, P, Q, z, R):
    from numpy import diag
    n = x.size
    m = z.size
    F = np.block([[F, np.zeros((n, m))],
                 [np.zeros((m, n)), diag(R)]])
    x = np.concatenate([x, z])
    P = np.block([[P, np.zeros((n, m))],
                 [np.zeros((m, n)), R]])
    Q = np.zeros((n + m, n + m))
    y = F @ x
    S = F @ P @ F.T + Q
    K = P @ np.linalg.inv(S)
    x = F @ x + K @ (y - F @ x)
    x_state = x[:n]
    P_state = P[:n, :n]
    return y, P_state, y - x_state, S, K, x_state
