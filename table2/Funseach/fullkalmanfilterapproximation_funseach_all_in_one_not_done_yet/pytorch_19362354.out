function:
def aproximate(x, F, P, Q, z, R):
    x = np.array([0.05 * x[0]**3 - 2 * x[0], 0.1 * np.sin(x[1])])
    n = x.shape[0]
    m = 2 * n + 1
    sigma_points = np.zeros((n, m))
    for i in range(n):
        sigma_points[i, i] = np.sqrt(3 * P[i,i])
    sigma_points[:,0] = x
    sigma_points[:,n+1:] = x + sigma_points[:,1:n+1]
    sigma_points[:,1:n+1] = x - sigma_points[:,1:n+1]
    sigma_points = F(sigma_points.T).T
    xp = sigma_points.mean(axis=1)
    P = np.cov(sigma_points) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    K = P @ inv_S
    x = xp + K @ y
    P = (np.eye(n) - K) @ P
    return xp, P, y, S, K, x
