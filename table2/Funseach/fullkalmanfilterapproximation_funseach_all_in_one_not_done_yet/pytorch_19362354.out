function:
def aproximate(x, F, P, Q, z, R):
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # State-dependent noise scaling
    noise_scale = np.exp(0.1 * np.abs(x))
    Q_adj = Q * noise_scale
    P = F @ P @ F.T + Q_adj
    return xp, P, y, S, K, x
