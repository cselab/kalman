function:
def aproximate(x, F, P, Q, z, R):
    import multiprocessing as mp
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Parallel processing
    with mp.Pool() as pool:
        results = pool.map(lambda func: func(), [lambda: np.array([0.05 * x[0]**3 - 2 * x[0]]), lambda: np.array([0.1 * np.sin(x[1])])])
    x = np.concatenate(results)
    return xp, P, y, S, K, x
