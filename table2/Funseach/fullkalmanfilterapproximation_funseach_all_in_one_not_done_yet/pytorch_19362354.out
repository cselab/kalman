function:
def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    # Handle singular S
    if np.count_nonzero(S.diagonal()) == 0:
        epsilon = 1e-8
        S += np.eye(S.shape[0]) * epsilon
    # Dynamic scaling based on innovation magnitude
    innovation_magnitude = np.linalg.norm(y)
    scale = 1 + 1.0 * np.clip(innovation_magnitude - 1, 0, None)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
