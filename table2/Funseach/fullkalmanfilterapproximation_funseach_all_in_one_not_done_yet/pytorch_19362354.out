    scale = 1 + c * np.clip(mahalanobis - 1, 0, 2)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S_adj, K, x
