function:
def aproximate(x, F, P, Q, z, R):
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    # Nonlinear observation model
    H = np.zeros((z.shape[0], x.shape[0]))
    H[:, 0] = 0.05 * x[0]**2
    H[:, 1] = 0.1 * np.cos(x[1])
    y_pred = H @ x
    e = z - y_pred
    S = H @ P @ H.T + R
    K = P @ H.T @ np.linalg.inv(S)
    x = x + K @ e
    P = P - K @ H @ P
    return y_pred, P, e, S, K, x
