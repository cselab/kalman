def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('Adams-Bashforth 2nd Order', x))
    if len(history) < 2:
        k1 = F @ x
        k2 = F @ (x + k1)
        x_new = x + (k1 + k2) / 2
    else:
        prev_x = history[-1][1]
        k1 = F @ x
        k2 = F @ prev_x
        x_new = x + (3*k1 - k2) / 2
    xp = F @ x_new
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
