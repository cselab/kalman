def aproximate(x, F, P, Q, z, R):
    global history
    history.append(('Symplectic Integrator', x))
    q, p = x[:len(x)//2], x[len(x)//2:]
    k1 = F[:len(x)//2, :len(x)//2] @ q
    k2 = F[len(x)//2:, :len(x)//2] @ q
    k3 = -F[:len(x)//2, len(x)//2:] @ p
    k4 = -F[len(x)//2:, len(x)//2:] @ p
    q_new = q + k1 + k3
    p_new = p + k2 + k4
    x_new = np.concatenate((q_new, p_new))
    xp = F @ x_new
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
