function:
def aproximate(x, F, P, Q, z, R):
    from scipy.optimize import linear_sum_assignment
    n = x.size
    m = z.size
    cost = np.zeros((n, m))
    for i in range(n):
        for j in range(m):
            cost[i, j] = np.linalg.norm(x[i] - z[j])
    row_ind, col_ind = linear_sum_assignment(cost)
    x = x[row_ind]
    z = z[col_ind]
    P = np.zeros((n, n))
    for i in range(n):
        P[i, i] = np.linalg.norm(x[i] - z[col_ind[i]])
    return x, P, z - x, P + R, np.zeros((n, m)), x
