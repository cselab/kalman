function:
def aproximate(x, F, P, Q, z, R):
    global history
    history.append(x.copy())
    
    # State transition
    xp = F @ x
    
    # Update state covariance
    P = F @ P @ F.T + Q
    
    # Measurement residual
    y = z - xp
    
    # Innovation covariance
    S = P + R
    
    # Invert innovation covariance
    inv_S = np.linalg.inv(S)
    
    # Mahalanobis distance
    mahalanobis = np.dot(y.T, inv_S @ y)
    
    # Scale factor for R
    scale = 1 + 0.1 * np.tanh(mahalanobis)
    
    # Adjusted R
    R_adj = R * scale
    
    # Adjusted S
    S_adj = P + R_adj
    
    # Kalman gain
    K = P @ np.linalg.inv(S_adj)
    
    # Update state
    x = xp + K @ y
    
    # Update state covariance
    P = (np.eye(F.shape[0]) - K) @ P
    
    return xp, P, y, S_adj, K, x
