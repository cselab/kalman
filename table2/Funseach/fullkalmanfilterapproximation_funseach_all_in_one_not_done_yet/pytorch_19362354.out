def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    clip_factor = 0.5
    K_clipped = np.clip(K, None, clip_factor)
    x = xp + K_clipped @ y
    P = (np.eye(F.shape[0]) - K_clipped @ np.linalg.inv(S) @ K_clipped.T) @ P
    return xp, P, y, S, K_clipped, x
