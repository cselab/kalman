def aproximate(x, F, P, Q, z, R):
    damping = 0.95
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0]
    ])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = P @ np.linalg.inv(S)
    x = xp + damping * K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
