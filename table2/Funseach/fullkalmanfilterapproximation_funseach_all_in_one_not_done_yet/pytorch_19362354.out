    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = (P @ y) / (y.T @ S @ y)
    x = xp + K * y
    P = (np.eye(F.shape[0]) - K) @ P
    return xp, P, y, S, K, x
