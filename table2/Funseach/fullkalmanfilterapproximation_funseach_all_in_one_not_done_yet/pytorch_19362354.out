def aproximate(x, F, P, Q, z, R):
    n = x.size
    m = z.size
    F_aug = np.block([[F, np.zeros((n, m))],
                      [np.zeros((m, n)), np.eye(m)]])
    x_aug = np.concatenate([x, z])
    P_aug = np.block([[P, np.zeros((n, m))],
                     [np.zeros((m, n)), R]])
    Q_aug = np.zeros((n + m, n + m))
    y = F_aug @ x_aug
    S = F_aug @ P_aug @ F_aug.T + Q_aug
    K = P_aug @ np.linalg.inv(S)
    x_aug = F_aug @ x_aug + K @ (y - x_aug)
    x = x_aug[:n]
    P = P_aug[:n, :n]
    return y, P, y - x_aug[:n], S, K, x
