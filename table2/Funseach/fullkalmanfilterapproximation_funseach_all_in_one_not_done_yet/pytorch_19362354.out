def aproximate(x, F, P, Q, z, R):
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    huber_threshold = 1.0
    M = np.zeros_like(y)
    M[np.abs(y) > huber_threshold] = huber_threshold
    S_robust = S + R * (1 - (1 - (y / huber_threshold)**2)**2)
    K = P @ np.linalg.inv(S_robust)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K @ np.linalg.inv(S_robust) @ K.T) @ P
    return xp, P, y, S_robust, K, x
