def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    c = 1.0
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    mahalanobis = y.T @ np.linalg.inv(S) @ y
    scale = 1 + c * np.clip(mahalanobis - 1, 0, None)
    R_adj = R * scale
    S_adj = P + R_adj
    K = P @ np.linalg.inv(S_adj)
    x = xp + K @ y
    P = (np.eye(F.shape[0]) - K) @ P
    history.append(('Modified Kalman Filter', np.mean((z - x)**2)))
    return xp, P, y, S_adj, K, x
