function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3 - 2 * x[0],
        0.1 * np.sin(x[1])
    ])
    xp = F.dot(x)
    P = F.dot(P.dot(F.T)) + Q
    y = z - xp
    S = P + R
    inv_S = np.linalg.inv(S)
    loss = np.sum(y.T.dot(inv_S.dot(y)))
    K = P.dot(inv_S)
    x = xp + K.dot(y)
    P = (np.eye(F.shape[0]) - K).dot(P)
    return xp, P, y, S, K, x
