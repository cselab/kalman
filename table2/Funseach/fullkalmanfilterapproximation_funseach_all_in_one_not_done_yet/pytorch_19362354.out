function:
def aproximate(x, F, P, Q, z, R):
    import numpy as np
    x = np.array([
        0.05 * x[0]**3-2*x[0],
        0.1 * np.sin(x[1])
    ])
    xp = F @ x
    P = F @ P @ F.T + Q
    y = z - xp
    S = P + R
    K = np.linalg.solve(S, P @ y)  # K = P @ inv(S) @ y
    x = xp + K
    P = P - K @ K.T
    return xp, P, y, S, K, x
